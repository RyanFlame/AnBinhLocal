      <div class="faq-list">
        <!-- Question 1 -->
        <div class="faq-item">
          <button class="faq-question">
            <h3
              class="lang-text"
              data-en="What types of conditions can Traditional Medicine treat?"
              data-vn="Đông y có thể điều trị những loại bệnh nào?"
            >
              Đông y có thể điều trị những loại bệnh nào?
            </h3>
            <div class="faq-toggle-icon"></div>
          </button>
          <div class="faq-answer">
            <p
              class="lang-text"
              data-en="Traditional Medicine is effective for a wide range of conditions, including chronic pain, digestive issues, stress-related disorders, insomnia, and hormonal imbalances. We take a holistic approach to address the root cause of your symptoms."
              data-vn="Y học cổ truyền mang lại hiệu quả cao đối với nhiều loại bệnh lý như đau mãn tính, các vấn đề về tiêu hóa, căng thẳng, rối loạn giấc ngủ và mất cân bằng nội tiết tố. Chúng tôi tiếp cận toàn diện để giải quyết nguyên nhân gốc rễ gây ra triệu chứng của bạn."
            >
