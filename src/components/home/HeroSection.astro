          ></path></svg
        >
      </a>
    </div>
  </div>
</header>

<style>
  /* ===============================
   HERO SECTION (FADE OUT EFFECT)
   =============================== */

  .hero-section {
    height: 120vh;
    width: 100%;
    border: none;

    /* Desktop Hero Image fallback via CSS variable */
    background-image: var(--hero-bg);
    background-size: cover;
    background-position: center;

    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    position: relative;
    overflow: hidden; /* REQUIRED for fade */
  }

  /* --- Hero Redesign Layout --- */
  .hero-layout-container {
    width: 100%;
    max-width: 1200px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 0 40px;
    margin-top: 60px;
    z-index: 3;
  }

  .hero-left-col {
    flex: 1;
    max-width: 550px;
    text-align: left;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: 4.5rem !important;
    font-weight: 600;
    color: var(--cream-rice);
    line-height: 1.1;
    margin-bottom: 30px;
    text-shadow: 0 4px 15px rgba(0, 0, 0, 0.5);
  }

  .hero-desc {
    font-size: 1.15rem;
    color: var(--cream-rice);
    margin-top: 30px;
    line-height: 1.6;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
  }

  .btn-hero-primary {
    background-color: var(--mustard-gold);
    color: var(--mahogany-dark);
    font-size: 1.1rem;
    padding: 14px 35px;
    border: none;
    font-weight: 700;
  }
  .btn-hero-primary:hover {
    background-color: #e0b04c;
    color: var(--mahogany-dark);
    border-color: transparent;
  }

  /* --- Right Side Card --- */
  .hero-right-col {
    flex: 1;
    display: flex;
    justify-content: flex-end;
  }

  .hero-floating-card {
    width: 360px;
    border-radius: 20px;
    padding: 15px;
    background: rgba(40, 40, 40, 0.45);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow: 0 15px 45px rgba(0, 0, 0, 0.4);
  }

  .floating-card-img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: 12px;
    margin-bottom: 15px;
  }

  .floating-card-address {
    font-size: 0.95rem;
    color: var(--cream-rice);
    line-height: 1.4;
    margin-bottom: 15px;
    font-weight: 600;
  }

  .floating-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .floating-card-status {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.8);
  }

  .icon-btn-arrow {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--cream-rice);
    color: var(--mahogany-dark);
    display: flex;
    justify-content: center;
    align-items: center;
    transition: transform 0.2s ease;
    text-decoration: none;
  }
  .icon-btn-arrow:hover {
    transform: translateX(3px);
  }

  /* --- Bottom Booking Bar --- */
  .hero-bottom-bar {
    width: 100%;
    max-width: 1200px;
    margin: 80px auto 0;
    padding: 0 40px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    z-index: 3;
  }

  .hero-booking-bar {
    display: flex;
    align-items: center;
    background: rgba(40, 40, 40, 0.45);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    padding: 10px 10px 10px 40px;
    filter: drop-shadow(0 15px 45px rgba(0, 0, 0, 0.4));

    /* Scooped Corners Mask */
    --scoop-radius: 25px;
    -webkit-mask-image:
      radial-gradient(
        circle at top left,
        transparent var(--scoop-radius),
        black calc(var(--scoop-radius) + 0.5px)
      ),
      radial-gradient(
        circle at top right,
        transparent var(--scoop-radius),
        black calc(var(--scoop-radius) + 0.5px)
      ),
      radial-gradient(
        circle at bottom left,
        transparent var(--scoop-radius),
        black calc(var(--scoop-radius) + 0.5px)
      ),
      radial-gradient(
        circle at bottom right,
        transparent var(--scoop-radius),
        black calc(var(--scoop-radius) + 0.5px)
      );
    -webkit-mask-position:
      top left,
      top right,
      bottom left,
      bottom right;
    -webkit-mask-size: 51% 51%;
    -webkit-mask-repeat: no-repeat;

    mask-image:
      radial-gradient(
        circle at top left,
        transparent var(--scoop-radius),
        black calc(var(--scoop-radius) + 0.5px)
      ),
      radial-gradient(
        circle at top right,
        transparent var(--scoop-radius),
        black calc(var(--scoop-radius) + 0.5px)
      ),
      radial-gradient(
        circle at bottom left,
        transparent var(--scoop-radius),
        black calc(var(--scoop-radius) + 0.5px)
      ),
      radial-gradient(
        circle at bottom right,
        transparent var(--scoop-radius),
        black calc(var(--scoop-radius) + 0.5px)
      );
    mask-position:
      top left,
      top right,
      bottom left,
      bottom right;
    mask-size: 51% 51%;
    mask-repeat: no-repeat;
  }

  .booking-segment {
    display: flex;
    flex-direction: column;
    padding: 0 25px;
    cursor: pointer;
  }
  .booking-segment:first-child {
    padding-left: 0;
  }

  .segment-label {
    font-size: 0.9rem;
    color: var(--cream-rice);
    font-weight: 700;
    margin-bottom: 4px;
  }

  .segment-value {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.7);
  }

  .segment-divider {
    width: 1px;
    height: 45px;
    background: rgba(255, 255, 255, 0.2);
  }

  .btn-booking-submit {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 15px 30px;
    border-radius: 40px;
    margin-left: 20px;
    cursor: pointer;
  }
  .search-icon {
    width: 20px;
    height: 20px;
  }

  /* Scroll Indicator & Socials */
  .hero-scroll-indicator,
  .hero-socials {
    display: flex;
    align-items: center;
    gap: 15px;
    padding-bottom: 10px;
  }

  .scroll-circle {
    width: 45px;
    height: 45px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.4);
    color: var(--cream-rice);
    display: flex;
    justify-content: center;
    align-items: center;
    transition: all 0.3s ease;
  }
  .scroll-circle:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: var(--cream-rice);
  }

  .social-link {
    color: var(--cream-rice);
    opacity: 0.8;
    transition: opacity 0.3s ease;
  }
  .social-link:hover {
    opacity: 1;
  }

  /* ===============================
   MOBILE ADJUSTMENTS
   =============================== */

  @media screen and (max-width: 900px) {
    .hero-section {
      /* On mobile, we still use the background-image variable but allow specialized positioning */
      background-image: var(--hero-bg);
      background-size: cover;
      background-position: top center;
      background-attachment: scroll;
      justify-content: space-between;
      padding-top: 12vh;
      padding-bottom: 10vh;
    }

    .hero-layout-container {
      flex-direction: column;
      align-items: center;
      text-align: center;
      margin-top: 0;
    }

    .hero-left-col {
      text-align: center;
      margin-bottom: 40px;
    }

    .hero-title {
      font-size: 3rem;
    }

    .hero-right-col {
      justify-content: center;
    }

    .hero-bottom-bar {
      flex-direction: column;
      align-items: center;
      gap: 30px;
      margin-top: auto;
    }

    .hero-booking-bar {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-areas:
        "treat date"
        "name time"
        "btn btn";
      gap: 8px;
      padding: 15px;
      width: 100%;
      --scoop-radius: 12px; /* smaller corner scoops for mobile layout */
    }

    .booking-segment {
      padding: 0 5px;
    }

    .segment-label {
      font-size: 0.8rem;
      margin-bottom: 2px;
    }

    .segment-value {
      font-size: 0.9rem;
    }

    /* Assign specific grid areas based on HTML classes */
    .segment-treatment {
      grid-area: treat;
    }
    .segment-date {
      grid-area: date;
    }
    .segment-name {
      grid-area: name;
    }
    .segment-time {
      grid-area: time;
    }

    .segment-divider {
      display: none; /* Hide native flex dividers in grid view */
    }

    .btn-booking-submit {
      grid-area: btn;
      margin-left: 0;
      margin-top: 5px;
      padding: 10px;
      font-size: 1rem;
      width: 100%;
      justify-content: center;
    }
  }

  @media screen and (max-width: 768px) {
    .hero-title {
      font-size: 2.5rem;
    }
    .hero-layout-container {
      margin-top: 0;
    }
  }

  @media screen and (max-width: 480px) {
    .hero-title {
      font-size: 2.1rem;
    }
    .hero-desc {
      font-size: 1.05rem;
    }
  }
</style>

<script is:inline>
  (() => {
    const hero = document.querySelector('.hero-section');
    if (!hero) return;

    let blurFrame = null;
    let lastBlur = -1;

    function updateBlur() {
        const rect = hero.getBoundingClientRect();
        const windowHeight = window.innerHeight;
        const progress = Math.min(Math.max((windowHeight - rect.bottom) / windowHeight, 0), 1);
        const blur = progress * progress * 12;

        if (Math.abs(blur - lastBlur) < 0.1) return;
        lastBlur = blur;
        hero.style.setProperty('--hero-blur', `${blur}px`);
    }

    function requestBlurUpdate() {
        if (blurFrame !== null) return;
        blurFrame = window.requestAnimationFrame(() => {
            blurFrame = null;
            updateBlur();
        });
    }

    window.addEventListener('scroll', requestBlurUpdate, { passive: true });
    window.addEventListener('resize', requestBlurUpdate);
    requestBlurUpdate();
  })();
</script>
