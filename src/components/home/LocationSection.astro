---
import { Image } from "astro:assets";
import { getImageByPath } from "../../utils/assets";
import { useTranslations } from "../../i18n/utils";

const { locale = "vi" } = Astro.props;
const t = useTranslations(locale);

const location_1 = getImageByPath(t("location.step1.image")) || getImageByPath("Location/outside.webp");
const location_2 = getImageByPath(t("location.step2.image")) || getImageByPath("Location/inside.webp");
const location_3 = getImageByPath(t("location.step3.image")) || getImageByPath("Location/healing.webp");

const asset_Thu_c_1_webp = getImageByPath("Thuốc 1.webp");
const asset_Thu_c_2_webp = getImageByPath("Thuốc 2.webp");
const asset_Thu_c_webp = getImageByPath("Thuốc 3.webp");

const carouselData = [
  {
    bg: location_1?.src,
    sub: t("location.step1.sub"),
    heading: t("location.step1.heading"),
    btnText: t("location.step1.btn_text"),
    btnLink: "https://www.google.com/maps/place/Ph%C3%B2ng+Y+H%E1%BB%8Dc+C%E1%BB%95+Truy%E1%BB%81n+An+B%C3%ACnh/@10.5085571,107.327058,455m"
  },
  {
    bg: location_2?.src,
    sub: t("location.step2.sub"),
    heading: t("location.step2.heading"),
    btnText: t("location.step2.btn_text"),
    btnLink: "https://www.google.com/maps/place/Ph%C3%B2ng+Y+H%E1%BB%8Dc+C%E1%BB%95+Truy%E1%BB%81n+An+B%C3%ACnh/@10.5085571,107.327058,455m"
  },
  {
    bg: location_3?.src,
    sub: t("location.step3.sub"),
    heading: t("location.step3.heading"),
    btnText: t("location.step3.btn_text"),
    btnLink: "#booking"
  }
];
---

<section class="location-section" id="location" data-header-theme="dark" data-carousel={JSON.stringify(carouselData)}>
  <div class="location-container">
    <!-- Background Image -->
    <img
      src={location_1?.src}
      class="location-bg-img"
      id="locationBg"
      alt="Location Background"
    />

    <!-- Left Overlay Content -->
    <div class="location-content">
      <div class="location-steps">
        <div class="step-indicator" data-index="0">
          <span class="step-circle active">1</span>
        </div>
        <div class="step-line">
          <div class="step-progress" id="progress0"></div>
        </div>

        <div class="step-indicator" data-index="1">
          <span class="step-circle">2</span>
        </div>
        <div class="step-line">
          <div class="step-progress" id="progress1"></div>
        </div>

        <div class="step-indicator" data-index="2">
          <span class="step-circle">3</span>
        </div>
      </div>

      <div class="location-text">
        <p class="location-sub sub-heading" id="locationSub">
          {t("location.step1.sub")}
        </p>
        <h2
          class="location-heading heading-hero"
          id="locationHeading"
          set:html={t("location.step1.heading")}
        />
        <a
          href={carouselData[0].btnLink}
          class="btn-primary location-btn"
          id="locationBtn"
          target="_blank">{t("location.step1.btn_text")}</a
        >
        <button class="play-btn">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"
            ><path d="M8 5v14l11-7z"></path></svg
          >
        </button>
      </div>
    </div>

    <!-- Bottom Right "Scooped" Card -->
    <div class="location-corner-card">
      <div class="corner-content">
        <span class="corner-label">{t("location.corner.know_more")}</span>
        <div class="corner-thumbnails">
          <Image src={asset_Thu_c_1_webp} alt="Place 1" />
          <Image src={asset_Thu_c_2_webp} alt="Place 2" />
          <Image src={asset_Thu_c_webp} alt="Place 3" />
          <div class="corner-text">
            <strong>{t("location.corner.title")}</strong>
            <small>{t("location.corner.subtitle")}</small>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* =========================================
   LOCATION SECTION (Carousel)
   ========================================= */
  .location-section {
    padding: 80px 20px;
    background-color: var(--bg-main);
    display: flex;
    justify-content: center;
  }

  .location-container {
    width: 100%;
    max-width: 1400px;
    height: 550px;
    border-radius: 40px;
    position: relative;
    overflow: hidden; /* Clips the background image */
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    background-color: #dbeaf9; /* Fallback blue */
  }

  /* Background Image */
  .location-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
    z-index: 1;
  }

  /* Left Content */
  .location-content {
    position: relative;
    z-index: 2;
    padding: 60px;
    height: 100%;
    display: flex;
    gap: 30px;
    background: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0.8) 0%,
      rgba(255, 255, 255, 0) 100%
    ); /* Fade for readability */
  }

  .location-steps {
    display: flex;
    flex-direction: column;
    align-items: start;
    padding-top: 10px;
  }

  .step-indicator {
    cursor: pointer;
    transition: transform 0.2s ease;
  }

  .step-indicator:hover {
    transform: scale(1.1);
  }

  .step-circle {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    color: var(--text-brown);
    backdrop-filter: blur(5px);
    transition: all 0.3s ease;
  }

  .step-circle.active {
    background: var(--mustard-gold);
    color: white;
    box-shadow: 0 0 15px rgba(200, 169, 126, 0.6);
  }

  .step-line {
    width: 2px;
    height: 60px;
    background: rgba(255, 255, 255, 0.4);
    margin: 5px 0;
    position: relative;
    overflow: hidden;
  }

  .step-progress {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 0%;
    background: var(--mustard-gold);
  }

  /* On mobile, step-line width is 40px, height is 2px. progress should fill width instead of height. */
  @media screen and (max-width: 768px) {
    .step-progress {
      width: 0%;
      height: 100%;
    }
  }

  .location-text {
    padding-top: 10px;
  }

  .location-sub {
    font-size: 0.9rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-brown);
    margin-bottom: 10px;
    font-weight: 600;
  }

  .location-heading {
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: 3.5rem;
    line-height: 1.1;
    color: #1a1a1a;
    margin-bottom: 40px;
  }

  .location-btn {
    display: inline-block;
    padding: 15px 35px;
    background-color: #2d8cff;
    color: white;
    border-radius: 30px;
    text-decoration: none;
    font-weight: 600;
    box-shadow: 0 10px 20px rgba(45, 140, 255, 0.3);
    transition: transform 0.2s;
  }

  .location-btn:hover {
    transform: translateY(-2px);
  }

  .play-btn {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: white;
    border: none;
    margin-left: 20px;
    cursor: pointer;
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    color: #2d8cff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    vertical-align: middle;
  }

  /* 
   ---------------------------------
   THE MAGIC "SCOOPED" CORNER CARD 
   ---------------------------------
*/
  .location-corner-card {
    position: absolute;
    bottom: 0px;
    right: 0px;
    z-index: 10;
    background-color: #fff;
    padding: 30px 40px;

    border-top-left-radius: 40px;
    min-width: 300px;
  }

  .location-corner-card::before {
    content: "";
    position: absolute;
    top: -40px;
    right: 0;
    width: 40px;
    height: 40px;
    background: transparent;
    border-bottom-right-radius: 50%;
    box-shadow: 20px 20px 0 20px #fff;
    z-index: 5;
  }

  .location-corner-card::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: -40px;
    width: 40px;
    height: 40px;
    background: transparent;
    border-bottom-right-radius: 50%;
    box-shadow: 20px 20px 0 20px #fff;
    z-index: 5;
  }

  /* Corner Content Styling */
  .corner-content {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .corner-label {
    font-weight: 700;
    font-size: 1.1rem;
    color: #1a1a1a;
    display: flex;
    justify-content: space-between;
  }

  .corner-thumbnails {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .corner-thumbnails img {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid #fff;
    box-shadow: 0 5px 10px rgba(0, 0, 0, 0.1);
    margin-left: -5px; /* Overlap */
  }
  .corner-thumbnails img:first-child {
    margin-left: 0;
  }

  .corner-text {
    margin-left: 10px;
    display: flex;
    flex-direction: column;
  }
  .corner-text strong {
    font-size: 0.9rem;
    color: #333;
  }
  .corner-text small {
    font-size: 0.75rem;
    color: #888;
  }

  @media screen and (max-width: 768px) {
    .location-container {
      height: auto;
      display: flex;
      flex-direction: column;
      border-radius: 20px;
      padding-bottom: 0px;
    }
    .location-content {
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      align-items: center;
      padding: 460px 20px 40px;
      text-align: center;
      background: linear-gradient(
        180deg,
        rgba(255, 255, 255, 0) 0%,
        rgba(255, 255, 255, 0) 60%,
        rgba(255, 255, 255, 0.95) 80%,
        rgba(255, 255, 255, 1) 100%
      );
      min-height: 100%;
    }

    .location-steps {
      flex-direction: row;
      justify-content: center;
      width: 100%;
      margin-bottom: 30px;
      padding: 0;
      position: absolute;
      top: 30px;
    }
    .step-line {
      width: 45px;
      height: 3px;
      margin: 15px 15px;
    }
    .location-heading {
      font-size: 2.2rem;
      margin-bottom: 20px;
    }
    .location-sub {
      display: none;
    }
    .play-btn {
      display: none;
    }
    .location-corner-card {
      display: none;
    }
  }
</style>

<script>
  declare const gsap: any;
  document.addEventListener("DOMContentLoaded", () => {
    const section = document.getElementById('location');
    if (!section) return;
    const carouselData = JSON.parse(section.dataset.carousel || '[]');
    const locBg = document.getElementById('locationBg') as HTMLImageElement;
    const locSub = document.getElementById('locationSub') as HTMLElement;
    const locHeading = document.getElementById('locationHeading') as HTMLElement;
    const locBtn = document.getElementById('locationBtn') as HTMLAnchorElement;
    const stepIndicators = document.querySelectorAll('.step-indicator');
    const progressBars = document.querySelectorAll('.step-progress');
    const playBtnEl = document.querySelector('.play-btn') as HTMLElement;

    let currentLocIndex = 0;
    let autoPlayTimer;
    let progressTween;
    let isPaused = false;
    let remainingTime = 8000;
    let autoPlayStartTime = 0;
    const CAROUSEL_INTERVAL = 8000;

    const playBtnSvgPause = `<svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><rect x="6" y="4" width="4" height="16"></rect><rect x="14" y="4" width="4" height="16"></rect></svg>`;
    const playBtnSvgPlay = `<svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M8 5v14l11-7z"></path></svg>`;

    function updateCarouselInnerContent(data) {
        locSub.innerHTML = data.sub;
        locHeading.innerHTML = data.heading;
        locBtn.innerHTML = data.btnText;
        locBtn.href = data.btnLink;
        if (data.btnLink.startsWith("http")) locBtn.target = "_blank";
        else locBtn.target = "_self";
    }

    function updateCarousel(newIndex) {
        if (newIndex === currentLocIndex) return;
        
        if (typeof gsap !== 'undefined') {
            const tl = gsap.timeline();
            tl.to([locSub, locHeading, locBtn], { opacity: 0, y: 10, duration: 0.3, stagger: 0.05, ease: "power1.inOut" })
              .to(locBg, { opacity: 0, duration: 0.4, ease: "power1.inOut" }, "-=0.2")
              .call(() => {
                  const data = carouselData[newIndex];
                  locBg.src = data.bg;
                  updateCarouselInnerContent(data);
              })
              .to(locBg, { opacity: 1, duration: 0.5, ease: "power1.inOut" })
              .to([locSub, locHeading, locBtn], { opacity: 1, y: 0, duration: 0.4, stagger: 0.1, ease: "power2.out" }, "-=0.3");
        } else {
            const data = carouselData[newIndex];
            locBg.src = data.bg;
            updateCarouselInnerContent(data);
        }

        stepIndicators.forEach((ind, i) => {
            const circle = ind.querySelector('.step-circle');
            if (i === newIndex) circle.classList.add('active');
            else circle.classList.remove('active');
        });

        currentLocIndex = newIndex;
        if (!isPaused) startAutoPlay();
    }

    function startAutoPlay(duration = CAROUSEL_INTERVAL) {
        if (autoPlayTimer) clearTimeout(autoPlayTimer);
        if (progressTween) progressTween.kill();
        
        const isMobile = window.innerWidth <= 768;
        progressBars.forEach(bar => {
            if (typeof gsap !== 'undefined') {
                gsap.set(bar, { width: isMobile ? "0%" : "100%", height: isMobile ? "100%" : "0%" });
            }
        });

        const activeProgressBar = document.getElementById(`progress${currentLocIndex}`);
        if (activeProgressBar && typeof gsap !== 'undefined') {
            progressTween = gsap.to(activeProgressBar, {
                width: "100%",
                height: "100%",
                duration: duration / 1000,
                ease: "linear"
            });
        }

        autoPlayStartTime = Date.now();
        remainingTime = duration;

        autoPlayTimer = setTimeout(() => {
            let nextIndex = (currentLocIndex + 1) % carouselData.length;
            updateCarousel(nextIndex);
        }, duration);
    }

    if (stepIndicators.length > 0) {
        stepIndicators.forEach(ind => {
            ind.addEventListener('click', () => {
                updateCarousel(parseInt(ind.getAttribute('data-index')));
            });
        });

        if (playBtnEl) {
            playBtnEl.innerHTML = playBtnSvgPause;
            playBtnEl.addEventListener('click', () => {
                isPaused = !isPaused;
                if (isPaused) {
                    playBtnEl.innerHTML = playBtnSvgPlay;
                    playBtnEl.style.color = '#fff';
                    playBtnEl.style.backgroundColor = '#2D8CFF';
                    if (autoPlayTimer) clearTimeout(autoPlayTimer);
                    if (progressTween) progressTween.pause();
                    remainingTime -= (Date.now() - autoPlayStartTime);
                } else {
                    playBtnEl.innerHTML = playBtnSvgPause;
                    playBtnEl.style.color = '#2D8CFF';
                    playBtnEl.style.backgroundColor = 'white';
                    if (progressTween) progressTween.resume();
                    autoPlayStartTime = Date.now();
                    autoPlayTimer = setTimeout(() => {
                        updateCarousel((currentLocIndex + 1) % carouselData.length);
                    }, remainingTime);
                }
            });
        }

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    startAutoPlay();
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.3 });
        
        const section = document.getElementById('location');
        if (section) observer.observe(section);
    }
  });
</script>
