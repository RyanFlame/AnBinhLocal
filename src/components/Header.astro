---
import { Image } from "astro:assets";
import { getImageByPath } from "../utils/assets";
import { localizePath, type Locale } from "../i18n/config";
import { useTranslations } from "../i18n/utils";

type Props = {
  locale: Locale;
};

const { locale = "vi" } = Astro.props;
const t = useTranslations(locale);
const logoAsset = getImageByPath("Logo/Logo-NBG.png");

const homeHref = locale === "en" ? "/en" : "/";
const aboutHref = locale === "en" ? "/en/about" : "/about";
const blogHref = "/blog";
const switchToVi = localizePath(Astro.url.pathname, "vi");
const switchToEn = localizePath(Astro.url.pathname, "en");
const currentLangLabel = locale === "en" ? "EN" : "VN";
---

<nav id="navbar">
  <a href={homeHref} class="logo-link">
    <Image src={logoAsset} alt="An Binh Traditional Meds" class="logo-image" />
  </a>

  <ul class="nav-links desktop-only">
    <li>
      <a href={homeHref}>
        {t("nav.home")}
      </a>
    </li>
    <li>
      <a href={aboutHref}>
        {t("nav.about")}
      </a>
    </li>
    <li class="booking-feature">
      <a href="#booking">
        {t("nav.booking")}
      </a>
    </li>
    <li>
      <a href={blogHref}>
        {t("nav.blog")}
      </a>
    </li>
  </ul>

  <div class="lang-dropdown desktop-lang-nav desktop-only">
    <div class="lang-dropdown-selected" role="button" tabindex="0">
      <span class="current-lang-text">{currentLangLabel}</span>
      <svg
        viewBox="0 0 24 24"
        width="20"
        height="20"
        class="dropdown-arrow"
        fill="currentColor"><path d="M7 10l5 5 5-5z"></path></svg
      >
    </div>
    <div class="lang-dropdown-options">
      <a
        href={switchToVi}
        class={`lang-btn dropdown-opt ${locale === "vi" ? "active" : ""}`}
        data-locale-switch="true"
        data-lang="vn">VN</a
      >
      <a
        href={switchToEn}
        class={`lang-btn dropdown-opt ${locale === "en" ? "active" : ""}`}
        data-locale-switch="true"
        data-lang="en">EN</a
      >
    </div>
  </div>

  <div class="mobile-nav-right mobile-only">
    <div class="lang-dropdown mobile-lang-nav">
      <div class="lang-dropdown-selected" role="button" tabindex="0">
        <span class="current-lang-text">{currentLangLabel}</span>
        <svg
          viewBox="0 0 24 24"
          width="20"
          height="20"
          class="dropdown-arrow"
          fill="currentColor"><path d="M7 10l5 5 5-5z"></path></svg
        >
      </div>
      <div class="lang-dropdown-options">
        <a
          href={switchToVi}
          class={`lang-btn dropdown-opt ${locale === "vi" ? "active" : ""}`}
          data-locale-switch="true"
          data-lang="vn">VN</a
        >
        <a
          href={switchToEn}
          class={`lang-btn dropdown-opt ${locale === "en" ? "active" : ""}`}
          data-locale-switch="true"
          data-lang="en">EN</a
        >
      </div>
    </div>
    <div class="hamburger-menu" id="hamburger-button">
      <div class="bar bar1"></div>
      <div class="bar bar2"></div>
      <div class="bar bar3"></div>
    </div>
  </div>
</nav>

<div class="mobile-menu-overlay" id="mobile-overlay">
  <ul class="mobile-nav-links">
    <li class="mobile-link-item">
      <a href={homeHref}>
        {t("nav.home")}
      </a>
    </li>
    <li class="mobile-link-item">
      <a href={aboutHref}>
        {t("nav.about")}
      </a>
    </li>
    <li class="mobile-link-item booking-feature">
      <a href="#booking">
        {t("nav.booking")}
      </a>
    </li>
    <li class="mobile-link-item">
      <a href={blogHref}>
        {t("nav.blog")}
      </a>
    </li>
  </ul>

  <div class="mobile-social-icons">
    <a href="tel:+0908052968" class="social-icon">
      <svg viewBox="0 0 24 24" fill="currentColor">
        <path
          d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56-.35-.12-.74-.03-1.01.24l-1.57 1.97c-2.83-1.44-5.15-3.75-6.59-6.59l1.97-1.57c.27-.27.35-.66.24-1.01-.37-1.11-.56-2.3-.56-3.53 0-.55-.45-1-1-1H4.39c-.55 0-1 .45-1 1 0 9.39 7.61 17 17 17 .55 0 1-.45 1-1v-3.5c0-.55-.45-1-1-1z"
        ></path>
      </svg>
    </a>

    <a
      href="https://www.google.com/maps/place/Ph%C3%B2ng+Y+H%E1%BB%8Dc+C%E1%BB%95+Truy%E1%BB%81n+An+B%C3%ACnh/@10.5085571,107.327058,455m"
      class="social-icon"
    >
      <svg viewBox="0 0 24 24" fill="currentColor">
        <path
          d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"
        ></path>
      </svg>
    </a>

    <a href="https://zalo.me/0908052968" class="social-icon">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 50 50"
        fill="currentColor"
      >
        <path
          d="M 9 4 C 6.2504839 4 4 6.2504839 4 9 L 4 41 C 4 43.749516 6.2504839 46 9 46
             L 41 46 C 43.749516 46 46 43.749516 46 41 L 46 9 C 46 6.2504839 43.749516 4
             41 4 L 9 4 z M 9 6 L 15.580078 6 C 12.00899 9.7156859 10 14.518083 10 19.5
             C 10 24.66 12.110156 29.599844 15.910156 33.339844 C 16.030156 33.549844
             16.129922 34.579531 15.669922 35.769531 C 15.379922 36.519531 14.799687
             37.499141 13.679688 37.869141 C 13.249688 38.009141 12.97 38.430859 13
             38.880859 C 13.03 39.330859 13.360781 39.710781 13.800781 39.800781 C
             16.670781 40.370781 18.529297 39.510078 20.029297 38.830078 C 21.379297
             38.210078 22.270625 37.789609 23.640625 38.349609 C 26.440625 39.439609
             29.42 40 32.5 40 C 36.593685 40 40.531459 39.000731 44 37.113281 L 44 41
             C 44 42.668484 42.668484 44 41 44 L 9 44 C 7.3315161 44 6 42.668484 6 41
             L 6 9 C 6 7.3315161 7.3315161 6 9 6 z"
        ></path>
      </svg>
    </a>
  </div>
</div>

<script>
  declare const gsap: any;
  document.addEventListener("DOMContentLoaded", function() {
    // =========================================
    // 1. Desktop Scroll Effect Logic
    // =========================================
    const navbar = document.getElementById("navbar");
    if (!navbar) return;

    let navbarState = "top";
    let navbarFrame: number | null = null;

    function handleScroll() {
        const isScrolled = window.scrollY > 50;
        const nextState = !isScrolled
            ? "top"
            : window.innerWidth > 768
                ? "desktop"
                : "mobile";

        if (nextState === navbarState) return;

        navbarState = nextState;
        navbar.classList.toggle("scrolled-desktop", nextState === "desktop");
        navbar.classList.toggle("scrolled-mobile", nextState === "mobile");
    }

    function requestNavbarStateUpdate() {
        if (navbarFrame !== null) return;
        navbarFrame = window.requestAnimationFrame(() => {
            navbarFrame = null;
            handleScroll();
        });
    }

    window.addEventListener("scroll", requestNavbarStateUpdate, { passive: true });
    window.addEventListener("resize", requestNavbarStateUpdate);
    requestNavbarStateUpdate();

    // =========================================
    // 2. Smart Header Theme Detection
    // =========================================
    const headerThemeObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const theme = entry.target.getAttribute('data-header-theme');
                if (theme === 'light') {
                    navbar.classList.add('on-light-bg');
                    navbar.classList.remove('on-dark-bg');
                } else if (theme === 'dark') {
                    navbar.classList.add('on-dark-bg');
                    navbar.classList.remove('on-light-bg');
                }
            }
        });
    }, {
        rootMargin: "-0% 0% -90% 0%",
        threshold: 0
    });

    document.querySelectorAll('section, header, .about-page, .hero-section').forEach(el => {
        headerThemeObserver.observe(el);
    });

    // =========================================
    // 3. Mobile Menu GSAP Animation
    // =========================================
    const hamburgerBtn = document.getElementById('hamburger-button');
    const mobileOverlay = document.getElementById('mobile-overlay');
    const mobileLinks = document.querySelectorAll('.mobile-link-item a');
    const socialIcons = document.querySelectorAll('.social-icon');
    let isMenuOpen = false;

    if (typeof gsap !== 'undefined') {
        const menuTimeline = gsap.timeline({ paused: true, reversed: true });
        menuTimeline
            .to(mobileOverlay, { duration: 0.3, autoAlpha: 1, ease: "power2.inOut" })
            .from(mobileLinks, { duration: 0.8, y: 60, opacity: 0, stagger: 0.1, ease: "expo.out" })
            .from(socialIcons, { duration: 0.6, y: 30, opacity: 0, stagger: 0.05, ease: "back.out(1.7)" }, "-=0.6");

        if (hamburgerBtn) {
            hamburgerBtn.addEventListener('click', () => {
                hamburgerBtn.classList.toggle('is-active');
                if (isMenuOpen) {
                    menuTimeline.reverse();
                    document.body.style.overflow = '';
                } else {
                    menuTimeline.play();
                    document.body.style.overflow = 'hidden';
                }
                isMenuOpen = !isMenuOpen;
            });
        }
        
        mobileLinks.forEach(link => {
            link.addEventListener('click', () => {
                if(isMenuOpen) {
                    hamburgerBtn.classList.remove('is-active');
                    menuTimeline.reverse();
                    document.body.style.overflow = '';
                    isMenuOpen = false;
                }
            });
        });
    }

    // =========================================
    // 4. Language Dropdown Logic
    // =========================================
    document.querySelectorAll('.lang-dropdown').forEach(dropdown => {
        const selected = dropdown.querySelector('.lang-dropdown-selected');
        const options = dropdown.querySelector('.lang-dropdown-options');
        if (!selected || !options) return;

        selected.addEventListener('click', (e) => {
            e.stopPropagation();
            dropdown.classList.toggle('open');
            options.classList.toggle('show');
        });

        selected.addEventListener('keydown', (e: Event) => {
            const keyEvent = e as KeyboardEvent;
            if (keyEvent.key === 'Enter' || keyEvent.key === ' ') {
                e.preventDefault();
                dropdown.classList.toggle('open');
                options.classList.toggle('show');
            }
        });
    });

    document.addEventListener('click', () => {
        document.querySelectorAll('.lang-dropdown').forEach(dropdown => {
            dropdown.classList.remove('open');
            const options = dropdown.querySelector('.lang-dropdown-options');
            if (options) options.classList.remove('show');
        });
    });
  });
</script>
