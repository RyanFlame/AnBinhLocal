---
import { getCollection, render } from "astro:content";
import BlogLayout from "../../layouts/BlogLayout.astro";
import Footer from "../../components/Footer.astro";
import { Image } from "astro:assets";
import { getImageByPath } from "../../utils/assets";
import { useTranslations } from "../../i18n/utils";
import { type Locale } from "../../i18n/config";

const locale = (Astro.currentLocale || "vi") as Locale;
const t = useTranslations(locale);

// Assets
const logoAsset = getImageByPath("Logo/Logo-NBG.png");
const tocToggleAsset = getImageByPath("Icon/toc_toggle.png");

// 1. Generate a new path for every collection entry
export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");
  return blogEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

// 2. For your template, you can get the entry directly from the prop
const { entry } = Astro.props;
const { Content, headings } = await render(entry);

// Filter headings for ToC
const tocHeadings = headings.filter((h) => h.depth <= 3);

// 3. Dynamic Read Time Calculation (250 words / minute)
const wordsPerMinute = 250;
const wordCount = entry.body ? entry.body.split(/\s+/).length : 0;
const readTimeValue = Math.max(1, Math.ceil(wordCount / wordsPerMinute));
const dynamicReadTime = t("blog.post.read_time").replace("{time}", readTimeValue.toString());

// 4. Fetch related posts by category
const allPosts = await getCollection("blog");
const relatedPosts = allPosts
  .filter((p) => p.id !== entry.id && p.data.category === entry.data.category)
  .slice(0, 3);

// 5. Get unique categories for sidebar
const categories = [...new Set(allPosts.map((p) => p.data.category))];

// 6. Automated Internal Linking (CTA Map)
const categoryCtaMap: Record<string, { text: string; link: string; icon: string }> = {
  "Trị Liệu": {
    text: locale === "vi" ? "Đặt lịch trị liệu chuyên sâu tại An Bình" : "Book an intensive therapy session at An Binh",
    link: locale === "vi" ? "/booking" : "/en/booking",
    icon: "🗓️",
  },
  "Thảo Dược": {
    text: locale === "vi" ? "Khám phá các phương thuốc thảo dược tự nhiên" : "Explore natural herbal remedies",
    link: locale === "vi" ? "/booking" : "/en/booking",
    icon: "🌿",
  },
  "Chăm Sóc": {
    text: locale === "vi" ? "Xem thêm dịch vụ chăm sóc sức khỏe" : "See more healthcare services",
    link: locale === "vi" ? "/services" : "/en/services",
    icon: "💆",
  },
  "Y Học Cổ Truyền": {
    text: locale === "vi" ? "Tính Âm Dương và các phương pháp phục hồi" : "Yin-Yang and recovery methods",
    link: locale === "vi" ? "/services" : "/en/services",
    icon: "☯️",
  },
  "Phục Hồi": {
    text: locale === "vi" ? "Hỗ trợ phục hồi nhanh chóng cùng chuyên gia" : "Fast recovery support with experts",
    link: locale === "vi" ? "/booking" : "/en/booking",
    icon: "💪",
  },
  "Nhật Ký": {
    text: locale === "vi" ? "Tìm hiểu thêm các kiến thức YHCT" : "Learn more about TCM knowledge",
    link: locale === "vi" ? "/blog" : "/en/blog",
    icon: "📖",
  },
};
const cta = categoryCtaMap[entry.data.category] || {
  text: locale === "vi" ? "Liên hệ tư vấn cùng An Bình y quán" : "Contact An Binh clinic for consultation",
  link: locale === "vi" ? "/contact" : "/en/contact",
  icon: "📞",
};

// 7. Dynamic Article Schema (JSON-LD)
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: entry.data.title,
  description: entry.data.excerpt || "",
  author: {
    "@type": "Person",
    name: entry.data.author,
  },
  datePublished: entry.data.date ? entry.data.date.toISOString() : "",
  image: (() => {
    if (!entry.data.image) return "";
    const imgStr =
      typeof entry.data.image === "object" && "src" in entry.data.image
        ? String(entry.data.image.src)
        : String(entry.data.image);
    try {
      return new URL(imgStr, Astro.site).toString();
    } catch (e) {
      return imgStr;
    }
  })(),
  publisher: {
    "@type": "Organization",
    name: locale === "vi" ? "Phòng Khám YHCT An Bình" : "An Binh TCM Clinic",
    logo: {
      "@type": "ImageObject",
      url: new URL("/Asset/Logo/Logo-NBG.png", Astro.site).toString(),
    },
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: locale === "vi" ? "Trang chủ" : "Home",
      item: new URL(locale === "vi" ? "/" : "/en", Astro.site).toString(),
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Blog",
      item: new URL(locale === "vi" ? "/blog" : "/en/blog", Astro.site).toString(),
    },
    {
      "@type": "ListItem",
      position: 3,
      name: entry.data.category,
      item: new URL(
        locale === "vi" ? `/blog/category/${entry.data.category}` : `/en/blog/category/${entry.data.category}`,
        Astro.site,
      ).toString(),
    },
    {
      "@type": "ListItem",
      position: 4,
      name: entry.data.title,
      item: new URL(locale === "vi" ? `/blog/${entry.id}` : `/en/blog/${entry.id}`, Astro.site).toString(),
    },
  ],
};
---

<BlogLayout title={`${entry.data.title} | An Bình`}>
  <!-- Inject JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbSchema)}
  />

  <main class="single-post-container sidebar-collapsed" id="postContainer">
    <aside class="post-sidebar-left collapsed" id="sidebarLeft">
      <div class="sidebar-content-wrapper">
        <!-- Sidebar Logo with Seal -->
        <div class="sidebar-logo-minimal">
          <Image src={logoAsset} alt="An Bình Logo" />
        </div>

        <!-- Mobile Close Button -->
        <button
          id="btnCloseSidebarMobile"
          class="mobile-close-btn"
          aria-label="Close Sidebar"
        >
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>

        <div class="ai-summary-block">
          <button id="btnAiSummary" class="action-btn ai-summary-btn">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8z"
              ></path>
              <path d="M12 6v6l4 2"></path>
            </svg>
            <span>{t("blog.post.ai_summary.btn")}</span>
          </button>
          <div id="aiSummaryContent" class="ai-summary-content hidden">
            <div class="summary-inner">
              <h4>{t("blog.post.ai_summary.title")}</h4>
              <p>{entry.data.excerpt}</p>
            </div>
          </div>
        </div>

        <nav class="toc-nav">
          <h3>{t("blog.post.toc")}</h3>
          <div class="toc-line"></div>
          <ul>
            {
              tocHeadings && tocHeadings.length > 0 ? (
                <>
                  {tocHeadings.map((h) => (
                    <li class={`toc-item depth-${h.depth}`}>
                      <a href={`#${h.slug}`}>{h.text}</a>
                    </li>
                  ))}
                </>
              ) : (
                <li class="toc-item">{t("blog.post.no_toc")}</li>
              )
            }
          </ul>
        </nav>
      </div>
    </aside>

    <!-- 2. CENTER CONTENT: Article -->
    <article class="post-main-content">
      <header class="post-header">
        <div class="post-meta-top">
          <span class="category-badge lang-text">{entry.data.category}</span>
          <span class="read-stats">
            {dynamicReadTime}
          </span>
        </div>

        <h1 class="post-title lang-text">{entry.data.title}</h1>

        <div class="post-meta-bottom">
          <span class="byline"
            >{t("blog.post.by").replace("{author}", entry.data.author)}</span
          >
          <time datetime={entry.data.date.toISOString()}>
            {
              entry.data.date.toLocaleDateString(locale === "vi" ? "vi-VN" : "en-US", {
                year: "numeric",
                month: "short",
                day: "numeric",
              })
            }
          </time>
        </div>

        <!-- Action Bar: Text Size, Share -->
        <div class="post-actions">
          <div class="text-size-controls">
            <button
              id="btnTextDec"
              class="action-btn"
              aria-label="Decrease text size">A-</button
            >
            <button
              id="btnTextInc"
              class="action-btn"
              aria-label="Increase text size">A+</button
            >
          </div>
          <button class="action-btn share-btn" aria-label="Share article">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path>
              <polyline points="16 6 12 2 8 6"></polyline>
              <line x1="12" y1="2" x2="12" y2="15"></line>
            </svg>
            Share on media
          </button>
        </div>
      </header>

      <figure class="post-hero-image rounded-corner">
        <Image src={entry.data.image as any} alt={entry.data.title} />
      </figure>

      <div class="markdown-content">
        <!-- Renders the actual markdown content -->
        <Content />
      </div>

      <!-- Automated Internal Linking (Dynamic CTA) -->
      <div class="dynamic-cta-block">
        <div class="cta-inner">
          <span class="cta-icon">{cta.icon}</span>
          <div class="cta-text-content">
            <p class="cta-message">{t("blog.post.cta.message")}</p>
            <a
              href={cta.link}
              class="cta-link"
            >
              {cta.text}
              <span class="arrow">→</span>
            </a>
          </div>
        </div>
      </div>
    </article>

    <!-- 3. RIGHT SIDEBAR: Related News -->
    <aside class="post-sidebar-right">
      <div class="sidebar-header">
        <h3>{t("blog.post.related.title")}</h3>
        <a href={locale === "vi" ? `/blog/category/${entry.data.category}` : `/en/blog/category/${entry.data.category}`} class="see-all"
          >{t("blog.post.related.see_all")}</a
        >
      </div>

      <div class="related-list">
        {
          relatedPosts && relatedPosts.length > 0 ? (
            <>
              {relatedPosts.map((post) => (
                <a
                  href={locale === "vi" ? `/blog/${post.id}` : `/en/blog/${post.id}`}
                  style="text-decoration: none; color: inherit;"
                >
                  <article class="post-card minimal">
                    <figure
                      class="post-image concave-corner"
                      style="height: 150px;"
                    >
                      <Image
                        src={post.data.image as any}
                        alt={post.data.title}
                        style="width: 100%; height: 100%; object-fit: cover;"
                      />
                    </figure>
                    <div class="post-content" style="padding: 10px 0 0 0;">
                      <div class="post-meta" style="margin-bottom: 5px;">
                        <span style="color: var(--accent); font-weight: 500; font-size: 0.8rem;">
                          {post.data.category}
                        </span>
                      </div>
                      <h4
                        class="post-title"
                        style="font-size: 1rem; line-height: 1.4; margin: 0;"
                      >
                        {post.data.title}
                      </h4>
                    </div>
                  </article>
                </a>
              ))}
            </>
          ) : (
            <p style="font-family: var(--font-body); color: rgba(60, 42, 33, 0.5);">
              {t("blog.post.related.none")}
            </p>
          )
        }
      </div>
    </aside>
  </main>

  <style>
    /* --- Blog Post Layout --- */
    .single-post-container {
      display: grid;
      grid-template-columns: 250px 1fr 300px;
      gap: 40px;
      max-width: 1400px;
      margin: 120px auto 60px;
      padding: 0 5%;
      align-items: stretch;
      transition: grid-template-columns 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .post-sidebar-left {
      position: sticky;
      top: 90px;
      align-self: start;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      z-index: 100;
      height: max-content;
    }

    .post-sidebar-right {
      position: sticky;
      top: 80px !important;
      align-self: start;
      z-index: 90;
      height: max-content;
    }

    .sidebar-content-wrapper {
      transition: all 0.4s ease;
    }

    .post-sidebar-left.collapsed {
      width: 0;
      margin-right: -40px;
    }

    .post-sidebar-left.collapsed .sidebar-content-wrapper {
      opacity: 0;
      pointer-events: none;
      visibility: hidden;
      transform: translateX(-20px);
    }

    .mobile-close-btn,
    .sidebar-logo-minimal {
      display: none;
    }

    /* AI Summary Block */
    .ai-summary-block {
      margin-bottom: 30px;
    }

    .ai-summary-btn {
      width: 100%;
      justify-content: center;
      gap: 10px;
      background: var(--indochine-teal);
      color: #fff;
      border: none;
      font-weight: 600;
      padding: 14px;
      border-radius: 8px;
      transition: all 0.3s ease;
      display: flex;
      align-items: center;
      cursor: pointer;
    }

    .ai-summary-btn:hover {
      background: var(--indochine-emerald);
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }

    .ai-summary-btn.active {
      background: var(--indochine-emerald);
      border-bottom-left-radius: 0;
      border-bottom-right-radius: 0;
    }

    .ai-summary-content {
      background: #fff;
      border: 1px solid rgba(200, 169, 198, 0.2);
      border-top: none;
      border-radius: 0 0 8px 8px;
      overflow: hidden;
      box-shadow: var(--shadow-sm);
      transition: all 0.3s ease;
    }

    .ai-summary-content.hidden {
      display: none;
    }

    .summary-inner {
      padding: 20px;
      border-left: 3px solid var(--indochine-teal);
    }

    .summary-inner h4 {
      font-family: var(--font-serif);
      font-size: 0.95rem;
      color: var(--indochine-teal);
      margin-bottom: 12px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .summary-inner p {
      font-size: 0.9rem;
      line-height: 1.6;
      color: var(--walnut-brown);
      margin: 0;
      font-style: italic;
    }

    /* Table of Contents */
    .toc-nav {
      margin-top: 40px;
      padding-top: 20px;
      border-top: 1px solid rgba(200, 169, 126, 0.2);
    }

    .toc-nav h3 {
      font-family: var(--font-serif);
      font-size: 1.25rem;
      margin-bottom: 15px;
      color: var(--mahogany-dark);
    }

    .toc-line {
      width: 35px;
      height: 2px;
      background: var(--brass-gold);
      margin-bottom: 25px;
    }

    .toc-nav ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .toc-item {
      margin-bottom: 15px;
    }

    .toc-item a {
      text-decoration: none;
      color: var(--walnut-brown);
      opacity: 0.8;
      font-family: var(--font-sans);
      font-size: 0.95rem;
      transition: all 0.3s ease;
      display: block;
      line-height: 1.4;
    }

    .toc-item.depth-3 {
      padding-left: 20px;
    }

    .toc-item a:hover {
      color: var(--indochine-teal);
      opacity: 1;
      padding-left: 5px;
    }

    /* Main Content */
    .post-main-content {
      background: var(--bg-light);
      padding: 0 20px;
    }

    .post-meta-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
    }

    .category-badge {
      background: rgba(212, 175, 55, 0.1);
      color: var(--accent);
      padding: 5px 15px;
      border-radius: 20px;
      font-size: 0.85rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .read-stats {
      display: flex;
      align-items: center;
      gap: 8px;
      color: rgba(60, 42, 33, 0.6);
      font-size: 0.9rem;
    }

    .post-title {
      font-family: var(--font-heading);
      font-size: 3rem;
      line-height: 1.2;
      color: var(--text-dark);
      margin-bottom: 20px;
    }

    .post-meta-bottom {
      font-family: var(--font-body);
      color: rgba(60, 42, 33, 0.6);
      font-size: 1rem;
      margin-bottom: 30px;
    }

    .author {
      color: var(--primary);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .post-actions {
      display: flex;
      justify-content: flex-end;
      align-items: center;
      gap: 15px;
      margin-bottom: 40px;
    }

    .text-size-controls {
      display: flex;
      gap: 5px;
      background: rgba(212, 175, 55, 0.05);
      border-radius: 30px;
      padding: 5px;
    }

    .action-btn {
      background: none;
      border: 1px solid rgba(212, 175, 55, 0.3);
      color: var(--text-dark);
      padding: 8px 15px;
      border-radius: 20px;
      font-family: var(--font-body);
      font-size: 0.9rem;
      cursor: pointer;
      transition: all 0.3s ease;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .action-btn:hover {
      background: var(--accent);
      color: var(--bg-light);
      border-color: var(--accent);
    }

    .post-hero-image {
      width: 100%;
      height: 380px;
      margin-bottom: 50px;
      overflow: hidden;
    }

    .post-hero-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* Markdown Content */
    .markdown-content {
      font-family: var(--font-body);
      font-size: 1.1rem;
      line-height: 1.8;
      color: rgba(60, 42, 33, 0.85);
    }

    .markdown-content h2,
    .markdown-content h3 {
      font-family: var(--font-heading);
      color: var(--text-dark);
      margin-top: 2em;
      margin-bottom: 1em;
    }

    .markdown-content h2 {
      font-size: 2.2rem;
    }
    .markdown-content h3 {
      font-size: 1.6rem;
    }

    .markdown-content p {
      margin-bottom: 1.5em;
    }

    .markdown-content blockquote {
      border-left: 4px solid var(--accent);
      padding-left: 20px;
      margin: 2em 0;
      font-style: italic;
      font-size: 1.25em;
      color: var(--text-dark);
      background: rgba(212, 175, 55, 0.05);
      padding: 20px;
      border-radius: 0 10px 10px 0;
    }

    /* Right Sidebar */
    .post-sidebar-right {
      position: sticky;
      top: 120px;
    }

    .sidebar-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 30px;
    }

    .sidebar-header h3 {
      font-family: var(--font-heading);
      font-size: 1.5rem;
      color: var(--text-dark);
    }

    .sidebar-header .highlight {
      color: var(--accent);
    }

    .sidebar-header .see-all {
      font-family: var(--font-body);
      font-size: 0.9rem;
      color: rgba(60, 42, 33, 0.6);
      text-decoration: none;
      transition: color 0.3s;
    }

    .sidebar-header .see-all:hover {
      color: var(--accent);
    }

    .related-list {
      display: flex;
      flex-direction: column;
      gap: 30px;
    }

    /* Image Shapes */
    .rounded-corner {
      border-radius: 20px;
      overflow: hidden;
    }

    .concave-corner {
      position: relative;
      overflow: hidden;
      --scoop: 20px;
      mask-image:
        radial-gradient(
          circle at top left,
          transparent var(--scoop),
          black calc(var(--scoop) + 0.5px)
        ),
        radial-gradient(
          circle at top right,
          transparent var(--scoop),
          black calc(var(--scoop) + 0.5px)
        ),
        radial-gradient(
          circle at bottom left,
          transparent var(--scoop),
          black calc(var(--scoop) + 0.5px)
        ),
        radial-gradient(
          circle at bottom right,
          transparent var(--scoop),
          black calc(var(--scoop) + 0.5px)
        );
      -webkit-mask-image:
        radial-gradient(
          circle at top left,
          transparent var(--scoop),
          black calc(var(--scoop) + 0.5px)
        ),
        radial-gradient(
          circle at top right,
          transparent var(--scoop),
          black calc(var(--scoop) + 0.5px)
        ),
        radial-gradient(
          circle at bottom left,
          transparent var(--scoop),
          black calc(var(--scoop) + 0.5px)
        ),
        radial-gradient(
          circle at bottom right,
          transparent var(--scoop),
          black calc(var(--scoop) + 0.5px)
        );
      mask-position:
        top left,
        top right,
        bottom left,
        bottom right;
      -webkit-mask-position:
        top left,
        top right,
        bottom left,
        bottom right;
      mask-size: 51% 51%;
      -webkit-mask-size: 51% 51%;
      mask-repeat: no-repeat;
      -webkit-mask-repeat: no-repeat;
    }

    /* Controls */
    .fixed-post-controls {
      position: fixed;
      bottom: 80px;
      right: 30px;
      display: flex;
      flex-direction: column;
      gap: 15px;
      z-index: 999;
    }

    .collapse-sidebar-btn {
      width: 50px;
      height: 50px;
      background: #fff;
      border: 1px solid var(--brass-gold);
      border-radius: 50%;
      display: flex;
      justify-content: center;
      align-items: center;
      cursor: pointer;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
      transition: all 0.3s ease;
      padding: 0;
    }

    .collapse-sidebar-btn:hover {
      background: var(--indochine-teal);
      transform: translateY(-5px);
    }

    .collapse-sidebar-btn:hover :global(img) {
      filter: brightness(0) invert(1);
      opacity: 1;
    }

    .back-to-top {
      background: var(--bg-light);
      border: 1px solid var(--brass-gold);
      color: var(--mahogany-dark);
      width: 50px;
      height: 50px;
      border-radius: 50%;
      display: flex;
      justify-content: center;
      align-items: center;
      cursor: pointer;
      opacity: 0;
      visibility: hidden;
      transition: all 0.3s ease;
      z-index: 999;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    }

    .back-to-top.visible {
      opacity: 1;
      visibility: visible;
    }

    .back-to-top:hover {
      background: var(--accent);
      color: var(--bg-light);
      transform: translateY(-5px);
    }

    /* Text Modes */
    .single-post-container.text-large .markdown-content {
      font-size: 1.35rem;
      line-height: 1.9;
    }

    .single-post-container.text-large .post-header .post-title {
      font-size: 3.5rem;
    }

    /* --- Dynamic CTA Block --- */
    .dynamic-cta-block {
      margin-top: 60px;
      padding: 30px;
      background: #f9f5e3;
      border: 1px solid var(--blog-border);
      border-radius: var(--scoop-radius, 12px);
      text-align: center;
    }
    .cta-inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 15px;
    }
    .cta-icon {
      font-size: 2.5rem;
      line-height: 1;
    }
    .cta-message {
      font-size: 0.95rem;
      color: var(--blog-subtext);
      margin: 0;
    }
    .cta-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: var(--font-heading, "Merriweather", serif);
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--blog-gold);
      text-decoration: none;
      transition: color 0.3s;
    }
    .cta-link:hover {
      color: var(--blog-green);
    }
    .cta-link:hover .arrow {
      transform: translateX(4px);
    }

    /* --- Responsive --- */
    @media screen and (max-width: 1200px) {
      .single-post-container {
        grid-template-columns: 200px 1fr 250px;
        gap: 30px;
      }
    }

    @media screen and (max-width: 992px) {
      .single-post-container {
        grid-template-columns: 200px 1fr;
        grid-template-areas:
          "left main"
          "left right";
      }
      .post-sidebar-left {
        grid-area: left;
      }
      .post-main-content {
        grid-area: main;
      }
      .post-sidebar-right {
        grid-area: right;
        position: static;
        margin-top: 60px;
        border-top: 1px solid rgba(212, 175, 55, 0.2);
        padding-top: 40px;
      }
      .post-header .post-title {
        font-size: 2.5rem;
      }
    }

    @media screen and (min-width: 769px) {
      .single-post-container.sidebar-collapsed {
        grid-template-columns: 0px 1fr 300px;
        gap: 20px;
      }
    }

    @media screen and (max-width: 768px) {
      .single-post-container {
        grid-template-columns: 1fr;
        grid-template-areas:
          "main"
          "left"
          "right";
      }

      .post-sidebar-left {
        position: fixed;
        top: 0;
        left: 0;
        bottom: 0;
        width: 75vw;
        background: #fff;
        z-index: 2000;
        margin-top: 0;
        padding: calc(30px + env(safe-area-inset-top)) 25px
          calc(40px + env(safe-area-inset-bottom));
        border-top: none;
        box-shadow: 10px 0 30px rgba(0, 0, 0, 0.1);
        transform: translateX(-100%);
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        overflow-y: auto;
      }

      .post-sidebar-left:not(.collapsed) {
        transform: translateX(0);
      }

      .single-post-container:not(.sidebar-collapsed)::after {
        content: "";
        position: fixed;
        top: 0;
        left: 0;
        bottom: 0;
        right: 0;
        background: rgba(0, 0, 0, 0.3);
        backdrop-filter: blur(3px);
        z-index: 1999;
      }

      .sidebar-content-wrapper {
        width: 100%;
        opacity: 1 !important;
        transform: none !important;
      }

      .mobile-close-btn {
        display: flex;
        position: absolute;
        top: 20px;
        right: 20px;
        background: none;
        border: none;
        color: var(--walnut-brown);
        z-index: 2001;
      }

      .sidebar-logo-minimal {
        display: flex;
        width: 100%;
        margin-bottom: 20px;
        margin-left: -12px;
      }

      .sidebar-logo-minimal :global(img) {
        height: 80px;
        padding: 13px;
        width: auto;
        object-fit: contain;
        filter: brightness(1.2);
        background-image: url("/Logo/Seal-NBG.png");
        background-size: 100px 100px;
        background-repeat: no-repeat;
        background-position: center;
      }

      .ai-summary-block {
        width: 100%;
        margin-bottom: 20px;
        margin-top: 10px;
      }

      .toc-nav {
        display: block;
        width: 100%;
        margin-top: 20px;
        padding-top: 15px;
      }

      .toc-item.depth-3 {
        padding-left: 15px;
      }

      .post-hero-image {
        height: 250px;
      }
      .post-actions {
        justify-content: space-between;
        margin-bottom: 30px;
      }

      .fixed-post-controls {
        bottom: 20px;
        right: 20px;
        z-index: 2100;
      }
    }
  </style>

  <style is:global>
    .blog-body .zalo-container {
      display: none !important;
    }
  </style>

  <!-- Fixed Controls: Sidebar Toggle & Back to Top -->
  <div class="fixed-post-controls">
    <div id="backToTop" class="back-to-top" title="Back to Top">
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <polyline points="18 15 12 9 6 15"></polyline>
      </svg>
    </div>

    <button
      id="btnCollapseSidebar"
      class="collapse-sidebar-btn"
      aria-label="Toggle Sidebar"
      title="Toggle Navigation"
    >
      <Image src={tocToggleAsset} alt="Toggle Sidebar" width={24} height={24} />
    </button>
  </div>
</BlogLayout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const postContainer = document.getElementById("postContainer");
    const btnInc = document.getElementById("btnTextInc");
    const btnDec = document.getElementById("btnTextDec");
    const backToTop = document.getElementById("backToTop");
    const btnAiSummary = document.getElementById("btnAiSummary");
    const aiSummaryContent = document.getElementById("aiSummaryContent");
    const btnCollapseSidebar = document.getElementById("btnCollapseSidebar");
    const sidebarLeft = document.getElementById("sidebarLeft");
    const btnCloseSidebarMobile = document.getElementById(
      "btnCloseSidebarMobile",
    );

    const toggleSidebar = () => {
      const currentlyCollapsed =
        postContainer?.classList.toggle("sidebar-collapsed");
      sidebarLeft?.classList.toggle("collapsed");
      localStorage.setItem(
        "blogSidebarCollapsed",
        currentlyCollapsed ? "true" : "false",
      );
    };

    // Sidebar Collapse Logic
    // Start collapsed by default as set in HTML, meaning no load animation!
    // Only fetch saved choice if the user has explicitly opened it.
    const savedCollapsed = localStorage.getItem("blogSidebarCollapsed");
    const isCollapsed =
      savedCollapsed === null ? true : savedCollapsed === "true";

    if (isCollapsed) {
      postContainer?.classList.add("sidebar-collapsed");
      sidebarLeft?.classList.add("collapsed");
    } else {
      postContainer?.classList.remove("sidebar-collapsed");
      sidebarLeft?.classList.remove("collapsed");
    }

    btnCollapseSidebar?.addEventListener("click", toggleSidebar);
    btnCloseSidebarMobile?.addEventListener("click", toggleSidebar);

    // Close sidebar when ToC item is clicked (mobile)
    const tocLinks = sidebarLeft?.querySelectorAll(".toc-nav a");
    tocLinks?.forEach((link) => {
      link.addEventListener("click", () => {
        if (window.innerWidth <= 768) {
          toggleSidebar();
        }
      });
    });

    // Close when clicking overlay (mobile)
    document.addEventListener("click", (e) => {
      const isMobile = window.innerWidth <= 768;
      const isExpanded = !sidebarLeft?.classList.contains("collapsed");
      if (isMobile && isExpanded) {
        // If click is outside sidebar and NOT the toggle button
        if (
          !(e.target instanceof Node && sidebarLeft?.contains(e.target)) &&
          !(e.target instanceof Node && btnCollapseSidebar?.contains(e.target))
        ) {
          toggleSidebar();
        }
      }
    });

    // AI Summary Toggle
    btnAiSummary?.addEventListener("click", () => {
      aiSummaryContent?.classList.toggle("hidden");
      btnAiSummary.classList.toggle("active");
    });

    // Text Size Logic
    const savedSize = localStorage.getItem("blogTextSize");
    if (savedSize === "large") {
      postContainer?.classList.add("text-large");
    }

    btnInc?.addEventListener("click", () => {
      postContainer?.classList.add("text-large");
      localStorage.setItem("blogTextSize", "large");
    });

    btnDec?.addEventListener("click", () => {
      postContainer?.classList.remove("text-large");
      localStorage.setItem("blogTextSize", "normal");
    });

    // Share Functionality
    const shareBtn = document.querySelector(".share-btn");
    shareBtn?.addEventListener("click", async () => {
      if (navigator.share) {
        try {
          await navigator.share({
            title: document.title,
            url: window.location.href,
          });
        } catch (err) {
          console.log("Share failed:", err);
        }
      } else {
        navigator.clipboard.writeText(window.location.href);
        alert("Link copied to clipboard!");
      }
    });

    // Back to Top functionality
    window.addEventListener("scroll", () => {
      if (window.pageYOffset > 300) {
        backToTop?.classList.add("visible");
      } else {
        backToTop?.classList.remove("visible");
      }
    });

    backToTop?.addEventListener("click", () => {
      const w = window as any;
      if (w.gsap) {
        w.gsap.to(window, {
          duration: 1.2,
          scrollTo: { y: 0 },
          ease: "power4.inOut",
        });
      } else {
        window.scrollTo({ top: 0, behavior: "smooth" });
      }
    });
  });
</script>
