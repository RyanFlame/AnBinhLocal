---
import { getCollection } from "astro:content";
import BlogLayout from "../../../layouts/BlogLayout.astro";
import { Image } from "astro:assets";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog");
  const uniqueCategories = [...new Set(allPosts.map((post) => post.data.category))];

  return uniqueCategories.map((category) => {
    const filteredPosts = allPosts.filter((post) => post.data.category === category);
    return {
      params: { category: category },
      props: { posts: filteredPosts },
    };
  });
}

const { category } = Astro.params;
const { posts } = Astro.props;
---

<BlogLayout title={`Chuyên Mục: ${category} | An Bình`}>
  <div class="category-page">
    <header class="category-header">
      <h1 class="category-title lang-text" data-vn={`Chuyên Mục: ${category}`} data-en={`Category: ${category}`}>
        Chuyên Mục: {category}
      </h1>
      <p class="category-desc lang-text" data-vn={`Khám phá các bài viết về ${category}`} data-en={`Explore articles in ${category}`}>Khám phá các bài viết về {category}</p>
    </header>

    <div class="category-grid">
      {posts.map((post: any) => (
        <article class="post-card main-feature">
          <a href={`/blog/${post.id}`} style="text-decoration: none; color: inherit; display: block;">
            <figure class="post-image concave-corner">
              <Image src={post.data.image} alt={post.data.title} />
            </figure>
          </a>
          <div class="post-content">
            <a href={`/blog/${post.id}`} style="text-decoration: none; color: inherit;">
              <h3 class="post-title">{post.data.title}</h3>
            </a>
            <p class="post-excerpt">{post.data.excerpt}</p>
            <div class="post-meta">
              <span>{post.data.author}</span>
              <span class="dot">•</span>
              <span>{new Intl.DateTimeFormat('vi-VN', { month: 'short', day: 'numeric' }).format(post.data.date)} • 4 min read</span>
            </div>
          </div>
        </article>
      ))}
    </div>
    
    <div class="back-link">
      <a href="/blog" class="pagination-btn">← Quay lại trang Blog</a>
    </div>
  </div>
</BlogLayout>

<style>
  :root {
    --blog-bg: #f9f5e3;
    --blog-text: #241a0f;
    --blog-green: #2b3a24;
    --blog-subtext: #5c6755;
    --blog-gold: #c8a97e;
    --blog-border: #e2dac9;
    --scoop-radius: 12px;
  }

  .category-page {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 120px 40px 100px;
    font-family: "Open Sans", sans-serif;
    color: var(--blog-text);
    box-sizing: border-box;
  }
  .category-header {
    text-align: center;
    margin-bottom: 60px;
    padding-bottom: 30px;
    border-bottom: 1px solid var(--blog-border);
  }
  .category-title {
    font-family: "Merriweather", serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: var(--blog-text);
    margin-bottom: 15px;
  }
  .category-desc {
    font-size: 1.1rem;
    color: var(--blog-subtext);
  }
  .category-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 40px;
    margin-bottom: 60px;
  }
  
  .post-card { display: flex; flex-direction: column; margin-bottom: 30px; }
  .post-title { 
    font-family: "Merriweather", serif; 
    font-weight: 700; 
    color: var(--blog-text); 
    line-height: 1.3; 
    margin-top: 15px; 
    margin-bottom: 8px; 
    cursor: pointer; 
    transition: color 0.3s; 
    display: -webkit-box; 
    -webkit-line-clamp: 2; 
    -webkit-box-orient: vertical; 
    overflow: hidden; 
    min-height: 2.6em; 
    font-size: 1.4rem;
  }
  .post-title:hover { color: var(--blog-gold); }
  .post-excerpt { font-size: 0.95rem; color: var(--blog-subtext); line-height: 1.5; margin-bottom: 15px; }
  .post-meta { font-size: 0.8rem; color: #777; display: flex; align-items: center; gap: 8px; }
  .dot { font-size: 0.5rem; }
  .post-image { width: 100%; height: 280px; overflow: hidden; margin: 0; box-shadow: 0 4px 15px rgba(0,0,0,0.05); }
  .post-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; }
  .post-card:hover .post-image img { transform: scale(1.05); }
  
  .concave-corner { 
    position: relative; overflow: hidden; 
    mask-image: radial-gradient(circle at top left, transparent 11px, black 12px), radial-gradient(circle at top right, transparent 11px, black 12px), radial-gradient(circle at bottom right, transparent 11px, black 12px), radial-gradient(circle at bottom left, transparent 11px, black 12px);
    mask-size: 51% 51%; mask-repeat: no-repeat;
    mask-position: top left, top right, bottom right, bottom left;
    -webkit-mask-image: radial-gradient(circle at top left, transparent 11px, black 12px), radial-gradient(circle at top right, transparent 11px, black 12px), radial-gradient(circle at bottom right, transparent 11px, black 12px), radial-gradient(circle at bottom left, transparent 11px, black 12px);
    -webkit-mask-size: 51% 51%; -webkit-mask-repeat: no-repeat; -webkit-mask-position: top left, top right, bottom left, bottom right;
  }

  .back-link {
    text-align: center;
    margin-top: 40px;
  }
  .pagination-btn { 
    display: inline-block;
    padding: 12px 30px; 
    border: 1px solid var(--blog-gold); 
    color: var(--blog-gold); 
    background-color: #fff; 
    text-decoration: none; 
    font-family: "Playfair Display", serif; 
    font-weight: 600; 
    transition: all 0.3s; 
    box-shadow: 0 2px 8px rgba(0,0,0,0.05); 
  }
  .pagination-btn:hover { 
    background: var(--blog-gold); 
    color: #fff; 
    transform: translateY(-2px); 
    box-shadow: 0 4px 12px rgba(200, 169, 126, 0.2); 
  }
  
  @media screen and (max-width: 1024px) {
    .category-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media screen and (max-width: 768px) {
    .category-page { padding: 100px 20px 80px; }
    .category-title { font-size: 2.2rem; }
    .category-grid { grid-template-columns: 1fr; gap: 30px; }
    .post-image { height: 250px; }
  }
</style>
