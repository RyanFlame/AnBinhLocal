<style>
  /* =======================================
   ABOUT PAGE LAYOUT STYLES
======================================= */
  :root {
    --text-primary: #1f2815; /* Extremely dark olive */
    --text-secondary: #5c6755;
    --about-bg: #f4f0e6; /* Soft cream background */
    --accent-green: #2b3a24; /* Deep forest green */
    --border-color: #e6e1d3;
  }

  body {
    background-color: var(--about-bg) !important;
  }

  .about-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 150px 40px 100px;
    color: var(--text-primary);
    font-family: "Open Sans", sans-serif;
  }

  /* ---------------------------------------
   CONCAVE CORNER IMPLEMENTATION
---------------------------------------- */
  /* We apply an inverted radial-gradient mask to "bite" the 4 corners safely out of any rectangle */
  .concave-corner {
    position: relative;
    overflow: hidden;
    /* Determine scoop size */
    --scoop-radius: 24px;

    mask-image:
      radial-gradient(
        circle at top left,
        transparent calc(var(--scoop-radius) - 1px),
        black var(--scoop-radius)
      ),
      radial-gradient(
        circle at top right,
        transparent calc(var(--scoop-radius) - 1px),
        black var(--scoop-radius)
      ),
      radial-gradient(
        circle at bottom right,
        transparent calc(var(--scoop-radius) - 1px),
        black var(--scoop-radius)
      ),
      radial-gradient(
        circle at bottom left,
        transparent calc(var(--scoop-radius) - 1px),
        black var(--scoop-radius)
      );
    mask-size: 51% 51%;
    mask-repeat: no-repeat;
    mask-position:
      top left,
      top right,
      bottom right,
      bottom left;

    /* Safari support */
    -webkit-mask-image:
      radial-gradient(
        circle at top left,
        transparent calc(var(--scoop-radius) - 1px),
        black var(--scoop-radius)
      ),
      radial-gradient(
        circle at top right,
        transparent calc(var(--scoop-radius) - 1px),
        black var(--scoop-radius)
      ),
      radial-gradient(
        circle at bottom right,
        transparent calc(var(--scoop-radius) - 1px),
        black var(--scoop-radius)
      ),
      radial-gradient(
        circle at bottom left,
        transparent calc(var(--scoop-radius) - 1px),
        black var(--scoop-radius)
      );
    -webkit-mask-size: 51% 51%;
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-position:
      top left,
      top right,
      bottom right,
      bottom left;
  }

  .concave-corner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ---------------------------------------
   HERO SECTION
---------------------------------------- */
  .about-hero {
    margin-bottom: 80px;
    margin-top: 60px;
  }

  .hero-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 40px;
    flex-wrap: wrap;
    gap: 30px;
  }

  .hero-header h1 {
    font-size: 4rem;
  }

  .huge-title {
    font-family: "Merriweather", serif;
    font-size: clamp(3rem, 6vw, 5.5rem);
    line-height: 1.05;
    margin: 0;
    color: var(--accent-green);
    letter-spacing: -1px;
    min-width: 300px;
  }

  .hero-right {
    max-width: 350px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .hero-desc {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0;
  }

  .explore-link,
  .text-link {
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--text-secondary);
    text-decoration: none;
    letter-spacing: 0.5px;
    border-bottom: 1px solid var(--text-secondary);
    padding-bottom: 3px;
    width: fit-content;
    text-transform: uppercase;
    transition: color 0.3s;
  }

  .explore-link:hover,
  .text-link:hover {
    color: var(--accent-green);
    border-bottom-color: var(--accent-green);
  }

  .hero-banner {
    /* Break out of the padded container to be full-screen width minus 10px on each side */
    width: 90vw;
    height: 450px;
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    margin: 0;
    display: none;
  }

  @media screen and (max-width: 1100px) {
    .hero-banner {
      /* Break out of the padded container to be full-screen width minus 10px on each side */
      display: none;
    }
  }

  /* ---------------------------------------
   BENTO 3 COLUMN
---------------------------------------- */
  .bento-grid-about {
    display: grid;
    grid-template-columns: 1fr 1.3fr 1.1fr;
    gap: 3vw;
    margin-bottom: 100px;
  }

