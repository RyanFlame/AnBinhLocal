---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import { getImageByPath } from "../utils/assets";

// Hero & Feature Images loaded via Bulk Loader
const asset_Dad_Final_3_webp = getImageByPath("Dad Final 3.webp");
const asset_Therapies_Bam_huyet_webp = getImageByPath(
  "Therapies/Bam huyet.webp",
);
const asset_Therapies_Cham_Cuu_webp = getImageByPath("Therapies/Cham Cuu.webp");
const asset_Therapies_Diagnose_webp = getImageByPath("Therapies/Diagnose.webp");
const asset_Therapies_Exercise_webp = getImageByPath("Therapies/Exercise.webp");
const asset_Therapies_Nutrition1_webp = getImageByPath(
  "Therapies/Nutrition1.webp",
);
const asset_Therapies_Thuoc_Bac_webp = getImageByPath(
  "Therapies/Thuoc Bac.webp",
);
const asset_Thu_c_1_webp = getImageByPath("Thuốc 1.webp");
const asset_Thu_c_1E_webp = getImageByPath("Thuốc 1E.webp");
const asset_Thu_c_2_webp = getImageByPath("Thuốc 2.webp");
const asset_Thu_c_webp = getImageByPath("Thuốc.webp");

// Icons
const icon_Chuan_Doan = getImageByPath('Icon/Chuan Doan.png');
const icon_Thuoc_1 = getImageByPath('Icon/Thuoc 1.png');
const icon_Cham_Cuu = getImageByPath('Icon/Cham Cuu.png');
const icon_Bam_Huyet = getImageByPath('Icon/Bam Huyet.png');
const icon_Dinh_Duong = getImageByPath('Icon/Dinh Duong.png');
const icon_The_Duc = getImageByPath('Icon/The Duc.png');
const icon_Thuoc_2 = getImageByPath('Icon/Thuoc 2.png');

// Location
const location_1 = getImageByPath('Location/Location 1.png');
---

<Layout title="An Binh - Traditional Chinese Medicine">
  <header class="hero-section hero-redesign" data-header-theme="dark">
    <div class="hero-layout-container">
      <!-- Left Side: Text Content -->
      <div class="hero-left-col">
        <h1
          class="hero-title lang-text"
          data-en="Restoring<br>balance naturally."
          data-vn="Phục hồi<br>cân bằng tự nhiên."
        >
          Phục hồi<br />cân bằng tự nhiên.
        </h1>
        <p
          class="hero-desc lang-text"
          data-en="Discover the serenity of holistic healing in our traditional clinic nestled in the heart of the city."
          data-vn="Khám phá sức mạnh từ những bài thuốc thảo dược dân gian thân quen, giúp cơ thể bạn phục hồi sự cân bằng tự nhiên."
        >
          Khám phá sức mạnh từ những bài thuốc thảo dược dân gian thân quen,
          giúp cơ thể bạn phục hồi sự cân bằng tự nhiên.
        </p>
      </div>
    </div>

    <!-- Bottom: Search/Booking Bar -->
    <div class="hero-bottom-bar">
      <div class="hero-scroll-indicator">
        <a href="#about" class="scroll-circle">
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M12 8v8M16 12l-4 4-4-4"></path>
          </svg>
        </a>
      </div>

      <div class="hero-booking-bar glass-panel booking-feature">
        <div
          class="booking-segment segment-treatment booking-feature"
          style="cursor: pointer;"
        >
          <span
            class="segment-label lang-text"
            data-en="Treatment"
            data-vn="Trị Liệu">Trị Liệu</span
          >
          <span
            class="segment-value lang-text"
            data-en="Select therapy"
            data-vn="Chọn liệu pháp">Chọn liệu pháp</span
          >
        </div>
        <div class="segment-divider div-1"></div>
        <div
          class="booking-segment segment-name booking-feature"
          style="cursor: pointer;"
        >
          <span class="segment-label lang-text" data-en="Name" data-vn="Họ Tên"
            >Họ Tên</span
          >
          <span
            class="segment-value lang-text"
            data-en="Add details"
            data-vn="Thêm thông tin">Thêm thông tin</span
          >
        </div>
        <div class="segment-divider div-2"></div>
        <div
          class="booking-segment segment-date booking-feature"
          style="cursor: pointer;"
        >
          <span class="segment-label lang-text" data-en="Date" data-vn="Ngày"
            >Ngày</span
          >
          <span
            class="segment-value lang-text"
            data-en="Add date"
            data-vn="Chọn ngày">Chọn ngày</span
          >
        </div>
        <div class="segment-divider div-3"></div>
        <div
          class="booking-segment segment-time booking-feature"
          style="cursor: pointer;"
        >
          <span class="segment-label lang-text" data-en="Time" data-vn="Giờ"
            >Giờ</span
          >
          <span
            class="segment-value lang-text"
            data-en="Select slot"
            data-vn="Chọn khung giờ">Chọn khung giờ</span
          >
        </div>
        <button
          class="btn-booking-submit btn-hero-primary lang-text"
          data-en="Book Now"
          data-vn="Đặt Lịch"
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            class="search-icon"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
          </svg>
          Đặt Lịch
        </button>
      </div>

      <div class="hero-socials">
        <a href="tel:+0908052968" class="social-link">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"
            ><path
              d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56-.35-.12-.74-.03-1.01.24l-1.57 1.97c-2.83-1.44-5.15-3.75-6.59-6.59l1.97-1.57c.27-.27.35-.66.24-1.01-.37-1.11-.56-2.3-.56-3.53 0-.55-.45-1-1-1H4.39c-.55 0-1 .45-1 1 0 9.39 7.61 17 17 17 .55 0 1-.45 1-1v-3.5c0-.55-.45-1-1-1z"
            ></path></svg
          >
        </a>
        <a
          href="https://www.google.com/maps/place/Ph%C3%B2ng+Y+H%E1%BB%8Dc+C%E1%BB%95+Truy%E1%BB%81n+An+B%C3%ACnh/@10.5085571,107.327058,455m/data=!3m1!1e3!4m6!3m5!1s0x3175a100125c7973:0x97569e0490503fa6!8m2!3d10.5082762!4d107.3262642!16s%2Fg%2F11mf93d8rf!5m1!1e1?authuser=0&entry=ttu&g_ep=EgoyMDI1MTIwOS4wIKXMDSoASAFQAw%3D%3D"
          class="social-link"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"
            ><path
              d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"
            ></path></svg
          >
        </a>
        <a href="#" class="social-link">
          <svg
            width="20"
            height="20"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 50 50"
            fill="currentColor"
            ><path
              d="M 9 4 C 6.2504839 4 4 6.2504839 4 9 L 4 41 C 4 43.749516 6.2504839 46 9 46 L 41 46 C 43.749516 46 46 43.749516 46 41 L 46 9 C 46 6.2504839 43.749516 4 41 4 L 9 4 z M 9 6 L 15.580078 6 C 12.00899 9.7156859 10 14.518083 10 19.5 C 10 24.66 12.110156 29.599844 15.910156 33.339844 C 16.030156 33.549844 16.129922 34.579531 15.669922 35.769531 C 15.379922 36.519531 14.799687 37.499141 13.679688 37.869141 C 13.249688 38.009141 12.97 38.430859 13 38.880859 C 13.03 39.330859 13.360781 39.710781 13.800781 39.800781 C 16.670781 40.370781 18.529297 39.510078 20.029297 38.830078 C 21.379297 38.210078 22.270625 37.789609 23.640625 38.349609 C 26.440625 39.439609 29.42 40 32.5 40 C 36.593685 40 40.531459 39.000731 44 37.113281 L 44 41 C 44 42.668484 42.668484 44 41 44 L 9 44 C 7.3315161 44 6 42.668484 6 41 L 6 9 C 6 7.3315161 7.3315161 6 9 6 z M 33 15 C 33.55 15 34 15.45 34 16 L 34 25 C 34 25.55 33.55 26 33 26 C 32.45 26 32 25.55 32 25 L 32 16 C 32 15.45 32.45 15 33 15 z M 18 16 L 23 16 C 23.36 16 23.700859 16.199531 23.880859 16.519531 C 24.050859 16.829531 24.039609 17.219297 23.849609 17.529297 L 19.800781 24 L 23 24 C 23.55 24 24 24.45 24 25 C 24 25.55 23.55 26 23 26 L 18 26 C 17.64 26 17.299141 25.800469 17.119141 25.480469 C 16.949141 25.170469 16.960391 24.780703 17.150391 24.470703 L 21.199219 18 L 18 18 C 17.45 18 17 17.55 17 17 C 17 16.45 17.45 16 18 16 z M 27.5 19 C 28.11 19 28.679453 19.169219 29.189453 19.449219 C 29.369453 19.189219 29.65 19 30 19 C 30.55 19 31 19.45 31 20 L 31 25 C 31 25.55 30.55 26 30 26 C 29.65 26 29.369453 25.810781 29.189453 25.550781 C 28.679453 25.830781 28.11 26 27.5 26 C 25.57 26 24 24.43 24 22.5 C 24 20.57 25.57 19 27.5 19 z M 38.5 19 C 40.43 19 42 20.57 42 22.5 C 42 24.43 40.43 26 38.5 26 C 36.57 26 35 24.43 35 22.5 C 35 20.57 36.57 19 38.5 19 z M 27.5 21 C 27.39625 21 27.29502 21.011309 27.197266 21.03125 C 27.001758 21.071133 26.819727 21.148164 26.660156 21.255859 C 26.500586 21.363555 26.363555 21.500586 26.255859 21.66