            ></path></svg
          >
        </a>
      </div>
    </div>
  </header>

  <!-- ===== OUR PRODUCTS CAROUSEL STYLES ===== -->
  <section class="product-section" id="products" data-header-theme="light">
    <div class="product-container">
      <div class="product-header">
        <h2
          class="heading-section lang-text"
          data-en="Our Natural Collections"
          data-vn="Bộ Sưu Tập Từ Thiên Nhiên"
        >
          Bộ Sưu Tập Từ Thiên Nhiên
        </h2>
        <div class="carousel-nav">
          <button id="prevBtn" class="nav-arrow" aria-label="Previous">
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M15 18l-6-6 6-6"></path>
            </svg>
          </button>
          <button id="nextBtn" class="nav-arrow" aria-label="Next">
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M9 18l6-6-6-6"></path>
            </svg>
          </button>
        </div>
      </div>

      <div class="carousel-viewport" id="carouselViewport">
        <div class="carousel-track" id="track">
          <div class="product-card">
            <a
              href="/about#svc-private"
              style="text-decoration: none; color: inherit; display: block; height: 100%; width: 100%;"
            >
              <div class="card-inner">
                <div class="icon-placeholder">
                  <Image
                    src={icon_Chuan_Doan}
                    alt="Icon"
                    class="temp-icon"
                  />
                </div>
                <h3
                  class="lang-text"
                  data-en="Pulse Diagnosis"
                  data-vn="Chẩn Đoán"
                >
                  Chẩn Đoán
                </h3>
              </div>
            </a>
          </div>

          <div class="product-card">
            <a
              href="/about#svc-herbal"
              style="text-decoration: none; color: inherit; display: block; height: 100%; width: 100%;"
            >
              <div class="card-inner">
                <div class="icon-placeholder">
                  <Image src={icon_Thuoc_1} alt="Icon" class="temp-icon" />
                </div>
                <h3
                  class="lang-text"
                  data-en="Herbal Decoctions"
                  data-vn="Bốc Thuốc Bắc"
                >
                  Bốc Thuốc Bắc
                </h3>
              </div>
            </a>
          </div>

          <div class="product-card">
            <a
              href="/about#svc-acupuncture"
              style="text-decoration: none; color: inherit; display: block; height: 100%; width: 100%;"
            >
              <div class="card-inner">
                <div class="icon-placeholder">
                  <Image src={icon_Cham_Cuu} alt="Icon" class="temp-icon" />
                </div>
                <h3 class="lang-text" data-en="Acupuncture" data-vn="Châm Cứu">
                  Châm Cứu
                </h3>
              </div>
            </a>
          </div>

          <div class="product-card">
            <a
              href="/about#svc-acupuncture"
              style="text-decoration: none; color: inherit; display: block; height: 100%; width: 100%;"
            >
              <div class="card-inner">
                <div class="icon-placeholder">
                  <Image src={icon_Bam_Huyet} alt="Icon" class="temp-icon" />
                </div>
                <h3 class="lang-text" data-en="Acupressure" data-vn="Bấm Huyệt">
                  Bấm Huyệt
                </h3>
              </div>
            </a>
          </div>

          <div class="product-card">
            <a
              href="/about#svc-nutrition"
              style="text-decoration: none; color: inherit; display: block; height: 100%; width: 100%;"
            >
              <div class="card-inner">
                <div class="icon-placeholder">
                  <Image
                    src={icon_Dinh_Duong}
                    alt="Icon"
                    class="temp-icon"
                  />
                </div>
                <h3
                  class="lang-text"
                  data-en="Nutritional Supplements"
                  data-vn="Dinh Dưỡng"
                >
                  Dinh Dưỡng
                </h3>
              </div>
            </a>
          </div>

          <div class="product-card">
            <a
              href="/about#svc-nutrition"
              style="text-decoration: none; color: inherit; display: block; height: 100%; width: 100%;"
            >
              <div class="card-inner">
                <div class="icon-placeholder">
                  <Image src={icon_The_Duc} alt="Icon" class="temp-icon" />
                </div>
                <h3
                  class="lang-text"
                  data-en="Physical Therapy"
                  data-vn="Vật Lý Trị Liệu"
                >
                  Vật Lý Trị Liệu
                </h3>
              </div>
            </a>
          </div>

          <div class="product-card">
            <a
              href="/about#svc-herbal"
              style="text-decoration: none; color: inherit; display: block; height: 100%; width: 100%;"
            >
              <div class="card-inner">
                <div class="icon-placeholder">
                  <Image src={icon_Thuoc_2} alt="Icon" class="temp-icon" />
                </div>
                <h3 class="lang-text" data-en="Tonic" data-vn="Thuốc Bổ">
                  Thuốc Bổ
                </h3>
              </div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========================================= -->
  <!-- PHILOSOPHY SECTION  -->
  <!-- ========================================= -->
  <section class="philosophy-section">
    <div class="philosophy-container">
      <div class="philosophy-text">
        <h2
          class="section-heading heading-section lang-text"
          data-en="Our Philosophy"
          data-vn="Triết Lý Của Chúng Tôi"
        >
          Triết Lý Của Chúng Tôi
        </h2>
        <h3
          class="sub-heading lang-text"
          data-en="Harmony of Body & Nature"
          data-vn="Hòa Hợp Giữa Cơ Thể & Thiên Nhiên"
        >
          Hòa Hợp Giữa Cơ Thể & Thiên Nhiên
        </h3>
        <p
          class="body-regular lang-text"
          data-en="At An Binh, we believe that true wellness comes from the balance between the internal elements of the body and the external rhythms of nature.<br><br>Drawing from thousands of years of traditional wisdom, our approach combines time-honored herbal remedies with modern understanding to restore your body's natural capacity for healing."
          data-vn="Tại An Bình, chúng tôi tin rằng sự khỏe mạnh đích thực đến từ sự cân bằng giữa các yếu tố bên trong cơ thể và nhịp điệu bên ngoài của thiên nhiên.<br><br>
          Với tâm niệm rằng mỗi người là một cá thể duy nhất với những nhu cầu chăm sóc khác nhau. 
          Chúng tôi kết hợp những bài thuốc lành tính từ thiên nhiên,
          được điều chỉnh theo từng thể trạng nhằm điều trị tận gốc bệnh lý và bồi
          bổ cơ thể."
        >
          Tại An Bình, chúng tôi tin rằng sự khỏe mạnh đích thực đến từ sự cân
          bằng giữa các yếu tố bên trong cơ thể và nhịp điệu bên ngoài của thiên
          nhiên.
          <br /><br />
          Chúng tôi hiểu rằng mỗi người là một cá thể duy nhất với những nhu cầu chăm
          sóc khác nhau. Chúng tôi kết hợp những bài thuốc lành tính từ thiên nhiên,
          được điều chỉnh theo từng thể trạng nhằm điều trị tận gốc bệnh lý và bồi
          bổ cơ thể.
        </p>
        <a
          href="/about"
          class="btn-secondary lang-text"
          data-en="DISCOVER MORE"
          data-vn="KHÁM PHÁ THÊM">KHÁM PHÁ THÊM</a
        >
      </div>

      <div class="philosophy-image-wrapper">
        <div class="philosophy-frame">
          <Image
            src={asset_Dad_Final_3_webp}
            alt="Traditional Medicine Philosophy"
            class="philosophy-img"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ========================================= -->
  <!-- INGREDIENT DETAIL SECTION -->
  <!-- ========================================= -->
  <section class="philosophy-section">
    <div class="philosophy-container reverse">
      <div class="philosophy-text">
        <h2
          class="section-heading heading-section lang-text"
          data-en="Premium Herbal Selection"
          data-vn="Lựa Chọn Thảo Dược Chuẩn Mực"
        >
          Lựa Chọn Thảo Dược Chuẩn Mực
        </h2>
        <h3
          class="sub-heading lang-text"
          data-en="Curated for Potency"
          data-vn="Tuyển Chọn Vì Chất Lượng"
        >
          Tuyển Chọn Vì Chất Lượng
        </h3>
        <p
          class="body-regular lang-text"
          data-en="Every formulation begins with the careful selection of premium herbs. We prioritize ingredients that are ethically sourced and harvested at peak maturity to ensure maximum therapeutic value.<br><br>Experience the difference that quality makes in your journey to wellness."
          data-vn="Mỗi vị thuốc đều đóng vai trò then chốt trong quá trình điều trị, 
          quyết định hiệu quả phục hồi của cơ thể. Tại An Bình, 
          chúng tôi khắt khe trong việc tuyển chọn nguồn dược liệu chất lượng cao, 
          đảm bảo thu hoạch đúng độ tuổi để giữ trọn vẹn dược tính và phát huy tối đa tác dụng trị liệu.
          <br><br>Chúng tôi luôn đồng hành cùng bạn trên hành trình phục hồi sức khỏe bằng những bài thuốc tinh túy và chất lượng tốt nhất."
        >
          Mỗi vị thuốc đều đóng vai trò then chốt trong quá trình điều trị,
