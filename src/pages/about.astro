  /* =======================================
   JOURNEY / VISION / MISSION TAB SECTION
  ======================================= */
  .tab-panel-section {
    margin-bottom: 80px;
    padding-bottom: 60px;
    border-bottom: 1px solid var(--border-color);
  }

  /* Pill switcher row */
