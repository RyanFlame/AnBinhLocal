---
import Layout from "../layouts/Layout.astro";
import { Image } from 'astro:assets';
import { getImageByPath } from '../utils/assets';

// Use the elite bulk loader for clinical photography
const asset_About_us2_webp = getImageByPath('About-us2.webp');
const asset_Chinese_med1_webp = getImageByPath('Chinese-med1.webp');
const asset_Dad_webp = getImageByPath('Dad.webp');
const asset_Med3_webp = getImageByPath('Med3.webp');
const asset_Personal_Treatment_webp = getImageByPath('Personal Treatment.webp');
---

<Layout title="About Us - An Binh">
  <!-- Main About Container -->
  <div class="about-page" data-header-theme="light">
    <!-- Hero Section -->
    <section class="about-hero">
      <div class="hero-header">
        <h1
          class="huge-title lang-text"
          data-en="About Us"
          data-vn="Về Chúng Tôi"
        >
          Về Chúng Tôi
        </h1>
        <div class="hero-right">
          <p
            class="hero-desc lang-text"
            data-en="The most popular and trusted traditional medicine clinic in the city."
            data-vn="Phòng khám y học cổ truyền uy tín và được tin tưởng nhất thành phố."
          >
            Phòng khám y học cổ truyền uy tín và được tin tưởng nhất thành phố.
          </p>
          <a
            href="/therapies"
            class="explore-link lang-text"
            data-en="EXPLORE TREATMENTS ↗"
            data-vn="KHÁM PHÁ TRỊ LIỆU ↗">KHÁM PHÁ TRỊ LIỆU ↗</a
          >
        </div>
      </div>

      <figure class="hero-banner concave-corner">
        <!-- Using a wide landscape image -->
        <Image src={asset_About_us2_webp} alt="An Binh Clinic Landscape" / />
      </figure>
    </section>

    <!-- Bento 3 Column Layout -->
    <section class="about-bento-section">
      <div class="bento-grid-about">
        <!-- Left Image -->
        <figure class="bento-col img-left concave-corner">
          <Image src={asset_Chinese_med1_webp} alt="Herbs preparation" / />
        </figure>

        <!-- Center Content -->
        <div class="bento-col center-content">
          <span
            class="label lang-text"
            data-en="☆ ABOUT US"
            data-vn="☆ VỀ CHÚNG TÔI">☆ VỀ CHÚNG TÔI</span
          >
          <h2
            class="section-title lang-text"
            data-en="The Highest Level of Comfort, Healing and Service"
            data-vn="Đỉnh Cao Của Chăm Sóc, Chữa Lành Và Phục Vụ"
          >
            Đỉnh Cao Của Chăm Sóc, Chữa Lành Và Phục Vụ
          </h2>
          <p
            class="section-desc lang-text"
            data-en="At An Binh Clinic, we combine premium traditional medicine with attention to detail. Whether it's a private therapy session tailored just for you, or a relaxing herbal remedy routine — we take care of everything, so you can enjoy every moment."
            data-vn="Tại Phòng khám An Bình, chúng tôi kết hợp y học cổ truyền cao cấp với sự tỉ mỉ đến từng chi tiết. Cho dù đó là một liệu trình châm cứu được kê riêng cho bạn, hay một liệu pháp thảo dược thư giãn — chúng tôi lo mọi thứ, để bạn có thể hoàn toàn tận hưởng."
          >
            Tại Phòng khám An Bình, chúng tôi kết hợp y học cổ truyền cao cấp
            với sự tỉ mỉ đến từng chi tiết. Cho dù đó là một liệu trình châm cứu
            được kê riêng cho bạn, hay một liệu pháp thảo dược thư giãn — chúng
            tôi lo mọi thứ, để bạn có thể hoàn toàn tận hưởng.
          </p>
          <a
            href="/ingredients"
            class="text-link lang-text"
            data-en="MORE ABOUT US ↗"
            data-vn="TÌM HIỂU THÊM ↗">TÌM HIỂU THÊM ↗</a
          >
        </div>

        <!-- Right Taller Image -->
        <figure class="bento-col img-right concave-corner">
          <Image src={asset_Dad_webp} alt="Traditional Medicine" / />
        </figure>
      </div>
    </section>

    <!-- ======================================= -->
    <!-- JOURNEY / VISION / MISSION TAB SECTION  -->
    <!-- ======================================= -->
    <section class="tab-panel-section">
      <!-- Tab switcher row -->
      <div class="tab-switcher">
        <button
          class="tab-pill active lang-text"
          data-tab="why-choose-us"
          data-en="✦ Why Choose Us"
          data-vn="✦ Tại Sao Chọn Chúng Tôi">✦ Tại Sao Chọn Chúng Tôi</button
        >
        <button
          class="tab-pill lang-text"
          data-tab="journey"
          data-en="Journey"
          data-vn="Hành Trình">Hành Trình</button
        >
        <button
          class="tab-pill lang-text"
          data-tab="vision"
          data-en="Vision"
          data-vn="Tầm Nhìn">Tầm Nhìn</button
        >
        <button
          class="tab-pill lang-text"
          data-tab="mission"
          data-en="Mission"
          data-vn="Sứ Mệnh">Sứ Mệnh</button
        >
      </div>

      <!-- Tab content panels -->
      <div class="tab-content-area">
        <!-- WHY CHOOSE US panel -->
        <div class="tab-panel active" id="tab-why-choose-us">
          <div class="tab-meta">
            <span
              class="tab-meta-label lang-text"
              data-en="✦ Why Choose Us"
              data-vn="✦ Tại Sao Chọn Chúng Tôi"
            >
              ✦ Tại Sao Chọn Chúng Tôi
            </span>
          </div>
          <div class="tab-body">
            <h2
              class="tab-heading lang-text"
              data-en="Rooted in Tradition, Perfected for Modern Healing."
              data-vn="Bắt nguồn từ truyền thống, hoàn thiện cho sự chữa lành hiện đại."
            >
              Bắt nguồn từ truyền thống, hoàn thiện cho sự chữa lành hiện đại.
            </h2>
            <div class="tab-features-grid">
              <div class="feature-item">
                <h4
                  class="lang-text"
                  data-en="Master Herbalists"
                  data-vn="Đội Ngũ Lương Y"
                >
                  Đội Ngũ Lương Y
                </h4>
                <p
                  class="lang-text"
                  data-en="Decades of classical training — every diagnosis is rooted in time-proven protocols."
                  data-vn="Hàng chục năm đào tạo cổ điển — mỗi chẩn đoán đều bắt nguồn từ phác đồ đã được kiểm chứng."
                >
                  Hàng chục năm đào tạo cổ điển — mỗi chẩn đoán đều bắt nguồn từ
                  phác đồ đã được kiểm chứng.
                </p>
              </div>
              <div class="feature-item">
                <h4
                  class="lang-text"
                  data-en="Personalised Care"
                  data-vn="Chăm Sóc Cá Nhân Hoá"
                >
                  Chăm Sóc Cá Nhân Hoá
                </h4>
                <p
                  class="lang-text"
                  data-en="Every plan is built for you — targeting your body's unique needs."
                  data-vn="Mỗi phác đồ được xây dựng cho riêng bạn — nhắm vào nhu cầu riêng của cơ thể."
                >
                  Mỗi phác đồ được xây dựng cho riêng bạn — nhắm vào nhu cầu
                  riêng của cơ thể.
                </p>
              </div>
              <div class="feature-item">
                <h4
                  class="lang-text"
                  data-en="Premium Ingredients"
                  data-vn="Dược Liệu Thượng Hạng"
                >
                  Dược Liệu Thượng Hạng
                </h4>
                <p
                  class="lang-text"
                  data-en="80+ varieties sourced from certified highland farms, prepared using traditional methods."
                  data-vn="Hơn 80 loại dược liệu từ vườn cao nguyên, sơ chế theo phương pháp truyền thống."
                >
                  Hơn 80 loại dược liệu từ vườn cao nguyên, sơ chế theo phương
                  pháp truyền thống.
                </p>
              </div>
              <div class="feature-item">
                <h4
                  class="lang-text"
                  data-en="Holistic Approach"
                  data-vn="Tiếp Cận Toàn Diện"
                >
                  Tiếp Cận Toàn Diện
                </h4>
                <p
                  class="lang-text"
                  data-en="We treat the root, not just the symptom — balancing body, mind, and energy."
                  data-vn="Chúng tôi điều trị tận gốc, không chỉ triệu chứng — cân bằng cơ thể, tâm trí và năng lượng."
                >
                  Chúng tôi điều trị tận gốc, không chỉ triệu chứng — cân bằng
                  cơ thể, tâm trí và năng lượng.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- JOURNEY panel -->
        <div class="tab-panel" id="tab-journey">
          <div class="tab-meta">
            <span
              class="tab-meta-label lang-text"
              data-en="● Our Journey"
              data-vn="● Hành trình của chúng tôi"
            >
              ● Hành trình của chúng tôi
            </span>
          </div>
          <div class="tab-body">
            <h2
              class="tab-heading lang-text"
              data-en="Over 30 years of healing, guided by ancestral wisdom and modern care."
              data-vn="Hơn 30 năm chữa lành, được dẫn dắt bởi trí tuệ tổ tiên và sự chăm sóc hiện đại."
            >
              Hơn 30 năm chữa lành, được dẫn dắt bởi trí tuệ tổ tiên và sự chăm
              sóc hiện đại.
            </h2>
            <p
              class="tab-desc lang-text"
              data-en="An Binh was founded in the early 1990s by Dr. Nguyen Phuoc Binh, a renowned physician trained in classical Eastern medicine. What began as a modest family clinic grew — generation by generation — into one of the city's most trusted institutions for holistic care."
              data-vn="An Bình được thành lập vào đầu những năm 1990 bởi Lương y Nguyễn Phước Bình — một thầy thuốc được đào tạo chính quy theo y học cổ truyền phương Đông. Từ một phòng khám gia đình nhỏ, qua từng thế hệ, nơi đây đã trở thành một trong những cơ sở chăm sóc sức khỏe toàn diện được tin tưởng nhất thành phố."
            >
              An Bình được thành lập vào đầu những năm 1990 bởi Lương y Nguyễn
              Phước Bình. Từ một phòng khám gia đình nhỏ, qua từng thế hệ, nơi
              đây đã trở thành một trong những cơ sở chăm sóc sức khỏe toàn diện
              được tin tưởng nhất thành phố.
            </p>
          </div>
        </div>

        <!-- VISION panel -->
        <div class="tab-panel" id="tab-vision">
          <div class="tab-meta">
            <span
              class="tab-meta-label lang-text"
              data-en="● Our vision"
              data-vn="● Tầm nhìn của chúng tôi"
            >
              ● Tầm nhìn của chúng tôi
            </span>
          </div>
          <div class="tab-body">
            <h2
              class="tab-heading lang-text"
              data-en="A future where traditional medicine is accessible to every family, at every stage of life."
              data-vn="Một tương lai mà y học cổ truyền trở nên dễ tiếp cận với mọi gia đình, ở mọi giai đoạn cuộc đời."
            >
              Một tương lai mà y học cổ truyền trở nên dễ tiếp cận với mọi gia
              đình, ở mọi giai đoạn cuộc đời.
            </h2>
            <p
              class="tab-desc lang-text"
              data-en="We envision An Binh as more than a clinic — a living bridge between ancient healing knowledge and the needs of modern life. By combining classical diagnostics with contemporary wellness practices, we strive to make holistic care not just effective, but truly welcoming."
              data-vn="Chúng tôi hình dung An Bình không chỉ là một phòng khám — mà là cầu nối sống động giữa kho tàng y học cổ và những nhu cầu của cuộc sống hiện đại. Bằng cách kết hợp chẩn đoán cổ điển với các thực hành sức khỏe đương đại, chúng tôi mong muốn mỗi người đều tìm được sự chữa lành thật sự."
            >
              Chúng tôi hình dung An Bình là cầu nối sống động giữa kho tàng y
              học cổ và những nhu cầu của cuộc sống hiện đại — mang lại sự chữa
              lành thật sự cho mọi người.
            </p>
          </div>
        </div>

        <!-- MISSION panel -->
        <div class="tab-panel" id="tab-mission">
          <div class="tab-meta">
            <span
              class="tab-meta-label lang-text"
              data-en="● Our mission"
              data-vn="● Sứ mệnh của chúng tôi"
            >
              ● Sứ mệnh của chúng tôi
            </span>
          </div>
          <div class="tab-body">
            <h2
              class="tab-heading lang-text"
              data-en="To honour the wisdom of traditional medicine while serving each patient with empathy, precision, and care."
              data-vn="Tôn vinh trí tuệ y học cổ truyền, phục vụ mỗi bệnh nhân bằng sự đồng cảm, chính xác và tận tâm."
            >
              Tôn vinh trí tuệ y học cổ truyền, phục vụ mỗi bệnh nhân bằng sự
              đồng cảm, chính xác và tận tâm.
            </h2>
            <p
              class="tab-desc lang-text"
              data-en="Our mission is grounded in three principles: personalised care that sees the whole person, ethical sourcing of every herb and remedy, and a deep commitment to education — sharing the knowledge of Eastern medicine with each patient and the wider community."
              data-vn="Sứ mệnh của chúng tôi dựa trên ba nguyên tắc: chăm sóc cá nhân hoá nhìn nhận toàn diện con người, tìm nguồn dược liệu có đạo đức, và cam kết chia sẻ kiến thức y học phương Đông đến từng bệnh nhân và cộng đồng."
            >
              Sứ mệnh của chúng tôi dựa trên ba nguyên tắc: chăm sóc cá nhân
              hoá, tìm nguồn dược liệu có đạo đức, và cam kết chia sẻ kiến thức
              y học phương Đông đến từng bệnh nhân và cộng đồng.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Offer Section -->
    <section class="services-offer">
      <div class="offer-header">
        <span
          class="label heart-icon lang-text"
          data-en="♥ SERVICES"
          data-vn="♥ DỊCH VỤ">♥ DỊCH VỤ</span
        >
        <h3
          class="section-title lang-text"
          data-en="What we offer?"
          data-vn="Chúng tôi cung cấp gì?"
        >
          Chúng tôi cung cấp gì?
        </h3>
        <p
          class="centered-desc lang-text"
          data-en="From a private diagnosis to a scheduled multi-month healing route to an accessible wellness check — we've got the perfect option for you."
          data-vn="Từ chẩn đoán riêng tư đến lộ trình phục hồi nhiều tháng hay kiểm tra sức khỏe cơ bản — chúng tôi có giải pháp hoàn hảo cho bạn."
        >
          Từ chẩn đoán riêng tư đến lộ trình phục hồi nhiều tháng hay kiểm tra
          sức khỏe cơ bản — chúng tôi có giải pháp hoàn hảo cho bạn.
        </p>
      </div>

      <div class="services-grid">
        <!-- Left Menu -->
        <div class="services-nav">
          <button
            class="service-btn active lang-text"
            data-service="private"
            data-en="Private Therapies"
            data-vn="Trị Liệu Cá Nhân">Trị Liệu Cá Nhân</button
          >
          <button
            class="service-btn lang-text"
            data-service="scheduled"
            data-en="Scheduled Treatments"
            data-vn="Điều Trị Theo Liệu Trình">Điều Trị Theo Liệu Trình</button
          >
          <button
            class="service-btn lang-text"
            data-service="herbal"
            data-en="Herbal Blends"
            data-vn="Thảo Dược Bốc Thuốc">Thảo Dược Bốc Thuốc</button
          >
          <button
            class="service-btn lang-text"
            data-service="acupuncture"
            data-en="Acupuncture - Acupressure"
            data-vn="Trâm cứu - Bấm huyệt">Trâm cứu - Bấm huyệt</button
          >
          <button
            class="service-btn lang-text"
            data-service="nutrition"
            data-en="Nutrition - Physical Therapy"
            data-vn="Dinh dưỡng - Vật lý Trị liệu"
            >Dinh dưỡng - Vật lý Trị liệu</button
          >
          <button
            class="service-btn lang-text"
            data-service="community"
            data-en="Community Support"
            data-vn="Hỗ Trợ Cộng Đồng">Hỗ Trợ Cộng Đồng</button
          >
        </div>

        <!-- Right content area: image + detail stacked per service -->
        <div class="service-panels-area">
          <!-- PRIVATE THERAPIES -->
          <div class="service-panel active" id="svc-private">
            <figure class="service-image concave-corner">
              <Image
                src={asset_Personal_Treatment_webp}
                alt="Private Therapies"
              / />
            </figure>
            <div class="service-detail">
              <span
                class="label icon-star lang-text"
                data-en="⚚ AS YOU WISH"
                data-vn="⚚ NHƯ Ý NGUYỆN">⚚ NHƯ Ý NGUYỆN</span
              >
              <h4
                class="detail-title lang-text"
                data-en="Tailored <em>Private Therapies</em><br>and treatments"
                data-vn="<em>Chăm sóc cá nhân</em><br>và điều trị chuyên biệt"
              >
                <em>Chăm sóc cá nhân</em><br />và điều trị chuyên biệt
              </h4>
              <p
                class="detail-desc lang-text"
                data-en="Enjoy a personalized healing journey in our VIP relaxing rooms. These sessions offer complete flexibility — targeting exactly your pain points or energy blocks at your own pace."
                data-vn="Tận hưởng hành trình phục hồi cá nhân trong phòng thư giãn VIP của chúng tôi. Các buổi điều trị mang lại sự linh hoạt hoàn toàn — nhắm chính xác vào điểm đau theo nhịp độ của riêng bạn."
              >
                Tận hưởng hành trình phục hồi cá nhân trong phòng thư giãn VIP
                của chúng tôi. Các buổi điều trị mang lại sự linh hoạt hoàn toàn
                — nhắm chính xác vào điểm đau theo nhịp độ của riêng bạn.
              </p>
              <div class="highlight-callout">
                <span class="highlight-icon">❁</span>
                <p
                  class="lang-text"
                  data-en="Perfect for those seeking a<br>custom wellness experience."
                  data-vn="Hoàn hảo cho những ai tìm kiếm<br>trải nghiệm phục hồi tuỳ chỉnh."
                >
                  Hoàn hảo cho những ai tìm kiếm<br />trải nghiệm phục hồi tuỳ
                  chỉnh.
                </p>
              </div>
              <a
                href="#booking"
                class="text-link booking-feature lang-text"
                data-en="EXPLORE TREATMENTS ↗"
                data-vn="TÌM HIỂU KHÓA TRỊ LIỆU ↗">TÌM HIỂU KHÓA TRỊ LIỆU ↗</a
              >
            </div>
          </div>

          <!-- SCHEDULED TREATMENTS -->
          <div class="service-panel" id="svc-scheduled">
            <figure class="service-image concave-corner">
              <Image src={asset_Chinese_med1_webp} alt="Scheduled Treatments" / />
            </figure>
            <div class="service-detail">
              <span
                class="label icon-star lang-text"
                data-en="⚚ STRUCTURED CARE"
                data-vn="⚚ CHĂM SÓC CÓ LỘ TRÌNH">⚚ CHĂM SÓC CÓ LỘ TRÌNH</span
              >
              <h4
                class="detail-title lang-text"
                data-en="<em>Structured</em><br>healing programmes"
                data-vn="<em>Lộ trình</em><br>phục hồi có cấu trúc"
              >
                <em>Lộ trình</em><br />phục hồi có cấu trúc
              </h4>
              <p
                class="detail-desc lang-text"
                data-en="Our multi-session treatment plans are designed for conditions that require sustained, progressive care. Each follow-up builds on the last — measurable improvement, every step."
                data-vn="Các chương trình điều trị nhiều buổi của chúng tôi được thiết kế cho các tình trạng cần chăm sóc liên tục và tiến triển. Mỗi lần theo dõi kế thừa kết quả trước — cải thiện rõ rệt từng bước."
              >
                Các chương trình điều trị nhiều buổi được thiết kế cho tình
                trạng cần chăm sóc liên tục. Mỗi lần theo dõi kế thừa kết quả
                trước — cải thiện rõ rệt từng bước.
              </p>
              <div class="highlight-callout">
                <span class="highlight-icon">❁</span>
                <p
                  class="lang-text"
                  data-en="Ideal for chronic conditions<br>and long-term recovery."
                  data-vn="Lý tưởng cho các bệnh mãn tính<br>và phục hồi dài hạn."
                >
