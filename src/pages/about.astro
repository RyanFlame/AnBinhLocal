---
import Layout from "../layouts/Layout.astro";
import { Image } from 'astro:assets';
import { getImageByPath } from '../utils/assets';
import { useTranslations } from "../i18n/utils";
import { type Locale } from "../i18n/config";

const locale = (Astro.currentLocale || "vi") as Locale;
const t = useTranslations(locale);

// Use the elite bulk loader for clinical photography
const heroImg = getImageByPath(t("about.hero.image")) || getImageByPath('About-us2.webp');
const bentoLeft = getImageByPath(t("about.bento.img_left")) || getImageByPath('Chinese-med1.webp');
const bentoRight = getImageByPath(t("about.bento.img_right")) || getImageByPath('Dad.webp');
const med3 = getImageByPath('Med3.webp');
const personalImg = getImageByPath('Personal Treatment.webp');
---

<Layout title={`${t("about.hero.title")} - An Binh`}>
  <!-- Main About Container -->
  <div class="about-page" data-header-theme="light">
    <!-- Hero Section -->
    <section class="about-hero">
      <div class="hero-header">
        <h1 class="huge-title">
          {t("about.hero.title")}
        </h1>
        <div class="hero-right">
          <p class="hero-desc">
            {t("about.hero.desc")}
          </p>
          <a href={locale === "vi" ? "/therapies" : "/en/therapies"} class="explore-link">
            {t("about.hero.link")}
          </a>
        </div>
      </div>

      <figure class="hero-banner concave-corner">
        <!-- Using a wide landscape image -->
        <Image src={heroImg} alt="An Binh Clinic Landscape" />
      </figure>
    </section>

    <!-- Bento 3 Column Layout -->
    <section class="about-bento-section">
      <div class="bento-grid-about">
        <!-- Left Image -->
        <figure class="bento-col img-left concave-corner">
          <Image src={bentoLeft} alt="Herbs preparation" />
        </figure>

        <!-- Center Content -->
        <div class="bento-col center-content">
          <span class="label">
            {t("about.bento.label")}
          </span>
          <h2 class="section-title">
            {t("about.bento.title")}
          </h2>
          <p class="section-desc">
            {t("about.bento.desc")}
          </p>
          <a href={locale === "vi" ? "/ingredients" : "/en/ingredients"} class="text-link">
            {t("about.bento.link")}
          </a>
        </div>

        <!-- Right Taller Image -->
        <figure class="bento-col img-right concave-corner">
          <Image src={bentoRight} alt="Traditional Medicine" />
        </figure>
      </div>
    </section>

    <!-- ======================================= -->
    <!-- JOURNEY / VISION / MISSION TAB SECTION  -->
    <!-- ======================================= -->
    <section class="tab-panel-section">
      <!-- Tab switcher row -->
      <div class="tab-switcher">
        <button class="tab-pill active" data-tab="why-choose-us">
          {t("about.tabs.why.pill")}
        </button>
        <button class="tab-pill" data-tab="journey">
          {t("about.tabs.journey.pill")}
        </button>
        <button class="tab-pill" data-tab="vision">
          {t("about.tabs.vision.pill")}
        </button>
        <button class="tab-pill" data-tab="mission">
          {t("about.tabs.mission.pill")}
        </button>
      </div>

      <!-- Tab content panels -->
      <div class="tab-content-area">
        <!-- WHY CHOOSE US panel -->
        <div class="tab-panel active" id="tab-why-choose-us">
          <div class="tab-meta">
            <span class="tab-meta-label">
              {t("about.tabs.why.label")}
            </span>
          </div>
          <div class="tab-body">
            <h2 class="tab-heading">
              {t("about.tabs.why.title")}
            </h2>
            <div class="tab-features-grid">
              <div class="feature-item">
                <h4>{t("about.tabs.why.f1.title")}</h4>
                <p>{t("about.tabs.why.f1.desc")}</p>
              </div>
              <div class="feature-item">
                <h4>{t("about.tabs.why.f2.title")}</h4>
                <p>{t("about.tabs.why.f2.desc")}</p>
              </div>
              <div class="feature-item">
                <h4>{t("about.tabs.why.f3.title")}</h4>
                <p>{t("about.tabs.why.f3.desc")}</p>
              </div>
              <div class="feature-item">
                <h4>{t("about.tabs.why.f4.title")}</h4>
                <p>{t("about.tabs.why.f4.desc")}</p>
              </div>
            </div>
          </div>
        </div>

        <!-- JOURNEY panel -->
        <div class="tab-panel" id="tab-journey">
          <div class="tab-meta">
            <span class="tab-meta-label">
              {t("about.tabs.journey.label")}
            </span>
          </div>
          <div class="tab-body">
            <h2 class="tab-heading">
              {t("about.tabs.journey.title")}
            </h2>
            <p class="tab-desc">
              {t("about.tabs.journey.desc")}
            </p>
          </div>
        </div>

        <!-- VISION panel -->
        <div class="tab-panel" id="tab-vision">
          <div class="tab-meta">
            <span class="tab-meta-label">
              {t("about.tabs.vision.label")}
            </span>
          </div>
          <div class="tab-body">
            <h2 class="tab-heading">
              {t("about.tabs.vision.title")}
            </h2>
            <p class="tab-desc">
              {t("about.tabs.vision.desc")}
            </p>
          </div>
        </div>

        <!-- MISSION panel -->
        <div class="tab-panel" id="tab-mission">
          <div class="tab-meta">
            <span class="tab-meta-label">
              {t("about.tabs.mission.label")}
            </span>
          </div>
          <div class="tab-body">
            <h2 class="tab-heading">
              {t("about.tabs.mission.title")}
            </h2>
            <p class="tab-desc">
              {t("about.tabs.mission.desc")}
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Offer Section -->
    <section class="services-offer">
      <div class="offer-header">
        <span class="label heart-icon">
          {t("about.services.label")}
        </span>
        <h3 class="section-title">
          {t("about.services.title")}
        </h3>
        <p class="centered-desc">
          {t("about.services.desc")}
        </p>
      </div>

      <div class="services-grid">
        <!-- Left Menu -->
        <div class="services-nav">
          <button class="service-btn active" data-service="private">
            {t("about.services.btn.private")}
          </button>
          <button class="service-btn" data-service="scheduled">
            {t("about.services.btn.scheduled")}
          </button>
          <button class="service-btn" data-service="herbal">
            {t("about.services.btn.herbal")}
          </button>
          <button class="service-btn" data-service="acupuncture">
            {t("about.services.btn.acupuncture")}
          </button>
          <button class="service-btn" data-service="nutrition">
            {t("about.services.btn.nutrition")}
          </button>
          <button class="service-btn" data-service="community">
            {t("about.services.btn.community")}
          </button>
        </div>

        <!-- Right content area: image + detail stacked per service -->
        <div class="service-panels-area">
          <!-- PRIVATE THERAPIES -->
          <div class="service-panel active" id="svc-private">
            <figure class="service-image concave-corner">
              <Image src={personalImg} alt="Private Therapies" />
            </figure>
            <div class="service-detail">
              <span class="label icon-star">
                {t("about.services.panel.private.label")}
              </span>
              <h4 class="detail-title" set:html={t("about.services.panel.private.title")} />
              <p class="detail-desc">
                {t("about.services.panel.private.desc")}
              </p>
              <div class="highlight-callout">
                <span class="highlight-icon">❁</span>
                <p set:html={t("about.services.panel.private.highlight")} />
              </div>
              <a href="#booking" class="text-link booking-feature">
                {t("about.services.panel.private.link")}
              </a>
            </div>
          </div>

          <!-- SCHEDULED TREATMENTS -->
          <div class="service-panel" id="svc-scheduled">
            <figure class="service-image concave-corner">
              <Image src={bentoLeft} alt="Scheduled Treatments" />
            </figure>
            <div class="service-detail">
              <span class="label icon-star">
                {t("about.services.panel.scheduled.label")}
              </span>
              <h4 class="detail-title" set:html={t("about.services.panel.scheduled.title")} />
              <p class="detail-desc">
                {t("about.services.panel.scheduled.desc")}
              </p>
              <div class="highlight-callout">
                <span class="highlight-icon">❁</span>
                <p set:html={t("about.services.panel.scheduled.highlight")} />
              </div>
              <a href="#booking" class="text-link booking-feature">
                {t("about.services.panel.scheduled.link")}
              </a>
            </div>
          </div>

          <!-- HERBAL BLENDS -->
          <div class="service-panel" id="svc-herbal">
            <figure class="service-image concave-corner">
              <Image src={asset_Med3_webp} alt="Herbal Blends" />
            </figure>
            <div class="service-detail">
              <span class="label icon-star">
                {t("about.services.panel.herbal.label")}
              </span>
              <h4 class="detail-title" set:html={t("about.services.panel.herbal.title")} />
              <p class="detail-desc">
                {t("about.services.panel.herbal.desc")}
              </p>
              <div class="highlight-callout">
                <span class="highlight-icon">❁</span>
                <p set:html={t("about.services.panel.herbal.highlight")} />
              </div>
              <a href={locale === "vi" ? "/ingredients" : "/en/ingredients"} class="text-link">
                {t("about.services.panel.herbal.link")}
              </a>
            </div>
          </div>

          <!-- ACUPUNCTURE -->
          <div class="service-panel" id="svc-acupuncture">
            <figure class="service-image concave-corner">
              <Image src={asset_About_us2_webp} alt="Acupuncture" />
            </figure>
            <div class="service-detail">
              <span class="label icon-star">
                {t("about.services.panel.acupuncture.label")}
              </span>
              <h4 class="detail-title" set:html={t("about.services.panel.acupuncture.title")} />
              <p class="detail-desc">
                {t("about.services.panel.acupuncture.desc")}
              </p>
              <div class="highlight-callout">
                <span class="highlight-icon">❁</span>
                <p set:html={t("about.services.panel.acupuncture.highlight")} />
              </div>
              <a href="#booking" class="text-link booking-feature">
                {t("about.services.panel.acupuncture.link")}
              </a>
            </div>
          </div>

          <!-- NUTRITION -->
          <div class="service-panel" id="svc-nutrition">
            <figure class="service-image concave-corner">
              <Image src={asset_Dad_webp} alt="Nutrition and Physical Therapy" />
            </figure>
            <div class="service-detail">
              <span class="label icon-star">
                {t("about.services.panel.nutrition.label")}
              </span>
              <h4 class="detail-title" set:html={t("about.services.panel.nutrition.title")} />
              <p class="detail-desc">
                {t("about.services.panel.nutrition.desc")}
              </p>
              <div class="highlight-callout">
                <span class="highlight-icon">❁</span>
                <p set:html={t("about.services.panel.nutrition.highlight")} />
              </div>
              <a href="#booking" class="text-link booking-feature">
                {t("about.services.panel.nutrition.link")}
              </a>
            </div>
          </div>

          <!-- COMMUNITY SUPPORT -->
          <div class="service-panel" id="svc-community">
            <figure class="service-image concave-corner">
              <Image src={asset_Chinese_med1_webp} alt="Community Support" />
            </figure>
            <div class="service-detail">
              <span class="label icon-star">
                {t("about.services.panel.community.label")}
              </span>
              <h4 class="detail-title" set:html={t("about.services.panel.community.title")} />
              <p class="detail-desc">
                {t("about.services.panel.community.desc")}
              </p>
              <div class="highlight-callout">
                <span class="highlight-icon">❁</span>
                <p set:html={t("about.services.panel.community.highlight")} />
              </div>
              <a href="#booking" class="text-link booking-feature">
                {t("about.services.panel.community.link")}
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- CTA Section -->
  <section class="about-cta">
    <div class="cta-overlay"></div>
    <Image src={asset_About_us2_webp} alt="An Binh Clinic" class="cta-bg" />
    <div class="cta-content">
      <h2 class="cta-title">
        {t("about.cta.title")}
      </h2>
      <p class="cta-desc">
        {t("about.cta.desc")}
      </p>
      <a href={locale === "vi" ? "/#booking" : "/en/#booking"} class="cta-btn">
        {t("about.cta.btn")}
      </a>
    </div>
  </section>
</Layout>

<style>
  /* =======================================
   ABOUT PAGE LAYOUT STYLES
======================================= */
  :root {
    --text-primary: #1f2815; /* Extremely dark olive */
    --text-secondary: #5c6755;
    --about-bg: #f4f0e6; /* Soft cream background */
    --accent-green: #2b3a24; /* Deep forest green */
    --border-color: #e6e1d3;
  }

  body {
    background-color: var(--about-bg) !important;
  }

  .about-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 150px 40px 100px;
    color: var(--text-primary);
    font-family: "Open Sans", sans-serif;
  }

  /* ---------------------------------------
   CONCAVE CORNER IMPLEMENTATION
---------------------------------------- */
  /* We apply an inverted radial-gradient mask to "bite" the 4 corners safely out of any rectangle */
  .concave-corner {
    position: relative;
    overflow: hidden;
    /* Determine scoop size */
    --scoop-radius: 24px;

    mask-image:
      radial-gradient(
        circle at top left,
        transparent calc(var(--scoop-radius) - 1px),
        black var(--scoop-radius)
      ),
      radial-gradient(
        circle at top right,
        transparent calc(var(--scoop-radius) - 1px),
        black var(--scoop-radius)
      ),
      radial-gradient(
        circle at bottom right,
        transparent calc(var(--scoop-radius) - 1px),
        black var(--scoop-radius)
      ),
      radial-gradient(
        circle at bottom left,
        transparent calc(var(--scoop-radius) - 1px),
        black var(--scoop-radius)
      );
    mask-size: 51% 51%;
    mask-repeat: no-repeat;
    mask-position:
      top left,
      top right,
      bottom right,
      bottom left;

    /* Safari support */
    -webkit-mask-image:
      radial-gradient(
        circle at top left,
        transparent calc(var(--scoop-radius) - 1px),
        black var(--scoop-radius)
      ),
      radial-gradient(
        circle at top right,
        transparent calc(var(--scoop-radius) - 1px),
        black var(--scoop-radius)
      ),
      radial-gradient(
        circle at bottom right,
        transparent calc(var(--scoop-radius) - 1px),
        black var(--scoop-radius)
      ),
      radial-gradient(
        circle at bottom left,
        transparent calc(var(--scoop-radius) - 1px),
        black var(--scoop-radius)
      );
    -webkit-mask-size: 51% 51%;
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-position:
      top left,
      top right,
      bottom right,
      bottom left;
  }

  .concave-corner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ---------------------------------------
   HERO SECTION
---------------------------------------- */
  .about-hero {
    margin-bottom: 80px;
    margin-top: 60px;
  }

  .hero-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 40px;
    flex-wrap: wrap;
    gap: 30px;
  }

  .hero-header h1 {
    font-size: 4rem;
  }

  .huge-title {
    font-family: "Merriweather", serif;
    font-size: clamp(3rem, 6vw, 5.5rem);
    line-height: 1.05;
    margin: 0;
    color: var(--accent-green);
    letter-spacing: -1px;
    min-width: 300px;
  }

  .hero-right {
    max-width: 350px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .hero-desc {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0;
  }

  .explore-link,
  .text-link {
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--text-secondary);
    text-decoration: none;
    letter-spacing: 0.5px;
    border-bottom: 1px solid var(--text-secondary);
    padding-bottom: 3px;
    width: fit-content;
    text-transform: uppercase;
    transition: color 0.3s;
  }

  .explore-link:hover,
  .text-link:hover {
    color: var(--accent-green);
    border-bottom-color: var(--accent-green);
  }

  .hero-banner {
    /* Break out of the padded container to be full-screen width minus 10px on each side */
    width: 90vw;
    height: 450px;
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    margin: 0;
    display: none;
  }

  @media screen and (max-width: 1100px) {
    .hero-banner {
      /* Break out of the padded container to be full-screen width minus 10px on each side */
      display: none;
    }
  }

  /* ---------------------------------------
   BENTO 3 COLUMN
---------------------------------------- */
  .bento-grid-about {
    display: grid;
    grid-template-columns: 1fr 1.3fr 1.1fr;
    gap: 3vw;
    margin-bottom: 100px;
  }

  .img-left {
    height: 380px;
    margin: 0;
  }

  .img-right {
    height: 600px; /* Taller image */
    margin: 0;
  }

  .center-content {
    display: flex;
    flex-direction: column;
    padding: 30px 10px 0 10px;
  }

  .label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 30px;
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .section-title {
    font-family: "Merriweather", serif;
    font-size: clamp(2rem, 3vw, 2.7rem);
    line-height: 1.2;
    margin: 0 0 25px 0;
    color: var(--text-primary);
  }

  .section-desc {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 40px;
  }

  /* ---------------------------------------
   SERVICES OFFER
---------------------------------------- */
  .services-offer {
    margin-bottom: 60px;
  }

  .offer-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 60px;
  }

  .centered-desc {
    max-width: 600px;
    text-align: center;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .services-grid {
    display: grid;
    grid-template-columns: 220px 1fr 1fr;
    gap: 40px;
    align-items: start;
  }

  /* Left Nav */
  .services-nav {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .service-btn {
    background: var(--border-color);
    border: none;
    padding: 18px 25px;
    text-align: left;
    font-family: "Open Sans", sans-serif;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    color: var(--text-primary);
    transition: all 0.3s;
    /* Soft pill styling to match overall design */
    border-radius: 4px;
  }

  .service-btn.active {
    background: var(--accent-green);
    color: white;
  }

  .service-btn:hover:not(.active) {
    background: #dfd9ca;
  }

  /* Center Image */
  .service-image {
    height: 500px;
    margin: 0;
  }

  /* Right Detail */
  .service-detail {
    display: flex;
    flex-direction: column;
    padding: 20px 0;
  }

  .service-panels-area {
    display: grid;
    grid-template-columns: 1fr 1fr; /* image col | detail col */
    grid-template-rows: 1fr;
    gap: 40px;
    grid-column: 2 / 4;
  }

  .service-panel {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    grid-area: 1 / 1 / 2 / 3; /* all panels share the same cell */
    align-items: start;
    /* Fade transition */
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.35s ease,
      transform 0.35s ease;
    pointer-events: none;
    visibility: hidden;
  }

  .service-panel.active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    visibility: visible;
  }

  .detail-title {
    font-family: "Merriweather", serif;
    font-size: 2.2rem;
    line-height: 1.2;
    margin: 0 0 25px 0;
    color: var(--text-primary);
  }

  .detail-title em {
    font-style: italic;
    font-weight: 400;
  }

  .detail-desc {
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 30px;
  }

  .highlight-callout {
    display: flex;
    gap: 15px;
    align-items: center;
    background: #edecd6; /* subtle highlight */
    padding: 20px;
    border-radius: 8px; /* Standard radius just for this block */
    margin-bottom: 40px;
  }

  .highlight-icon {
    font-size: 1.5rem;
    color: var(--accent-green);
  }

  .highlight-callout p {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.5;
    color: var(--text-primary);
  }

  /* ---------------------------------------
   RESPONSIVE DESIGN (MOBILE/TABLET)
---------------------------------------- */
  @media (max-width: 1024px) {
    .bento-grid-about {
      grid-template-columns: 1fr;
    }

    .img-left {
      height: 300px;
    }

    .img-right {
      height: 400px;
    }

    .services-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .service-panels-area {
      grid-column: 1 / -1;
      grid-template-columns: 1fr;
    }

    .service-panel {
      grid-template-columns: 1fr;
      grid-area: 1 / 1 / 2 / 2;
    }

    .service-image {
      height: 400px;
    }
  }

  @media (max-width: 768px) {
    .about-page {
      padding-top: 100px;
      padding-left: 20px;
      padding-right: 20px;
    }

    .huge-title {
      font-size: 3rem;
    }

    .services-nav {
      flex-direction: row;
      overflow-x: auto;
      padding-bottom: 20px;
      margin-bottom: 20px;
      /* Hide scrollbar but keep functionality */
      -ms-overflow-style: none;
      scrollbar-width: none;
      gap: 15px;
    }

    .services-nav::-webkit-scrollbar {
      display: none;
    }

    .service-btn {
      white-space: nowrap;
      padding: 12px 20px;
      font-size: 0.9rem;
      border-radius: 50px; /* Pill shape on mobile */
    }

    .service-image {
      height: 250px;
    }

    .detail-title {
      font-size: 1.8rem;
    }

    .highlight-callout {
      padding: 15px;
      margin-bottom: 30px;
    }
    
    .centered-desc {
        font-size: 0.95rem;
    }
  }

  /* =======================================
   JOURNEY / VISION / MISSION TAB SECTION
  ======================================= */
  .tab-panel-section {
    margin-bottom: 80px;
    padding-bottom: 60px;
    border-bottom: 1px solid var(--border-color);
  }

  /* Pill switcher row */
  .tab-switcher {
    display: flex;
    gap: 10px;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }

  .tab-pill {
    font-family: "Open Sans", sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    padding: 10px 24px;
    border-radius: 9999px; /* full pill */
    border: 1.5px solid var(--border-color);
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    letter-spacing: 0.3px;
    transition:
      background 0.3s ease,
      color 0.3s ease,
      border-color 0.3s ease;
  }

  .tab-pill:hover:not(.active) {
    background: var(--border-color);
    color: var(--text-primary);
  }

  .tab-pill.active {
    background: var(--accent-green);
    color: #fff;
    border-color: var(--accent-green);
  }

  /* Panel layout: bullet meta left | large text right */
  /* Grid stacking: all panels share cell 1/1 so container never collapses */
  .tab-content-area {
    display: grid;
  }

  .tab-panel {
    /* Stack all panels in the same grid cell */
    grid-area: 1 / 1;
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 40px;
    align-items: start;
    align-content: start; /* Ensures rows are packed at the top */
    justify-content: start; /* Ensures columns are packed at the start */
    /* Fade + slide transition */
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.35s ease,
      transform 0.35s ease;
    pointer-events: none;
    /* Invisible panels don't block interaction or layout */
    visibility: hidden;
  }

  .tab-panel.active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    visibility: visible;
  }

  /* Left meta column */
  .tab-meta {
    padding-top: 8px;
  }

  .tab-meta-label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 1px;
    line-height: 1.4;
    display: block;
  }

  /* Right content column */
  .tab-body {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .tab-heading {
    font-family: "Merriweather", serif;
    font-size: clamp(1.7rem, 2.5vw, 2.6rem);
    font-weight: 400;
    line-height: 1.25;
    color: var(--text-primary);
    margin: 0;
    letter-spacing: -0.3px;
  }

  .tab-desc {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin: 0;
    max-width: 680px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .tab-panel {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .tab-panel-section {
      margin-bottom: 60px;
    }
  }

  /* New Tab Features Styles */
  .tab-features-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px 60px;
    margin-top: 40px;
    border-top: 1px solid var(--border-color);
    padding-top: 40px;
  }

  .feature-item {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .feature-item h4 {
    font-family: "Merriweather", serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--accent-green);
    margin: 0;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .feature-item h4::before {
    content: "✦";
    font-size: 0.9rem;
    opacity: 0.6;
  }

  .feature-item p {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin: 0;
  }

  @media (max-width: 600px) {
    .tab-features-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }
  }

  /* =======================================
   CTA SECTION
  ======================================= */
  .about-cta {
    width: 100%;
    height: 780px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
    overflow: hidden;
    margin-bottom: 0;
  }

  .cta-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .cta-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      rgba(31, 40, 21, 0.4),
      rgba(31, 40, 21, 0.8)
    );
    z-index: 2;
  }

  .cta-content {
    position: relative;
    z-index: 3;
    max-width: 800px;
    padding: 0 20px;
  }

  .cta-title {
    font-family: "Merriweather", serif;
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 20px;
    line-height: 1.2;
  }

  .cta-desc {
    font-size: 1.1rem;
    margin-bottom: 40px;
    opacity: 0.9;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-btn {
    display: inline-block;
    background: var(--about-bg);
    color: var(--accent-green);
    font-weight: 700;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 16px 40px;
    border-radius: 99px;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
  }

  .cta-btn:hover {
    background: #fff;
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
  }

  @media (max-width: 768px) {
    .about-cta {
      height: auto;
      padding: 80px 0;
    }
  }
</style>

<script>
  // ── Journey / Vision / Mission tab switcher ──────────────────────
  const pills = document.querySelectorAll<HTMLButtonElement>(".tab-pill");
  const panels = document.querySelectorAll<HTMLElement>(".tab-panel");

  pills.forEach((pill) => {
    pill.addEventListener("click", () => {
      const target = pill.dataset.tab;
      pills.forEach((p) => p.classList.remove("active"));
      pill.classList.add("active");
      panels.forEach((panel) => panel.classList.remove("active"));
      const targetPanel = document.getElementById(`tab-${target}`);
      if (targetPanel) {
        setTimeout(() => targetPanel.classList.add("active"), 50);
      }
    });
  });

  // ── Services section switcher ─────────────────────────────────────
  const serviceBtns =
    document.querySelectorAll<HTMLButtonElement>(".service-btn");
  const servicePanels =
    document.querySelectorAll<HTMLElement>(".service-panel");

  serviceBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const target = btn.dataset.service;

      // Update active button
      serviceBtns.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");

      // Fade out all panels
      servicePanels.forEach((panel) => panel.classList.remove("active"));

      // Fade in the target panel
      const targetPanel = document.getElementById(`svc-${target}`);
      if (targetPanel) {
        setTimeout(() => targetPanel.classList.add("active"), 50);
      }
    });
  });

  // ── Hash handling for deep linking ────────────────────────────────
  window.addEventListener("load", () => {
    const hash = window.location.hash;
    if (!hash) return;

    const id = hash.substring(1); // remove #

    // Check if it's a tab (Journey/Vision/Mission)
    if (id.startsWith("tab-")) {
      const tabName = id.replace("tab-", "");
      const pill = document.querySelector<HTMLButtonElement>(
        `.tab-pill[data-tab="${tabName}"]`
      );
      if (pill) pill.click();
      // Scroll to the tabs section
      const tabSection = document.querySelector(".tabs-section");
      if (tabSection) tabSection.scrollIntoView({ behavior: "smooth" });
    }

    // Check if it's a service (svc-herbal, etc)
    if (id.startsWith("svc-")) {
      const svcName = id.replace("svc-", "");
      const btn = document.querySelector<HTMLButtonElement>(
        `.service-btn[data-service="${svcName}"]`
      );
      if (btn) btn.click();
      // Scroll to the services section
      const servicesSection = document.querySelector(".services-offer");
      if (servicesSection)
        servicesSection.scrollIntoView({ behavior: "smooth" });
    }
  });
</script>
