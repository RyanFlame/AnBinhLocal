---
import Layout from "../layouts/Layout.astro";
import { Image } from 'astro:assets';
import { getImageByPath } from '../utils/assets';
import { useTranslations } from "../i18n/utils";
import { type Locale } from "../i18n/config";

const locale = (Astro.currentLocale || "vi") as Locale;
const t = useTranslations(locale);

const bgAsset = getImageByPath('Asset/404-bg.png');
---

<Layout title={t("404.title")}>
  <main class="error-page" data-header-theme="light">
    <div class="container error-container">
      <div class="error-visual">
          <div class="frame-scooped scoop-xl">
             <Image src={bgAsset} alt="Serene Clinic Doorway" class="error-img" />
          </div>
          <div class="floating-404">404</div>
      </div>
      
      <div class="error-content">
        <span class="accent-label">
            {t("404.accent")}
        </span>
        <h1 class="heading-section">
           {t("404.heading")}
        </h1>
        <p class="body-large">
          {t("404.desc")}
        </p>
        
        <div class="error-actions">
           <a href={locale === "vi" ? "/" : "/en/"} class="btn-primary">
              {t("404.actions.home")}
           </a>
           <a href={locale === "vi" ? "/about#services" : "/en/about#services"} class="btn-secondary">
              {t("404.actions.therapies")}
           </a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .error-page {
    min-height: 90vh;
    display: flex;
    align-items: center;
    background-color: var(--warm-white);
    padding-top: 100px;
    padding-bottom: 100px;
  }

  .error-container {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 80px;
    align-items: center;
  }

  .error-visual {
    position: relative;
    padding: 20px;
  }

  .error-img {
    width: 100%;
    height: 550px;
    object-fit: cover;
    display: block;
  }

  .floating-404 {
    position: absolute;
    top: -30px;
    right: -20px;
    font-family: var(--font-serif);
    font-size: 10rem;
    color: var(--indochine-teal);
    opacity: 0.12;
    z-index: 10;
    pointer-events: none;
    line-height: 1;
  }

  .error-content {
    display: flex;
    flex-direction: column;
    gap: 25px;
  }

  .accent-label {
    display: block;
    margin-bottom: -15px;
  }

  .error-actions {
    display: flex;
    gap: 20px;
    margin-top: 20px;
  }

  @media screen and (max-width: 992px) {
    .error-container {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 50px;
    }
    
    .error-visual {
        max-width: 500px;
        margin: 0 auto;
    }
    
    .error-img {
      height: 400px;
    }
    
    .error-actions {
      justify-content: center;
    }

    .floating-404 {
        font-size: 7rem;
        top: -10px;
        right: 0;
    }
  }

  @media screen and (max-width: 600px) {
    .error-actions {
      flex-direction: column;
      align-items: center;
    }
    .error-actions a {
        width: 100%;
        text-align: center;
    }
    .heading-section {
        font-size: 2.2rem;
    }
  }
</style>
