---
import { Image } from "astro:assets";
import { getImageByPath } from "../../utils/assets";
import { useTranslations } from "../../i18n/utils";

const { locale = "vi" } = Astro.props;
const t = useTranslations(locale);

const asset_Dad_Final_3_webp = getImageByPath("Dad Final 3.webp");
const asset_Thu_c_1E_webp = getImageByPath("Thuốc 1E.webp");
---

<!-- PHILOSOPHY SECTION  -->
<section class="philosophy-section">
  <div class="philosophy-container">
    <div class="philosophy-text">
      <h2 class="section-heading heading-section">
        {t("philosophy.section.title")}
      </h2>
      <h3 class="sub-heading">
        {t("philosophy.section.subtitle")}
      </h3>
      <p class="body-regular" set:html={t("philosophy.section.body")} />
      <a href="/about" class="btn-secondary">
        {t("philosophy.section.btn")}
      </a>
    </div>

    <div class="philosophy-image-wrapper">
      <div class="philosophy-frame">
        <Image
          src={asset_Dad_Final_3_webp}
          alt="Traditional Medicine Philosophy"
          class="philosophy-img"
        />
      </div>
    </div>
  </div>
</section>

<!-- INGREDIENT DETAIL SECTION -->
<section class="philosophy-section">
  <div class="philosophy-container reverse">
    <div class="philosophy-text">
      <h2 class="section-heading heading-section">
        {t("philosophy.herbs.title")}
      </h2>
      <h3 class="sub-heading">
        {t("philosophy.herbs.subtitle")}
      </h3>
      <p class="body-regular" set:html={t("philosophy.herbs.body")} />
      <a href="/ingredients" class="btn-secondary">
        {t("philosophy.herbs.btn")}
      </a>
    </div>

    <div class="philosophy-image-wrapper">
      <div class="philosophy-frame">
        <Image
          src={asset_Thu_c_1E_webp}
          alt="Premium Herbs"
          class="philosophy-img"
        />
      </div>
    </div>
  </div>
</section>

<style>
/* =========================================
   PHILOSOPHY SECTION ("Our Philosophy")
   ========================================= */
.philosophy-section {
    background-color: var(--beige-sand); /* Replaced var(--section-bg) */
    padding: 80px 0;
    font-family: var(--font-sans);
}

.philosophy-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 60px;
}

/* Modifiers */
.philosophy-container.reverse {
    flex-direction: row-reverse;
}

/* Text Side */
.philosophy-text {
    flex: 1;
    max-width: 550px;
}

.section-heading {
    font-family: var(--font-serif);
    font-size: 2.5rem;
    color: var(--text-brown);
    margin-bottom: 10px;
    position: relative;
    display: inline-block;
}

.sub-heading {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    color: var(--primary-green);
    margin-bottom: 25px;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
}

.philosophy-text p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-main);
    margin-bottom: 40px;
}

/* Button with existing theme style */
.btn-more, .btn-secondary {
    display: inline-block;
    padding: 12px 35px;
    border: 2px solid var(--text-brown);
    text-decoration: none;
    color: var(--text-brown);
    font-size: 0.95rem;
    letter-spacing: 1px;
    font-weight: 600;
    transition: all 0.3s ease;
    background: transparent;
}

.btn-more:hover, .btn-secondary:hover {
    background: var(--text-brown);
    color: var(--accent-cream);
}

/* Image Side with Scooped Corners */
.philosophy-image-wrapper {
    flex: 1;
    display: flex;
    justify-content: center;
}

.philosophy-frame {
    width: 400px;
    height: 500px;
    position: relative;
    
    /* Decoration Border (Double line illusion via padding + border) */
    padding: 8px;
    border: 1px solid var(--text-brown);
    
    /* The Scooped Mask */
    --p-scoop: 30px;
    -webkit-mask-image: 
        radial-gradient(circle at top left, transparent var(--p-scoop), black calc(var(--p-scoop) + 0.5px)),
        radial-gradient(circle at top right, transparent var(--p-scoop), black calc(var(--p-scoop) + 0.5px)),
        radial-gradient(circle at bottom left, transparent var(--p-scoop), black calc(var(--p-scoop) + 0.5px)),
        radial-gradient(circle at bottom right, transparent var(--p-scoop), black calc(var(--p-scoop) + 0.5px));
    -webkit-mask-position: top left, top right, bottom left, bottom right;
    -webkit-mask-size: 51% 51%;
    -webkit-mask-repeat: no-repeat;
    
    mask-image: 
        radial-gradient(circle at top left, transparent var(--p-scoop), black calc(var(--p-scoop) + 0.5px)),
        radial-gradient(circle at top right, transparent var(--p-scoop), black calc(var(--p-scoop) + 0.5px)),
        radial-gradient(circle at bottom left, transparent var(--p-scoop), black calc(var(--p-scoop) + 0.5px)),
        radial-gradient(circle at bottom right, transparent var(--p-scoop), black calc(var(--p-scoop) + 0.5px));
    mask-position: top left, top right, bottom left, bottom right;
    mask-size: 51% 51%;
    mask-repeat: no-repeat;
    
    transition: transform 0.4s ease;
}

.philosophy-frame:hover {
    transform: scale(1.02);
}

.philosophy-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Apply inner mask or just let it fill the masked container */
    display: block;
}

@media screen and (max-width: 768px) {
    .philosophy-container, .philosophy-container.reverse {
        flex-direction: column;
        text-align: center;
        gap: 30px;
    }
    .philosophy-frame {
        width: 100%;
        max-width: 320px;
        height: 380px;
        margin: 0 auto;
    }
}

@media screen and (max-width: 480px) {
    .philosophy-frame {
        height: 320px;
        max-width: 290px;
    }
}
</style>
