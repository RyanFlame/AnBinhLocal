  .tab-pill {
    font-family: "Open Sans", sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    padding: 10px 24px;
    border-radius: 9999px; /* full pill */
    border: 1.5px solid var(--border-color);
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    letter-spacing: 0.3px;
    transition:
      background 0.3s ease,
      color 0.3s ease,
      border-color 0.3s ease;
  }

  .tab-pill:hover:not(.active) {
    background: var(--border-color);
    color: var(--text-primary);
  }

  .tab-pill.active {
    background: var(--accent-green);
    color: #fff;
    border-color: var(--accent-green);
  }

  /* Panel layout: bullet meta left | large text right */
  /* Grid stacking: all panels share cell 1/1 so container never collapses */
  .tab-content-area {
    display: grid;
  }

  .tab-panel {
    /* Stack all panels in the same grid cell */
    grid-area: 1 / 1;
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 40px;
    align-items: start;
    align-content: start; /* Ensures rows are packed at the top */
    justify-content: start; /* Ensures columns are packed at the start */
    /* Fade + slide transition */
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.35s ease,
      transform 0.35s ease;
    pointer-events: none;
    /* Invisible panels don't block interaction or layout */
    visibility: hidden;
  }

  .tab-panel.active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    visibility: visible;
  }

  /* Left meta column */
  .tab-meta {
    padding-top: 8px;
  }

  .tab-meta-label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 1px;
    line-height: 1.4;
    display: block;
  }

  /* Right content column */
  .tab-body {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .tab-heading {
    font-family: "Merriweather", serif;
    font-size: clamp(1.7rem, 2.5vw, 2.6rem);
    font-weight: 400;
    line-height: 1.25;
    color: var(--text-primary);
    margin: 0;
    letter-spacing: -0.3px;
  }

  .tab-desc {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin: 0;
    max-width: 680px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .tab-panel {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .tab-panel-section {
      margin-bottom: 60px;
    }
  }

  /* New Tab Features Styles */
  .tab-features-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px 60px;
    margin-top: 40px;
    border-top: 1px solid var(--border-color);
    padding-top: 40px;
  }

  .feature-item {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .feature-item h4 {
    font-family: "Merriweather", serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--accent-green);
    margin: 0;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .feature-item h4::before {
    content: "✦";
    font-size: 0.9rem;
    opacity: 0.6;
  }

  .feature-item p {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin: 0;
  }

  @media (max-width: 600px) {
    .tab-features-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }
  }

  /* =======================================
   CTA SECTION
  ======================================= */
  .about-cta {
    width: 100%;
    height: 780px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
    overflow: hidden;
    margin-bottom: 0;
  }

  .cta-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .cta-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      rgba(31, 40, 21, 0.4),
      rgba(31, 40, 21, 0.8)
    );
    z-index: 2;
  }

  .cta-content {
    position: relative;
    z-index: 3;
    max-width: 800px;
    padding: 0 20px;
  }

  .cta-title {
    font-family: "Merriweather", serif;
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 20px;
    line-height: 1.2;
  }

  .cta-desc {
    font-size: 1.1rem;
    margin-bottom: 40px;
    opacity: 0.9;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-btn {
    display: inline-block;
    background: var(--about-bg);
    color: var(--accent-green);
    font-weight: 700;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 16px 40px;
    border-radius: 99px;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
  }

  .cta-btn:hover {
    background: #fff;
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
  }

  @media (max-width: 768px) {
    .about-cta {
      height: auto;
      padding: 80px 0;
    }
  }
</style>

<script>
  // ── Journey / Vision / Mission tab switcher ──────────────────────
  const pills = document.querySelectorAll<HTMLButtonElement>(".tab-pill");
  const panels = document.querySelectorAll<HTMLElement>(".tab-panel");

  pills.forEach((pill) => {
    pill.addEventListener("click", () => {
      const target = pill.dataset.tab;
      pills.forEach((p) => p.classList.remove("active"));
      pill.classList.add("active");
      panels.forEach((panel) => panel.classList.remove("active"));
      const targetPanel = document.getElementById(`tab-${target}`);
      if (targetPanel) {
        setTimeout(() => targetPanel.classList.add("active"), 50);
      }
    });
  });

  // ── Services section switcher ─────────────────────────────────────
  const serviceBtns =
    document.querySelectorAll<HTMLButtonElement>(".service-btn");
  const servicePanels =
    document.querySelectorAll<HTMLElement>(".service-panel");

  serviceBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const target = btn.dataset.service;

      // Update active button
      serviceBtns.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");

      // Fade out all panels
      servicePanels.forEach((panel) => panel.classList.remove("active"));

      // Fade in the target panel
      const targetPanel = document.getElementById(`svc-${target}`);
      if (targetPanel) {
        setTimeout(() => targetPanel.classList.add("active"), 50);
      }
    });
  });

  // ── Hash handling for deep linking ────────────────────────────────
  window.addEventListener("load", () => {
    const hash = window.location.hash;
    if (!hash) return;

    const id = hash.substring(1); // remove #

    // Check if it's a tab (Journey/Vision/Mission)
    if (id.startsWith("tab-")) {
      const tabName = id.replace("tab-", "");
      const pill = document.querySelector<HTMLButtonElement>(
        `.tab-pill[data-tab="${tabName}"]`
      );
      if (pill) pill.click();
      // Scroll to the tabs section
      const tabSection = document.querySelector(".tabs-section");
      if (tabSection) tabSection.scrollIntoView({ behavior: "smooth" });
    }

    // Check if it's a service (svc-herbal, etc)
    if (id.startsWith("svc-")) {
      const svcName = id.replace("svc-", "");
      const btn = document.querySelector<HTMLButtonElement>(
        `.service-btn[data-service="${svcName}"]`
      );
      if (btn) btn.click();
      // Scroll to the services section
      const servicesSection = document.querySelector(".services-offer");
      if (servicesSection)
        servicesSection.scrollIntoView({ behavior: "smooth" });
    }
  });
</script>
