---
import { Image } from "astro:assets";
import { getImageByPath } from "../utils/assets";

// Footer Component
const logoAsset = getImageByPath("Logo/Logo-NBG.png");
const bookingAsset = getImageByPath("Thuốc 1E.webp");
---

<footer class="bg-ebony-black text-cream-rice pt-2xl pb-0 font-sans relative border-t-[5px] border-brass-gold">
  <div class="max-w-[1200px] mx-auto px-lg pb-xl pt-0 grid grid-cols-[1.5fr_1fr_1fr_1fr] gap-lg max-[900px]:grid-cols-1 max-[900px]:gap-lg max-[900px]:text-left max-[900px]:px-[25px] max-[900px]:pb-lg">
    <!-- Brand Column -->
    <div class="flex flex-col items-start max-[900px]:col-span-1">
      <Image src={logoAsset} alt="An Binh Logo" class="footer-logo" />
      <h3 class="font-serif text-[1.5rem] text-brass-gold mb-[15px]">Phòng Khám Y Học Cổ Truyền An Bình</h3>
      <p
        class="text-[0.95rem] leading-[1.6] text-subtle-grey max-w-[280px] lang-text"
        data-en="Peaceful nourishment, balanced vitality"
        data-vn="An nhiên dưỡng tạng – Bình ổn thân tâm"
      >
        An nhiên dưỡng tạng – Bình ổn thân tâm
      </p>
    </div>

    <!-- Links Column -->
    <div class="flex flex-col">
      <h4
        class="font-serif text-[1.2rem] text-white mb-md relative pb-[15px] after:content-[''] after:absolute after:bottom-0 after:left-0 after:w-10 after:h-[2px] after:bg-primary-green lang-text"
        data-en="Quick Links"
        data-vn="Liên Kết Nhanh"
      >
        Liên Kết Nhanh
      </h4>
      <div class="flex flex-col gap-[15px] max-[900px]:grid max-[900px]:grid-cols-2 max-[900px]:gap-5">
        <a
          href="/about"
          class="lang-text"
          data-en="Philosophy"
          data-vn="Triết Lý">Triết Lý</a
        >
        <a
          href="/ingredients"
          class="lang-text"
          data-en="Remedies"
          data-vn="Bài Thuốc">Bài Thuốc</a
        >
        <a
          href="/therapies"
          class="lang-text"
          data-en="Services"
          data-vn="Liệu Pháp">Liệu Pháp</a
        >
        <a
          href="https://www.google.com/maps/place/Ph%C3%B2ng+Y+H%E1%BB%8Dc+C%E1%BB%95+Truy%E1%BB%81n+An+B%C3%ACnh/@10.5085571,107.327058,455m/data=!3m1!1e3!4m6!3m5!1s0x3175a100125c7973:0x97569e0490503fa6!8m2!3d10.5082762!4d107.3262642!16s%2Fg%2F11mf93d8rf!5m1!1e1?authuser=0&entry=ttu&g_ep=EgoyMDI1MTIwOS4wIKXMDSoASAFQAw%3D%3D"
          class="lang-text"
          data-en="Visit Us"
          data-vn="Địa Chỉ">Địa Chỉ</a
        >
      </div>
    </div>

    <!-- Contact Column -->
    <div class="flex flex-col">
      <h4
        class="font-serif text-[1.2rem] text-white mb-md relative pb-[15px] after:content-[''] after:absolute after:bottom-0 after:left-0 after:w-10 after:h-[2px] after:bg-primary-green lang-text"
        data-en="Contact Us"
        data-vn="Liên Hệ"
      >
        Liên Hệ
      </h4>
      <p class="mb-md text-[0.95rem] text-subtle-grey leading-relaxed">
        <strong class="text-white inline-block mr-[5px] lang-text" data-en="Old Address:" data-vn="Địa Chỉ Cũ:"
          >Địa Chỉ Cũ:</strong
        >
        Đường Tháp Nước, Xã Láng Dài, Huyện Đất Đỏ, Tỉnh BR-VT
      </p>

      <div class="flex flex-row justify-start items-baseline gap-[30px] flex-wrap mt-[10px] max-[900px]:gap-[30px]">
        <p class="mb-0 text-[0.95rem] text-subtle-grey leading-relaxed min-w-0">
          <strong class="text-white block mr-[5px] lang-text" data-en="Phone:" data-vn="Điện thoại:"
            >Điện thoại:</strong
          >
          0908 052 968
        </p>
        <p class="mb-0 text-[0.95rem] text-subtle-grey leading-relaxed min-w-0">
          <strong class="text-white block mr-[5px]">Email:</strong>
          info@yhctanbinh.com
        </p>
      </div>
    </div>

    <!-- Hours Column -->
    <div class="flex flex-col">
      <h4
        class="font-serif text-[1.2rem] text-white mb-md relative pb-[15px] after:content-[''] after:absolute after:bottom-0 after:left-0 after:w-10 after:h-[2px] after:bg-primary-green lang-text"
        data-en="Hours"
        data-vn="Giờ Mở Cửa"
      >
        Giờ Mở Cửa
      </h4>
      <ul class="list-none p-0">
        <li class="flex justify-between mb-3 text-[0.95rem] text-[#ccc] border-b border-white/10 pb-2">
          <span class="text-white font-semibold lang-text" data-en="Mon-Fri:" data-vn="T2-T6:"
            >T2-T6:</span
          >
          <span class="text-white font-semibold lang-text" data-en="9am - 6pm" data-vn="9h - 18h"
            >9h - 18h</span
          >
        </li>
        <li class="flex justify-between mb-3 text-[0.95rem] text-subtle-grey border-b border-white/10 pb-2">
          <span class="text-white font-semibold lang-text" data-en="Sat:" data-vn="T7:">T7:</span>
          <span class="text-white font-semibold lang-text" data-en="10am - 4pm" data-vn="10h - 16h"
            >10h - 16h</span
          >
        </li>
        <li class="flex justify-between mb-3 text-[0.95rem] text-subtle-grey border-b border-white/10 pb-2 !border-none">
          <span class="text-white font-semibold lang-text" data-en="Sun:" data-vn="CN:">CN:</span>
          <span class="text-white font-semibold lang-text" data-en="Closed" data-vn="Đóng cửa"
            >Đóng cửa</span
          >
        </li>
      </ul>
    </div>
  </div>

  <div class="bg-off-black py-md px-lg text-center border-t border-white/5 max-w-none">
    <div
      class="text-[0.85rem] text-[#888] lang-text"
      data-en="© 2026 An Binh Traditional Clinic. <br class='mobile-only'>All Rights Reserved."
      data-vn="© 2026 An Bình. <br class='mobile-only'>Bản Quyền Đã Được Bảo Lưu."
    >
      &copy; 2026 An Bình. <br class="mobile-only" />Bản Quyền Đã Được Bảo Lưu.
    </div>
  </div>
</footer>



<!-- Zalo Floating Button -->
<div class="zalo-container right">
  <a
    id="zalo-btn"
    href="https://zalo.me/0908052968"
    target="_blank"
    rel="noopener nofollow"
  >
    <div class="animated_zalo infinite zoomIn_zalo cmoz-alo-circle"></div>
    <div class="animated_zalo infinite pulse_zalo cmoz-alo-circle-fill"></div>
    <span
      ><Image
        src="https://vutruso.com/wp-content/uploads/2024/05/zalo-2.png"
        alt="Contact Me on Zalo"
        width={35}
        height={35}
      /></span
    >
  </a>
</div>

<style>
  /* =========================================
     SITE FOOTER (Indochine Theme)
     ========================================= */
  /* --- SITE FOOTER STYLES REDUCED TO LOGO LOGIC --- */
  .footer-logo {
    height: 80px;
    width: auto;
    margin-bottom: 20px;
    filter: brightness(1.35);
    padding: 9px;
    background-image: url("/Logo/Seal-NBG.png");
    background-size: 110px 110px;
    background-position: center;
    background-repeat: no-repeat;
  }


  @media screen and (max-width: 900px) {
    .site-footer {
      padding: 60px 0 0 0;
    }
  }

  /* --- BOOKING MODAL MOVED TO COMPONENT --- */

  /* =========================================
     FLOATING ZALO BUTTON
     ========================================= */
  .zalo-container {
    position: fixed;
    bottom: 25px;
    z-index: 9999;
    width: 60px;
    height: 60px;
  }
  .zalo-container.right {
    right: 35px;
  }
  #zalo-btn {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
    text-decoration: none;
  }

  #zalo-btn .cmoz-alo-circle {
    width: 60px;
    height: 60px;
    top: 50%;
    left: 50%;
    position: absolute;
    background-color: transparent;
    border-radius: 100%;
    border: 2px solid #0068ff;
    opacity: 1;
    transform: translate(-50%, -50%);
    transition: all 0.2s ease-in-out;
  }
  #zalo-btn .cmoz-alo-circle-fill {
    width: 40px;
    height: 40px;
    top: 50%;
    left: 50%;
    position: absolute;
    background-color: #0068ff;
    border-radius: 100%;
    border: 2px solid transparent;
    opacity: 0.7;
    transform: translate(-50%, -50%);
    transition: all 0.2s ease-in-out;
  }
  #zalo-btn span {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 40px;
    height: 40px;
    top: 50%;
    left: 50%;
    position: absolute;
    background-color: #0068ff;
    border-radius: 100%;
    transform: translate(-50%, -50%);
    overflow: hidden;
  }
  #zalo-btn span :global(img) {
    width: 45px;
    height: 45px;
    object-fit: contain;
  }

  .animated_zalo.zoomIn_zalo {
    animation-name: zoomIn_zalo;
  }
  .animated_zalo.pulse_zalo {
    animation-name: pulse_zalo;
  }
  .animated_zalo.infinite {
    animation-iteration-count: infinite;
  }
  .animated_zalo {
    animation-duration: 1s;
    animation-fill-mode: both;
  }

  @keyframes zoomIn_zalo {
    0% {
      opacity: 0;
      transform: translate(-50%, -50%) scale3d(0.3, 0.3, 0.3);
    }
    50% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }
  @keyframes pulse_zalo {
    0% {
      transform: translate(-50%, -50%) scale3d(1, 1, 1);
      opacity: 0.7;
    }
    50% {
      transform: translate(-50%, -50%) scale3d(1.3, 1.3, 1.3);
      opacity: 0;
    }
    100% {
      transform: translate(-50%, -50%) scale3d(1, 1, 1);
      opacity: 0;
    }
  }

  @media screen and (max-width: 768px) {
    .zalo-container {
      bottom: 20px;
    }
    .zalo-container.right {
      right: 25px;
    }
  }
</style>

<style is:global>
  body.booking-disabled .booking-feature {
    display: none !important;
  }
</style>
