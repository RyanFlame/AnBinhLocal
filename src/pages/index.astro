---
import Layout from "../layouts/Layout.astro";
import HeroSection from "../components/home/HeroSection.astro";
import ProductCarousel from "../components/home/ProductCarousel.astro";
import PhilosophySection from "../components/home/PhilosophySection.astro";
import TherapiesBentoGrid from "../components/home/TherapiesBentoGrid.astro";
import LocationSection from "../components/home/LocationSection.astro";
import WallOfLove from "../components/home/WallOfLove.astro";
import FAQSection from "../components/home/FAQSection.astro";
import { type Locale } from "../i18n/config";

const locale = (Astro.currentLocale || "vi") as Locale;
---

<Layout title="An Binh - Traditional Chinese Medicine">
  <HeroSection locale={locale} />
  <ProductCarousel locale={locale} />
  <PhilosophySection locale={locale} />
  <TherapiesBentoGrid locale={locale} />
  <LocationSection locale={locale} />
  <WallOfLove locale={locale} />
  <FAQSection locale={locale} />
</Layout>
