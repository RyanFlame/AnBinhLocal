---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import GlobalLoader from "../components/GlobalLoader.astro";
import BookingModal from "../components/BookingModal.astro";
import SEO from "../components/SEO.astro";
import { type Locale } from "../i18n/config";
import "../styles/global.css";

type Props = {
  title: string;
  description?: string;
  image?: string;
};

const { title, description, image } = Astro.props;
const locale = (Astro.currentLocale || "vi") as Locale;
const lang = locale;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <SEO title={title} description={description} image={image} locale={locale} />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" is:inline></script>


    <!-- Google Tag Manager -->
    <script type="text/partytown">
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-M93VGLK5");
    </script>
    <!-- End Google Tag Manager -->

    <!-- Google Analytics (GA4) -->
    <script
      type="text/partytown"
      src="https://www.googletagmanager.com/gtag/js?id=G-BRLVYQF4KP"></script>
    <script type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-BRLVYQF4KP");
    </script>
    <!-- End GA4 -->

    <!-- Schema.org JSON-LD for An Binh Clinic -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "MedicalClinic",
        "name": "Phòng Khám YHCT An Bình",
        "alternateName": "An Binh Traditional Medicine",
        "slogan": "An nhiên dưỡng tạng – Bình ổn thân tâm",
        "description": "Phòng khám YHCT An Bình mang đến không gian chữa lành yên bình tại Đất Đỏ. Chuyên châm cứu, xoa bóp bấm huyệt và bốc thuốc Đông y truyền thống.",
        "image": "https://yhctanbinh.com/_astro/Thuoc-1E.webp",
        "logo": "https://yhctanbinh.com/Logo/Logo-NBG.png",
        "@id": "https://yhctanbinh.com/#clinic",
        "url": "https://yhctanbinh.com",
        "telephone": "+84-908-052-968",
        "priceRange": "VND",
        "inLanguage": ["vi", "en"],
        "paymentAccepted": "Cash, Bank Transfer",
        "isAcceptingNewPatients": true,
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Đường Tháp Nước, Xã Láng Dài",
          "addressLocality": "Huyện Đất Đỏ",
          "addressRegion": "Bà Rịa - Vũng Tàu",
          "postalCode": "790000",
          "addressCountry": "VN"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": "10.5082762",
          "longitude": "107.3262642"
        },
        "hasMap": "https://www.google.com/maps/place/Ph%C3%B2%C3%A0ng+Y+H%C3%A1%C2%BB%C2%8Dc+C%C3%A1%C2%BB%C2%95+Truy%C3%A1%C2%BB%C2%81n+An+B%C3%ACnh/@10.5082762,107.3262642",
        "areaServed": [
          { "@type": "AdministrativeArea", "name": "Bà Rịa - Vũng Tàu" },
          { "@type": "AdministrativeArea", "name": "Hồ Chí Minh City" },
          { "@type": "AdministrativeArea", "name": "Đồng Nai" }
        ],
        "medicalSpecialty": [
          "https://schema.org/PrimaryCare",
          "AlternativeMedicine",
          "TraditionalChineseMedicine"
        ],
        "availableService": [
          {
            "@type": "MedicalTherapy",
            "name": "Châm cứu (Acupuncture)"
          },
          {
            "@type": "MedicalTherapy",
            "name": "Xoa bóp bấm huyệt (Acupressure)"
          },
          {
            "@type": "MedicalTherapy",
            "name": "Bắt mạch kê đơn (Traditional Diagnosis)"
          }
        ],
        "openingHoursSpecification": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": [
              "Monday",
              "Tuesday",
              "Wednesday",
              "Thursday",
              "Friday"
            ],
            "opens": "09:00",
            "closes": "18:00"
          },
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": "Saturday",
            "opens": "10:00",
            "closes": "16:00"
          }
        ],
        "sameAs": ["https://www.facebook.com/AnBinhYHCT"]
      }
    </script>

    <script
      src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <script>
      const netlifyIdentity = (window as any).netlifyIdentity;
      if (netlifyIdentity) {
        netlifyIdentity.on("init", (user: any) => {
          if (!user) {
            netlifyIdentity.on("login", () => {
              document.location.href = "/anbinh-portal/";
            });
          }
        });
      }
    </script>
  </head>
  <body
    class="antialiased bg-warm-white text-text-main font-sans leading-relaxed overflow-x-clip"
    data-locale={locale}
  >
    <a href="#main-content" class="skip-to-content">
      Skip to content
    </a>
    
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-M93VGLK5"
        height="0"
        width="0"
        class="hidden invisible"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->
    
    <GlobalLoader />

    <Header locale={locale} />

    <main id="main-content" class="min-h-dvh">
      <slot />
    </main>

    <Footer locale={locale} />
    
    <BookingModal locale={locale} />

  </body>
</html>
