  .service-image {
    height: 500px;
    margin: 0;
  }

  /* Right Detail */
  .service-detail {
    display: flex;
    flex-direction: column;
    padding: 20px 0;
  }

  .service-panels-area {
    display: grid;
    grid-template-columns: 1fr 1fr; /* image col | detail col */
    grid-template-rows: 1fr;
    gap: 40px;
    grid-column: 2 / 4;
  }

  .service-panel {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    grid-area: 1 / 1 / 2 / 3; /* all panels share the same cell */
    align-items: start;
    /* Fade transition */
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.35s ease,
      transform 0.35s ease;
    pointer-events: none;
    visibility: hidden;
  }

  .service-panel.active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    visibility: visible;
  }

  .detail-title {
    font-family: "Merriweather", serif;
    font-size: 2.2rem;
    line-height: 1.2;
    margin: 0 0 25px 0;
    color: var(--text-primary);
  }

  .detail-title em {
    font-style: italic;
    font-weight: 400;
  }

  .detail-desc {
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 30px;
  }

  .highlight-callout {
    display: flex;
    gap: 15px;
    align-items: center;
    background: #edecd6; /* subtle highlight */
    padding: 20px;
    border-radius: 8px; /* Standard radius just for this block */
    margin-bottom: 40px;
  }

  .highlight-icon {
    font-size: 1.5rem;
    color: var(--accent-green);
  }

  .highlight-callout p {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.5;
    color: var(--text-primary);
  }

  /* ---------------------------------------
   RESPONSIVE DESIGN (MOBILE/TABLET)
---------------------------------------- */
  @media (max-width: 1024px) {
    .bento-grid-about {
      grid-template-columns: 1fr;
    }

    .img-left {
      height: 300px;
    }

    .img-right {
      height: 400px;
    }

    .services-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .service-panels-area {
      grid-column: 1 / -1;
      grid-template-columns: 1fr;
    }

    .service-panel {
      grid-template-columns: 1fr;
      grid-area: 1 / 1 / 2 / 2;
    }

    .service-image {
      height: 400px;
    }
  }

  @media (max-width: 768px) {
    .about-page {
      padding-top: 100px;
      padding-left: 20px;
      padding-right: 20px;
    }

    .huge-title {
      font-size: 3rem;
    }

