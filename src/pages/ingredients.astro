---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import { getImageByPath } from "../utils/assets";
import { useTranslations } from "../i18n/utils";
import { type Locale } from "../i18n/config";

const locale = (Astro.currentLocale || "vi") as Locale;
const t = useTranslations(locale);

// Use the elite bulk loader to get images automatically
// This is much cleaner than manually importing every single file.
const asset_Med_webp = getImageByPath("Med.webp");
const asset_Ingri_Ginseng_webp = getImageByPath("Ingri/Ginseng.webp");
const asset_Med8_webp = getImageByPath("Med8.webp");
const asset_Med3_webp = getImageByPath("Med3.webp");
const asset_Thu_c_3_webp = getImageByPath("Thuốc 3.webp");
const asset_Herbal_Medicine_webp = getImageByPath("Herbal-Medicine.webp");
---

<Layout title={`${t("ingredients.why.title").replace("<br>", " ")} - An Binh`}>
  <!-- ================================================ -->
  <!-- HERO SECTION                                       -->
  <!-- ================================================ -->
  <section class="ing-hero">
    <div class="ing-hero-overlay"></div>
    <div class="ing-hero-content">
      <p class="ing-hero-label">
        {t("ingredients.hero.label")}
      </p>
      <h1 class="ing-hero-title" set:html={t("ingredients.hero.title")} />
      <p class="ing-hero-desc">
        {t("ingredients.hero.desc")}
      </p>
      <a href="#categories" class="btn-primary ing-hero-btn">
        {t("ingredients.hero.btn")}
      </a>
    </div>
    <!-- Scooped decorative corner card -->
    <div class="ing-hero-corner">
      <div class="ing-hero-corner-inner">
        <span class="ing-corner-label">
          {t("ingredients.hero.corner.label")}
        </span>
        <div class="ing-corner-stats">
          <div class="ing-stat">
            <strong>{t("ingredients.hero.corner.stat1.num")}</strong>
            <small>{t("ingredients.hero.corner.stat1.label")}</small>
          </div>
          <div class="ing-stat-divider"></div>
          <div class="ing-stat">
            <strong>{t("ingredients.hero.corner.stat2.num")}</strong>
            <small>{t("ingredients.hero.corner.stat2.label")}</small>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================ -->
  <!-- WHY CHOOSE OUR INGREDIENTS                        -->
  <!-- ================================================ -->
  <section class="ing-why" id="categories">
    <div class="ing-why-container">
      <div class="ing-why-header">
        <p class="sub-heading">
          {t("ingredients.why.label")}
        </p>
        <h2 class="heading-section" set:html={t("ingredients.why.title")} />
        <p class="body-regular ing-why-desc">
          {t("ingredients.why.desc")}
        </p>
      </div>

      <!-- 3-column ingredient category cards -->
      <div class="ing-cards-grid">
        <!-- Card 1: Dried Herbs -->
        <div class="ing-category-card">
          <div class="ing-card-img-wrap">
            <Image
              src={asset_Med_webp}
              alt={t("ingredients.cards.c1.title")}
              class="ing-card-img"
            />
            <div class="ing-card-img-overlay"></div>
          </div>
          <div class="ing-card-body">
            <h3 class="heading-subsection ing-card-title">
              {t("ingredients.cards.c1.title")}
            </h3>
            <p class="body-small ing-card-desc">
              {t("ingredients.cards.c1.desc")}
            </p>
            <a href={locale === "vi" ? "/about" : "/en/about"} class="btn-secondary ing-card-btn">
              {t("ingredients.cards.c1.btn")}
            </a>
          </div>
        </div>

        <!-- Card 2: Medicinal Roots -->
        <div class="ing-category-card ing-card-featured">
          <div class="ing-card-img-wrap">
            <Image
              src={asset_Ingri_Ginseng_webp}
              alt={t("ingredients.cards.c2.title")}
              class="ing-card-img"
            />
            <div class="ing-card-img-overlay"></div>
          </div>
          <div class="ing-card-body">
            <h3 class="heading-subsection ing-card-title">
              {t("ingredients.cards.c2.title")}
            </h3>
            <p class="body-small ing-card-desc">
              {t("ingredients.cards.c2.desc")}
            </p>
            <a href={locale === "vi" ? "/about" : "/en/about"} class="btn-primary ing-card-btn">
              {t("ingredients.cards.c2.btn")}
            </a>
          </div>
        </div>

        <!-- Card 3: Herbal Blends -->
        <div class="ing-category-card">
          <div class="ing-card-img-wrap">
            <Image
              src={asset_Med8_webp}
              alt={t("ingredients.cards.c3.title")}
              class="ing-card-img"
            />
            <div class="ing-card-img-overlay"></div>
          </div>
          <div class="ing-card-body">
            <h3 class="heading-subsection ing-card-title">
              {t("ingredients.cards.c3.title")}
            </h3>
            <p class="body-small ing-card-desc">
              {t("ingredients.cards.c3.desc")}
            </p>
            <a href={locale === "vi" ? "/about" : "/en/about"} class="btn-secondary ing-card-btn">
              {t("ingredients.cards.c3.btn")}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================ -->
  <!-- EDITORIAL INFO SECTION (Row 1: 3-col text grid)  -->
  <!-- ================================================ -->
  <section class="ing-editorial">
    <div class="ing-editorial-container">
      <!-- Row 1: 3-column editorial grid -->
      <div class="ing-editorial-row ing-row-top">
        <!-- Col 1: label + big statement -->
        <div class="ing-ed-col ing-ed-col-left">
          <p class="ing-ed-label">
            {t("ingredients.editorial.label1")}
          </p>
          <h2 class="ing-ed-statement">
            {t("ingredients.editorial.statement")}
          </h2>
        </div>

        <!-- Col 2: category label + description paragraphs -->
        <div class="ing-ed-col ing-ed-col-mid">
          <p class="ing-ed-label">
            {t("ingredients.editorial.label2")}
          </p>
          <p class="ing-ed-body">
            {t("ingredients.editorial.body1")}
          </p>
          <p class="ing-ed-body">
            {t("ingredients.editorial.body2")}
          </p>
        </div>

        <!-- Col 3: image — stretches to match col 2 height -->
        <div class="ing-ed-col ing-ed-col-img">
          <div class="ing-ed-img-box">
            <Image src={asset_Med3_webp} alt="Herbal ingredients" />
          </div>
        </div>
      </div>

      <!-- Row 2: same 3-col grid, col 1 is intentionally blank (indent effect) -->
      <div class="ing-editorial-row ing-row-mid">
        <!-- Col 1: intentional blank spacer -->
        <div class="ing-ed-col ing-ed-col-spacer" aria-hidden="true"></div>

        <!-- Col 2: large italic quote -->
        <div class="ing-ed-col ing-ed-col-quote">
          <p class="ing-ed-label">
            {t("ingredients.editorial.label3")}
          </p>
          <blockquote class="ing-ed-quote">
            {t("ingredients.editorial.quote")}
          </blockquote>
        </div>

        <!-- Col 3: supporting text + CTA link -->
        <div class="ing-ed-col ing-ed-col-body">
          <p class="ing-ed-label">
            {t("ingredients.editorial.label4")}
          </p>
          <p class="ing-ed-body">
            {t("ingredients.editorial.body3")}
          </p>
          <p class="ing-ed-body">
            {t("ingredients.editorial.body4")}
          </p>
          <a href={locale === "vi" ? "/about" : "/en/about"} class="ing-ed-link">
            {t("ingredients.editorial.link")}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================ -->
  <!-- STATS BENTO ROW                                   -->
  <!-- ================================================ -->
  <section class="ing-bento">
    <div class="ing-bento-container">
      <!-- Card 1: Image -->
      <div class="ing-bento-card ing-bento-img">
        <Image src={asset_Thu_c_3_webp} alt="Herbal preparation" />
      </div>

      <!-- Card 2: Stat — Years -->
      <div class="ing-bento-card ing-bento-stat ing-stat-light">
        <a href={locale === "vi" ? "/about" : "/en/about"} class="ing-stat-arrow" aria-label="Learn more">
          <svg
            viewBox="0 0 24 24"
            width="18"
            height="18"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <path d="M7 17L17 7M17 7H7M17 7v10"></path>
          </svg>
        </a>
        <div class="ing-bento-stat-number">{t("ingredients.bento.s1.num")}</div>
        <div class="ing-bento-stat-title">
          {t("ingredients.bento.s1.title")}
        </div>
        <p class="ing-bento-stat-desc">
          {t("ingredients.bento.s1.desc")}
        </p>
      </div>

      <!-- Card 3: Image -->
      <div class="ing-bento-card ing-bento-img">
        <Image src={asset_Herbal_Medicine_webp} alt="Herbal medicine collection" />
      </div>

      <!-- Card 4: Stat — Satisfaction (Brass accent) -->
      <div class="ing-bento-card ing-bento-stat ing-stat-brass">
        <a href={locale === "vi" ? "/about" : "/en/about"} class="ing-stat-arrow" aria-label="Learn more">
          <svg
            viewBox="0 0 24 24"
            width="18"
            height="18"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <path d="M7 17L17 7M17 7H7M17 7v10"></path>
          </svg>
        </a>
        <div class="ing-bento-stat-number">{t("ingredients.bento.s2.num")}</div>
        <div class="ing-bento-stat-title">
          {t("ingredients.bento.s2.title")}
        </div>
        <p class="ing-bento-stat-desc">
          {t("ingredients.bento.s2.desc")}
        </p>
      </div>
    </div>
  </section>

  <!-- ================================================ -->
  <!-- CTA — LARGE TEXT MINIMAL STYLE                    -->
  <!-- ================================================ -->
  <section class="ing-cta-minimal">
    <div class="ing-cta-minimal-container">
      <div class="ing-editorial-rule"></div>
      <p class="ing-cta-min-label">
        {t("ingredients.cta.label")}
      </p>
      <h2 class="ing-cta-min-title">
        {t("ingredients.cta.title")}
      </h2>
      <div class="ing-editorial-rule"></div>
      <a href="#booking" class="ing-cta-min-link booking-feature">
        {t("ingredients.cta.btn")}
      </a>
    </div>
  </section>
</Layout>
<style>
  /* ================================================
   HERO SECTION
   ================================================ */
  .ing-hero {
    position: relative;
    min-height: 100vh;
    background-image: url("/Asset/Thuoc-1E.webp");
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .ing-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(36, 26, 15, 0.88) 0%,
      rgba(36, 26, 15, 0.6) 50%,
      rgba(36, 26, 15, 0.2) 100%
    );
    z-index: 1;
  }

  .ing-hero-content {
    position: relative;
    z-index: 2;
    max-width: 650px;
    padding: 140px 80px 100px;
  }

  .ing-hero-label {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--brass-gold);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .ing-hero-title {
    font-family: var(--font-serif);
    font-size: 4.2rem;
    color: var(--cream-rice);
    line-height: 1.15;
    margin-bottom: 25px;
    text-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
  }

  .ing-hero-desc {
    font-family: var(--font-sans);
    font-size: 1.1rem;
    color: rgba(249, 245, 227, 0.85);
    line-height: 1.7;
    margin-bottom: 40px;
    max-width: 520px;
  }

  .ing-hero-btn {
    font-size: 0.9rem;
    letter-spacing: 2px;
  }

  /* Corner stat card (bottom-right) */
  .ing-hero-corner {
    position: absolute;
    bottom: 0;
    right: 0;
    z-index: 3;
    background: var(--cream-rice);
    padding: 35px 45px;
    border-top-left-radius: 40px;

    /* Outer scooped shadow trick */
  }
  .ing-hero-corner::before {
    content: "";
    position: absolute;
    top: -40px;
    right: 0;
    width: 40px;
    height: 40px;
    background: transparent;
    border-bottom-right-radius: 50%;
    box-shadow: 20px 20px 0 20px var(--cream-rice);
    z-index: 5;
  }
  .ing-hero-corner::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: -40px;
    width: 40px;
    height: 40px;
    background: transparent;
    border-bottom-right-radius: 50%;
    box-shadow: 20px 20px 0 20px var(--cream-rice);
    z-index: 5;
  }

  .ing-hero-corner-inner {
    position: relative;
    z-index: 6;
  }

  .ing-corner-label {
    display: block;
    font-family: var(--font-serif);
    font-size: 0.85rem;
    color: var(--indochine-teal);
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 16px;
    font-weight: 700;
  }

  .ing-corner-stats {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .ing-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .ing-stat strong {
    font-family: var(--font-serif);
    font-size: 2rem;
    color: var(--mahogany-dark);
    line-height: 1;
  }

  .ing-stat small {
    font-size: 0.8rem;
    color: var(--walnut-brown);
    margin-top: 4px;
    text-align: center;
  }

  .ing-stat-divider {
    width: 1px;
    height: 50px;
    background: rgba(74, 59, 42, 0.2);
  }

  /* ================================================
   WHY OUR INGREDIENTS SECTION
   ================================================ */
  .ing-why {
    background-color: var(--beige-sand);
    padding: 100px 0;
  }

  .ing-why-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .ing-why-header {
    text-align: center;
    margin-bottom: 60px;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .ing-why-desc {
    margin-top: 20px;
    color: var(--walnut-brown);
  }

  /* 3-col grid */
  .ing-cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    align-items: start;
  }

  .ing-category-card {
    background: #fff;
    overflow: hidden;
    transition:
      transform 0.35s ease,
      box-shadow 0.35s ease;

    /* Scooped corners */
    --scoop-radius: 20px;
    -webkit-mask-image:
      radial-gradient(
        circle at top left,
        transparent var(--scoop-radius),
        black calc(var(--scoop-radius) + 0.5px)
      ),
      radial-gradient(
        circle at top right,
        transparent var(--scoop-radius),
        black calc(var(--scoop-radius) + 0.5px)
      ),
      radial-gradient(
        circle at bottom left,
        transparent var(--scoop-radius),
        black calc(var(--scoop-radius) + 0.5px)
      ),
      radial-gradient(
        circle at bottom right,
        transparent var(--scoop-radius),
        black calc(var(--scoop-radius) + 0.5px)
      );
    -webkit-mask-position:
      top left,
      top right,
      bottom left,
      bottom right;
    -webkit-mask-size: 51% 51%;
    -webkit-mask-repeat: no-repeat;
    mask-image:
      radial-gradient(
        circle at top left,
        transparent var(--scoop-radius),
        black calc(var(--scoop-radius) + 0.5px)
      ),
      radial-gradient(
        circle at top right,
        transparent var(--scoop-radius),
        black calc(var(--scoop-radius) + 0.5px)
      ),
      radial-gradient(
        circle at bottom left,
        transparent var(--scoop-radius),
        black calc(var(--scoop-radius) + 0.5px)
      ),
      radial-gradient(
        circle at bottom right,
        transparent var(--scoop-radius),
        black calc(var(--scoop-radius) + 0.5px)
      );
    mask-position:
      top left,
      top right,
      bottom left,
      bottom right;
    mask-size: 51% 51%;
    mask-repeat: no-repeat;
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
  }

  .ing-category-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 45px rgba(74, 59, 42, 0.18);
  }

  /* Featured middle card slightly taller */
  .ing-card-featured {
    transform: translateY(-12px);
    box-shadow: 0 20px 45px rgba(74, 59, 42, 0.18);
  }
  .ing-card-featured:hover {
    transform: translateY(-18px);
  }

  .ing-card-img-wrap {
    position: relative;
    overflow: hidden;
    height: 240px;
  }
  .ing-card-featured .ing-card-img-wrap {
    height: 280px;
  }

  .ing-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .ing-category-card:hover .ing-card-img {
    transform: scale(1.06);
  }

  .ing-card-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(36, 26, 15, 0.4) 0%,
      transparent 60%
    );
  }

  .ing-card-body {
    padding: 28px 28px 32px;
  }

  .ing-card-title {
    margin-bottom: 10px;
  }

  .ing-card-desc {
    margin-bottom: 22px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ing-card-btn {
    font-size: 0.85rem;
    padding: 10px 28px;
    letter-spacing: 1px;
  }

  /* ================================================
   EDITORIAL INFO SECTION
   ================================================ */
  .ing-editorial {
    background-color: var(--warm-white);
    padding: 60px 0 80px;
  }

  .ing-editorial-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
  }

  /* Thin divider — used only in CTA section */
  .ing-editorial-rule {
    height: 1px;
    background-color: rgba(74, 59, 42, 0.18);
    margin: 0;
  }

  /* Both rows share the same 3-col grid */
  .ing-editorial-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 40px;
    padding: 0;
  }

  /* Row 1: image column stretches to match col 2 text height */
  .ing-row-top {
    align-items: stretch;
    margin-bottom: 60px;
  }

  /* Row 2: col 1 is blank spacer, cols 2-3 hold content */
  .ing-row-mid {
    align-items: start;
  }

  /* Label above each column */
  .ing-ed-label {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--indochine-teal);
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 700;
    margin-bottom: 20px;
    display: block;

    /* Underline marker */
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(74, 59, 42, 0.15);
  }

  /* Large bold statement (col 1, row 1) */
  .ing-ed-statement {
    font-family: var(--font-serif);
    font-size: 2rem;
    color: var(--mahogany-dark);
    line-height: 1.3;
    font-weight: 400;
    margin: 0;
  }

  /* Body paragraphs */
  .ing-ed-body {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--walnut-brown);
    line-height: 1.75;
    margin-bottom: 16px;
  }
  .ing-ed-body:last-of-type {
    margin-bottom: 0;
  }

  /* Image column — fills the full row height alongside col 2 text */
  .ing-ed-col-img {
    display: flex;
    flex-direction: column;
  }

  .ing-ed-img-box {
    width: 100%;
    /* No fixed height — let it stretch to match the sibling column */
    flex: 1;
    min-height: 220px;
    overflow: hidden;

    /* Scooped corners */
    --scoop-radius: 18px;
    -webkit-mask-image:
      radial-gradient(
        circle at top left,
        transparent var(--scoop-radius),
        black calc(var(--scoop-radius) + 0.5px)
      ),
      radial-gradient(
        circle at top right,
        transparent var(--scoop-radius),
        black calc(var(--scoop-radius) + 0.5px)
      ),
      radial-gradient(
        circle at bottom left,
        transparent var(--scoop-radius),
        black calc(var(--scoop-radius) + 0.5px)
      ),
      radial-gradient(
        circle at bottom right,
        transparent var(--scoop-radius),
        black calc(var(--scoop-radius) + 0.5px)
      );
    -webkit-mask-position:
      top left,
      top right,
      bottom left,
      bottom right;
    -webkit-mask-size: 51% 51%;
    -webkit-mask-repeat: no-repeat;
    mask-image:
      radial-gradient(
        circle at top left,
        transparent var(--scoop-radius),
        black calc(var(--scoop-radius) + 0.5px)
      ),
      radial-gradient(
        circle at top right,
        transparent var(--scoop-radius),
        black calc(var(--scoop-radius) + 0.5px)
      ),
      radial-gradient(
        circle at bottom left,
        transparent var(--scoop-radius),
        black calc(var(--scoop-radius) + 0.5px)
      ),
      radial-gradient(
        circle at bottom right,
        transparent var(--scoop-radius),
        black calc(var(--scoop-radius) + 0.5px)
      );
    mask-position:
      top left,
      top right,
      bottom left,
      bottom right;
    mask-size: 51% 51%;
    mask-repeat: no-repeat;
  }

  .ing-ed-img-box img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .ing-ed-img-box:hover img {
    transform: scale(1.05);
  }

  /* Large quote (row 2, left col) */
  .ing-ed-quote {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    color: var(--mahogany-dark);
    line-height: 1.45;
    font-weight: 400;
    font-style: italic;
    margin: 0;
    quotes: none;
  }

  /* CTA link at bottom of col */
  .ing-ed-link {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--mahogany-dark);
    text-decoration: none;
    letter-spacing: 1.5px;
    margin-top: 28px;
    border-bottom: 1.5px solid var(--mahogany-dark);
    padding-bottom: 2px;
    transition:
      color 0.3s ease,
      border-color 0.3s ease;
  }

  .ing-ed-link:hover {
    color: var(--indochine-teal);
    border-color: var(--indochine-teal);
