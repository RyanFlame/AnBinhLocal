---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import type { Page } from "astro";
import type { CollectionEntry } from "astro:content";
import BlogLayout from "../../layouts/BlogLayout.astro";
import { Image } from "astro:assets";
import { slugify } from "../../utils/slugify";

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const allPosts = await getCollection("blog");
  const viPosts = allPosts
    .filter(post => post.data.lang === 'vi')
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return paginate(viPosts, { pageSize: 6 });
};

interface Props {
  page: Page<CollectionEntry<"blog">>;
}

const { page } = Astro.props as unknown as Props;

// All posts are always Vietnamese
const allPosts = await getCollection("blog");
const viPosts = allPosts
  .filter(post => post.data.lang === 'vi')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const heroSlides = viPosts.slice(0, 6);
const featuredMain = viPosts[0];
const featuredSliderPosts = viPosts.slice(1, 5);
const popularPosts = [
  viPosts[2] || viPosts[0],
  viPosts[4] || viPosts[1],
  viPosts[6] || viPosts[viPosts.length - 1],
].filter(Boolean);

function getPostUrl(postId: string): string {
  return `/blog/${postId.replace(/\.(vi|en)$/, '')}`;
}

const fmt = (date: Date) => new Intl.DateTimeFormat('vi-VN', { month: 'short', day: 'numeric', year: 'numeric' }).format(date);
const fmtShort = (date: Date) => new Intl.DateTimeFormat('vi-VN', { month: 'short', day: 'numeric' }).format(date);
---


<BlogLayout title={`Blog An Bình - Trang ${page.currentPage}/${page.lastPage}`}>
  <h1 class="sr-only">Blog An Bình</h1>
  {page.currentPage === 1 && (
    <section class="hs-section" data-header-theme="dark">
      <div class="hs-viewport" id="hsViewport">
        <div class="hs-track" id="hsTrack">
          {heroSlides.map((post, i) => (
            <div class="hs-slide" data-index={i}>
              <a href={getPostUrl(post.id)} class="hs-slide-link" aria-label={post.data.title}></a>
              <Image class="hs-bg" src={post.data.image as any} alt={post.data.title} />
              <div class="hs-overlay">
                <a href={`/blog/category/${slugify(post.data.category)}`} class="hs-cat">{post.data.category}</a>
                <h2 class="hs-title">{post.data.title}</h2>
                <div class="hs-meta">{post.data.author} &nbsp;•&nbsp; {fmt(post.data.date)}</div>
              </div>
            </div>
          ))}
        </div>
        <button class="hs-arrow hs-prev" id="hsPrev" aria-label="Slide trước">&#8249;</button>
        <button class="hs-arrow hs-next" id="hsNext" aria-label="Slide tiếp">&#8250;</button>
        <div class="hs-dots" id="hsDots">
          {heroSlides.map((_, i) => (
            <span class={`hs-dot ${i === 0 ? 'active' : ''}`}></span>
          ))}
        </div>
      </div>
      <div class="hs-thumb-wrapper">
        <div class="hs-thumb-track" id="hsThumbTrack">
          {heroSlides.map((post, i) => (
            <div class={`hs-thumb ${i === 0 ? 'active' : ''}`} data-index={i}>
              <div class="hs-thumb-img-wrap"><Image src={post.data.image as any} alt={post.data.title} /></div>
              <p class="hs-thumb-title">{post.data.title}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <div class="blog-page">
    {page.currentPage === 1 && featuredMain && (
      <section id="featured" class="featured-section" data-header-theme="light">
        <h2 class="section-heading">NỔI BẬT</h2>
        <div class="heading-underline"></div>
        <div class="featured-grid">
          <div class="post-card main-feature">
            <a href={getPostUrl(featuredMain.id)} class="card-overlay-link" aria-label={featuredMain.data.title}></a>
            <figure class="post-image concave-corner"><Image src={featuredMain.data.image as any} alt={featuredMain.data.title} /></figure>
            <div class="post-content">
              <h3 class="post-title">{featuredMain.data.title}</h3>
              <p class="post-excerpt">{featuredMain.data.excerpt}</p>
              <div class="post-meta">
                <span>{featuredMain.data.author} · <a href={`/blog/category/${slugify(featuredMain.data.category)}`} class="meta-cat-link">{featuredMain.data.category}</a></span>
                <span class="dot">•</span>
                <span>{fmtShort(featuredMain.data.date)}</span>
                <span class="dot">•</span>
                <span>★</span>
              </div>
            </div>
          </div>
          <div class="featured-slider-col">
            <div class="fs-header">
              <div class="fs-nav">
                <button id="fsPrev" class="fs-btn"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"></path></svg></button>
                <button id="fsNext" class="fs-btn"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"></path></svg></button>
              </div>
            </div>
            <div class="fs-viewport">
              <div class="fs-track" id="fsTrack">
                {Array.from({ length: Math.ceil(featuredSliderPosts.length / 2) }, (_, colIdx) => (
                  <div class="fs-slide-col">
                    {featuredSliderPosts.slice(colIdx * 2, colIdx * 2 + 2).map((post) => (
                      <div class="post-card medium">
                        <a href={getPostUrl(post.id)} class="card-overlay-link" aria-label={post.data.title}></a>
                        <figure class="post-image concave-corner"><Image src={post.data.image as any} alt={post.data.title} /></figure>
                        <div class="post-content">
                          <h4 class="post-title">{post.data.title}</h4>
                          <div class="post-meta">
                            <span>{post.data.author} · <a href={`/blog/category/${slugify(post.data.category)}`} class="meta-cat-link">{post.data.category}</a></span>
                            <span class="dot">•</span>
                            <span>{fmtShort(post.data.date)}</span>
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>
    )}

    <div class="bottom-layout">
      <section class="latest-section">
        <h2 class="section-heading">BÀI VIẾT MỚI NHẤT</h2>
        <div class="heading-underline"></div>
        <div class="latest-grid" id="latestGrid">
          {page.data.map((post: CollectionEntry<"blog">) => (
            <div class="post-card main-feature">
              <a href={getPostUrl(post.id)} class="card-overlay-link" aria-label={post.data.title}></a>
              <figure class="post-image concave-corner">
                <Image src={post.data.image as any} alt={post.data.title} />
              </figure>
              <div class="post-content">
                <h3 class="post-title">{post.data.title}</h3>
                <p class="post-excerpt">{post.data.excerpt}</p>
                <div class="post-meta">
                  <span>{post.data.author}</span>
                  <span class="dot">•</span>
                  <span>{fmtShort(post.data.date)}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <aside class="popular-section">
        <h2 class="section-heading">PHỔ BIẾN</h2>
        <div class="heading-underline"></div>
        <div class="popular-list">
          {popularPosts.map((post, i) => (
            <div class="popular-item">
              <a href={getPostUrl(post.id)} class="card-overlay-link" aria-label={post.data.title}></a>
              <span class="popular-number">{String(i + 1).padStart(2, '0')}</span>
              <div class="post-content">
                <h4 class="post-title">{post.data.title}</h4>
                <div class="post-meta">
                  <span>{post.data.author} · <a href={`/blog/category/${slugify(post.data.category)}`} class="meta-cat-link">{post.data.category}</a></span>
                  <span>{fmtShort(post.data.date)}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </aside>
    </div>

    <nav class="pagination-nav" aria-label="Phân trang blog">
      <div class="pagination-info">Trang {page.currentPage} / {page.lastPage}</div>
      <div class="pagination-links">
        {page.url.prev ? (
          <a href={page.url.prev} class="pagination-btn">← Trước</a>
        ) : (
          <span class="pagination-btn disabled">← Trước</span>
        )}
        <div class="page-numbers">
          {[...Array(page.lastPage)].map((_, i) => (
            <a
              href={i === 0 ? "/blog" : `/blog/${i + 1}`}
              class={`page-number ${page.currentPage === i + 1 ? 'active' : ''}`}
            >
              {i + 1}
            </a>
          ))}
        </div>
        {page.url.next ? (
          <a href={page.url.next} class="pagination-btn">Tiếp →</a>
        ) : (
          <span class="pagination-btn disabled">Tiếp →</span>
        )}
      </div>
    </nav>
  </div>
</BlogLayout>

<style>
  :root {
    --blog-bg: #f9f5e3;
    --blog-text: #241a0f;
    --blog-green: #2b3a24;
    --blog-subtext: #5c6755;
    --blog-gold: #c8a97e;
    --blog-border: #e2dac9;
    --scoop-radius: 12px;
  }

  body { background-color: var(--blog-bg) !important; }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .blog-page {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 100px 40px;
    font-family: "Open Sans", sans-serif;
    color: var(--blog-text);
    box-sizing: border-box;
  }

  /* Restored Hero Styles from dist/ */
  .hs-section { width: 90vw !important; max-width: 90vw !important; margin: 24px auto 10px !important; position: relative; user-select: none; }
  
  /* Modified only the viewport height to meet "full screen" request while keeping other styles "old" */
  .hs-viewport { 
    position: relative; 
    width: 100%; 
    height: 70vh; 
    overflow: hidden; 
    background: #1a1208;
    mask-image: radial-gradient(circle at top left, transparent 19px, black 20px), radial-gradient(circle at top right, transparent 19px, black 20px);
    mask-size: 51% 100%; mask-repeat: no-repeat;
    mask-position: top left, top right;
    -webkit-mask-image: radial-gradient(circle at top left, transparent 19px, black 20px), radial-gradient(circle at top right, transparent 19px, black 20px);
    -webkit-mask-size: 51% 100%; -webkit-mask-repeat: no-repeat; -webkit-mask-position: top left, top right;
  }
  
  .hs-track { display: flex; width: 100%; height: 100%; transition: transform 0.65s cubic-bezier(0.77, 0, 0.18, 1); will-change: transform; }
  .hs-slide { flex: 0 0 100%; width: 100%; height: 100%; position: relative; }
  .hs-slide-link { position: absolute; inset: 0; z-index: 2; }
  .hs-bg { width: 100%; height: 100%; object-fit: cover; display: block; }
  .hs-overlay { position: absolute; bottom: 0; left: 0; right: 0; padding: 60px 5% 36px; background: linear-gradient(to top, rgba(20, 12, 4, 0.88) 0%, rgba(20, 12, 4, 0.55) 50%, transparent 100%); color: #fff; z-index: 3; pointer-events: none; }
  
  .hs-cat { pointer-events: auto; position: relative; z-index: 10; display: inline-block; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: var(--blog-gold); background: rgba(200, 169, 126, 0.15); border: 1px solid rgba(200, 169, 126, 0.4); padding: 4px 12px; margin-bottom: 14px; text-decoration: none; }
  .hs-title { font-family: "Merriweather", serif; font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 700; margin: 0 0 12px; line-height: 1.2; text-shadow: 0 4px 12px rgba(0,0,0,0.4); }
  .hs-meta { font-size: 0.9rem; color: rgba(255, 255, 255, 0.7); }

  .hs-arrow { position: absolute; top: 50%; transform: translateY(-50%); width: 46px; height: 46px; border-radius: 50%; border: 1px solid rgba(255, 255, 255, 0.55); background: #f9f5e326; color: #fff; cursor: pointer; display: flex; align-items: center; justify-content: center; z-index: 10; font-size: 1.8rem; backdrop-filter: blur(4px); transition: all 0.3s; }
  .hs-arrow:hover { background: var(--blog-gold); border-color: var(--blog-gold); }
  .hs-prev { left: 24px; }
  .hs-next { right: 24px; }

  .hs-dots { position: absolute; bottom: 18px; left: 50%; transform: translate(-50%); display: flex; gap: 8px; z-index: 10; }
  .hs-dot { width: 7px; height: 7px; border-radius: 50%; background: rgba(255, 255, 255, 0.4); cursor: pointer; transition: all 0.3s; border: none; }
  .hs-dot.active { background: var(--blog-gold); transform: scale(1.35); }

  .hs-thumb-wrapper { width: 100%; overflow: hidden; background: var(--blog-text); }
  .hs-thumb-track { display: flex; transition: transform 0.45s ease; will-change: transform; }
  .hs-thumb { flex: 0 0 25%; display: flex; align-items: center; gap: 14px; padding: 16px 18px; cursor: pointer; background: var(--blog-text); border-top: 3px solid transparent; transition: all 0.3s; box-sizing: border-box; }
  .hs-thumb:hover { background: #3a2a19; }
  .hs-thumb.active { border-top-color: var(--blog-gold); background: #2e2013; }
  .hs-thumb-img-wrap { flex-shrink: 0; width: 72px; height: 52px; overflow: hidden; }
  .hs-thumb-img-wrap img { width: 100%; height: 100%; object-fit: cover; }
  .hs-thumb-title { font-size: 0.85rem; font-weight: 500; color: rgba(255, 255, 255, 0.7); line-height: 1.4; margin: 0; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .hs-thumb.active .hs-thumb-title { color: #fff; }

  /* Standard Content Sections */
  .section-heading { font-family: "Open Sans", sans-serif; font-size: 1.2rem; font-weight: 700; color: var(--blog-text); text-transform: uppercase; margin-bottom: 10px; letter-spacing: 0.5px; }
  .heading-underline { width: 100%; height: 1px; background-color: var(--blog-text); margin-bottom: 40px; opacity: 0.8; }

  .post-card { display: flex; flex-direction: column; margin-bottom: 30px; position: relative; }
  .card-overlay-link { position: absolute; inset: 0; z-index: 2; display: block; border: none; outline: none; }
  .card-overlay-link:focus { outline: 2px solid var(--blog-gold); outline-offset: 4px; }
  .meta-cat-link { position: relative; z-index: 10; color: var(--blog-gold); font-weight: 600; text-decoration: none; pointer-events: auto; }
  .meta-cat-link:hover { text-decoration: underline; }
  .post-title { font-family: "Merriweather", serif; font-weight: 700; color: var(--blog-text); line-height: 1.3; margin-top: 15px; margin-bottom: 8px; cursor: pointer; transition: color 0.3s; }
  .post-card:hover .post-title { color: var(--blog-gold); }
  .post-excerpt { font-size: 0.95rem; color: var(--blog-subtext); line-height: 1.5; margin-bottom: 15px; }
  .post-meta { font-size: 0.8rem; color: #777; display: flex; align-items: center; gap: 8px; flex-wrap: wrap; position: relative; z-index: 3; }
  .post-meta .dot { font-size: 0.5rem; }
  .post-image { width: 100%; margin: 0; box-shadow: 0 4px 15px rgba(0,0,0,0.05); }
  .post-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; }
  .post-card:hover .post-image img { transform: scale(1.05); }

  .post-title {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 2.6em;
  }

  .concave-corner { 
    position: relative; overflow: hidden; 
    mask-image: radial-gradient(circle at top left, transparent 11px, black 12px), radial-gradient(circle at top right, transparent 11px, black 12px), radial-gradient(circle at bottom right, transparent 11px, black 12px), radial-gradient(circle at bottom left, transparent 11px, black 12px);
    mask-size: 51% 51%; mask-repeat: no-repeat;
    mask-position: top left, top right, bottom right, bottom left;
    -webkit-mask-image: radial-gradient(circle at top left, transparent 11px, black 12px), radial-gradient(circle at top right, transparent 11px, black 12px), radial-gradient(circle at bottom right, transparent 11px, black 12px), radial-gradient(circle at bottom left, transparent 11px, black 12px);
    -webkit-mask-size: 51% 51%; -webkit-mask-repeat: no-repeat; -webkit-mask-position: top left, top right, bottom left, bottom right;
  }

  .featured-section { margin-bottom: 80px; }
  .featured-grid { display: grid; grid-template-columns: 1fr 2fr; gap: 40px; }
  .main-feature .post-image { height: 350px; }
  .main-feature .post-title { font-size: 1.6rem; }

  .featured-slider-col { position: relative; width: 100%; display: flex; flex-direction: column; min-width: 0; }
  .fs-header { display: flex; justify-content: flex-end; margin-bottom: 25px; }
  .fs-nav { display: flex; gap: 12px; }
  .fs-btn { width: 44px; height: 44px; border-radius: 50%; border: 1px solid var(--blog-gold); background: transparent; color: var(--blog-gold); cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.3s; }
  .fs-btn:hover { background: var(--blog-gold); color: #fff; }
  .fs-viewport { width: 100%; overflow: hidden; }
  .fs-track { display: flex; gap: 40px; transition: transform 0.6s cubic-bezier(0.77, 0, 0.18, 1); }
  .fs-slide-col { flex: 0 0 calc(50% - 20px); display: flex; flex-direction: column; gap: 40px; min-width: 0; }
  .post-card.medium .post-image { height: 180px; }
  .post-card.medium .post-title { font-size: 1.2rem; }

  .bottom-layout { display: grid; grid-template-columns: 2fr 1fr; gap: 60px; align-items: stretch; }
  .latest-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; }
  .latest-grid .post-image { height: 250px; }
  .latest-grid .post-title { font-size: 1.4rem; }

  .pagination-nav { margin-top: 80px; padding: 40px 0; border-top: 1px solid var(--blog-border); display: flex; flex-direction: column; align-items: center; gap: 24px; width: 100%; }
  .pagination-info { font-size: 0.95rem; font-weight: 600; color: var(--blog-subtext); letter-spacing: 0.5px; }
  .pagination-links { display: flex; align-items: center; gap: 20px; }
  .pagination-btn { padding: 10px 28px; border: 1px solid var(--blog-gold); color: var(--blog-gold); background-color: #fff; text-decoration: none; font-family: "Playfair Display", serif; font-weight: 600; transition: all 0.3s; box-shadow: 0 2px 8px rgba(0,0,0,0.05); }
  .pagination-btn:hover:not(.disabled) { background: var(--blog-gold); color: #fff; transform: translateY(-2px); box-shadow: 0 4px 12px rgba(200, 169, 126, 0.2); }
  .pagination-btn.disabled { opacity: 0.3; cursor: not-allowed; border-color: var(--blog-border); color: var(--blog-subtext); }
  .page-numbers { display: flex; gap: 12px; }
  .page-number { width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; border: 1px solid var(--blog-border); background-color: #fff; text-decoration: none; color: var(--blog-text); font-weight: 600; transition: all 0.3s; }
  .page-number:hover:not(.active) { border-color: var(--blog-gold); color: var(--blog-gold); }
  .page-number.active { background: var(--blog-green); color: #fff; border-color: var(--blog-green); transform: scale(1.1); box-shadow: 0 4px 10px rgba(43, 58, 36, 0.2); }

  .popular-section { position: sticky; top: 90px; align-self: start; height: max-content; }
  .popular-list { display: flex; flex-direction: column; gap: 35px; }
  .popular-item { display: flex; gap: 20px; align-items: flex-start; position: relative; }
  .popular-number { font-size: 2.5rem; font-weight: 800; color: var(--blog-border); line-height: 1; padding-top: 5px; position: relative; z-index: 1; }

  /* Mobile Styles (Full width already handled by removing max-width on containers if needed, but here we keep it outside) */
  @media screen and (max-width: 1024px) {
    .hs-thumb { flex: 0 0 33.333%; }
    .featured-grid, .bottom-layout { grid-template-columns: 1fr; }
    .fs-slide-col { flex: 0 0 100%; width: 100%; }
    .popular-section { position: static; }
  }
  @media screen and (max-width: 768px) {
    .hs-section { width: 100% !important; max-width: 100% !important; margin: 0 !important; }
    .hs-viewport { height: 50vh; }
    .hs-thumb { flex: 0 0 50% !important; padding: 12px 10px; border-right: 1px solid rgba(255,255,255,0.05); }
    .latest-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  (function () {
    const track = document.getElementById("hsTrack") as HTMLElement;
    const thumbTrack = document.getElementById("hsThumbTrack") as HTMLElement;
    const dots = Array.from(document.querySelectorAll(".hs-dot")) as HTMLElement[];
    const thumbs = Array.from(document.querySelectorAll(".hs-thumb")) as HTMLElement[];
    const prevBtn = document.getElementById("hsPrev");
    const nextBtn = document.getElementById("hsNext");

    // Dynamic total — count actual rendered slides
    const TOTAL = track ? track.children.length : 0;
    if (TOTAL === 0) return;

    let current = 0;
    let thumbOffset = 0;

    function getThumbsVisible() {
      if (window.innerWidth <= 768) return 2;
      if (window.innerWidth <= 1024) return 3;
      return 4;
    }

    function goToSlide(rawIndex: number) {
      let index = rawIndex;
      if (index < 0) index = TOTAL - 1;
      if (index >= TOTAL) index = 0;
      current = index;

      if(track) track.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((d, i) => d.classList.toggle("active", i === current));
      thumbs.forEach((t, i) => t.classList.toggle("active", i === current));

      // Centering/Shifting thumb track
      const visible = getThumbsVisible();
      if (TOTAL > visible) {
        if (current >= thumbOffset + visible) {
          thumbOffset = Math.min(TOTAL - visible, current);
        } else if (current < thumbOffset) {
          thumbOffset = Math.max(0, current);
        }
        if (thumbTrack) {
          const shift = (thumbOffset / TOTAL) * 100;
          thumbTrack.style.transform = `translateX(-${shift}%)`;
        }
      }
    }

    if (prevBtn) prevBtn.addEventListener("click", () => goToSlide(current - 1));
    if (nextBtn) nextBtn.addEventListener("click", () => goToSlide(current + 1));

    dots.forEach((dot, index) => {
      dot.addEventListener("click", () => goToSlide(index));
    });

    thumbs.forEach((thumb, index) => {
      thumb.addEventListener("click", () => goToSlide(index));
    });

    // Auto-advance
    let auto = setInterval(() => goToSlide(current + 1), 6000);

    const container = document.querySelector(".hs-viewport");
    if (container) {
      container.addEventListener("mouseenter", () => clearInterval(auto));
      container.addEventListener("mouseleave", () => {
        clearInterval(auto);
        auto = setInterval(() => goToSlide(current + 1), 6000);
      });
    }
    goToSlide(0);

    // Featured Slider Logic
    (function initFeaturedSlider() {
      const fsTrack = document.getElementById("fsTrack");
      const fsPrev = document.getElementById("fsPrev");
      const fsNext = document.getElementById("fsNext");
      if (!fsTrack || !fsPrev || !fsNext) return;
      let fsOffset = 0;
      function updateFs() {
        const isMobile = window.innerWidth <= 1024;
        const width = fsTrack.offsetWidth;
        const step = isMobile ? (width + 40) : (width / 2 + 20);
        fsTrack.style.transform = `translateX(calc(-1 * ${fsOffset} * ${step}px))`;
      }
      fsNext.addEventListener("click", (e) => {
        e.preventDefault();
        const maxOffset = Math.max(0, fsTrack.children.length - (window.innerWidth <= 1024 ? 1 : 2));
        fsOffset = (fsOffset + 1) > maxOffset ? 0 : fsOffset + 1;
        updateFs();
      });
      fsPrev.addEventListener("click", (e) => {
        e.preventDefault();
        const maxOffset = Math.max(0, fsTrack.children.length - (window.innerWidth <= 1024 ? 1 : 2));
        fsOffset = (fsOffset - 1) < 0 ? maxOffset : fsOffset - 1;
        updateFs();
      });
      window.addEventListener("resize", updateFs);
      updateFs();
    })();
  })();
</script>
